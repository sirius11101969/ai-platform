# Reference only. Run ops/bin/as6-init-staging-v1 to generate real values.
# These short sample values intentionally fail deployment validation.
# Never commit the populated .env.staging file.
AS6_ENVIRONMENT=staging
AS6_STAGING_PAYMENT_SIMULATION=true
AS6_STAGING_DOMAIN=staging.as6.ru
AS6_STAGING_HTTP_PORT=18080
AS6_STAGING_DB_PASSWORD=sample
JWT_SECRET=sample
AI_EXECUTION_ADMIN_KEY=sample
APP_URL=https://staging.as6.ru

# Staging must never use live payment credentials.
PAYMENT_MODE=disabled
PAYMENT_WEBHOOK_SECRET=
YOOKASSA_MODE=disabled
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=

# Optional. Leave blank for deterministic UI/API validation without AI calls.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1
