#!/usr/bin/env bash
set -euo pipefail
ROOT="${AS6_REPO_ROOT:-$(git rev-parse --show-toplevel 2>/dev/null || pwd)}"
cd "$ROOT"

fail=0

check_file() {
  if [ -f "$1" ]; then
    echo "OK:$1"
  else
    echo "FAIL:$1"
    fail=1
  fi
}

echo "=== AS6 AI Workforce Status ==="

check_file ".github/workflows/as6-codex-review.yml"
check_file ".github/workflows/as6-backend-agent.yml"
check_file ".github/workflows/as6-frontend-agent.yml"
check_file ".github/workflows/as6-devops-agent.yml"

check_file ".github/codex/prompts/as6-pr-review.md"
check_file ".github/codex/prompts/as6-backend-agent.md"
check_file ".github/codex/prompts/as6-frontend-agent.md"
check_file ".github/codex/prompts/as6-devops-agent.md"

check_file "ops/bin/as6-diagnose-codex-workflow"

./ops/bin/as6-diagnose-codex-workflow

if [ "$fail" -eq 0 ]; then
  echo "AS6_AI_WORKFORCE_STATUS=OK"
  exit 0
fi

echo "AS6_AI_WORKFORCE_STATUS=FAIL"
exit 1

# AS6 v7 diagnostic: ops/bin/as6-diagnose-agent-write-mode

# AS6 v8 diagnostic: ops/bin/as6-diagnose-controlled-write-mode

# AS6 v9 diagnostic: ops/bin/as6-diagnose-controlled-branch-writer

# AS6 v9 writer diagnostic: ops/bin/as6-diagnose-agent-branch-writer

# AS6 workflow YAML diagnostic: ops/bin/as6-diagnose-workflow-yaml

# AS6 Agent Branch Writer E2E diagnostic: ops/bin/as6-diagnose-agent-branch-writer-e2e

# AS6 Agent PR Factory E2E diagnostic: ops/bin/as6-diagnose-agent-pr-factory-e2e

# AS6 GitHub Actions Node 24 readiness diagnostic: ops/bin/as6-diagnose-actions-node24

# AS6 GitHub Actions Node 24 migration diagnostic: ops/bin/as6-diagnose-actions-node24-migration

