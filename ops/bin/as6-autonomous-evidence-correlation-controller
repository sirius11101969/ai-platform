#!/usr/bin/env bash
set -euo pipefail
cd /var/www/ai-platform
fail=0
warn=0
dir="runtime/evidence-correlation"
bundle="$dir/evidence"
mkdir -p "$bundle"
out="$dir/latest.out"
matrix="$dir/evidence-correlation-matrix.tsv"
summary="$dir/evidence-summary.env"
: > "$out"
: > "$matrix"
: > "$summary"
say(){ echo "$1" | tee -a "$out"; }
ok(){ say "PASS: $1"; }
soft(){ say "WARN: $1"; warn=1; }
bad(){ say "FAIL: $1"; fail=1; }
capture(){ name="$1"; file="$2"; shift 2; say "--- capture: $name ---"; if "$@" > "$file" 2>&1; then ok "$name"; else bad "$name"; fi; cat "$file" >> "$out"; }

say "=== AS6 AUTONOMOUS EVIDENCE CORRELATION CONTROLLER V2 ==="

say "--- live controller evidence capture ---"
[ -x ops/bin/as6-autonomous-rollback-verification-controller ] && capture "rollback verification" "$bundle/rollback-verification.out" ops/bin/as6-autonomous-rollback-verification-controller || bad "rollback verification controller missing"
[ -x ops/bin/as6-autonomous-deployment-controller ] && capture "deployment controller" "$bundle/deployment-controller.out" ops/bin/as6-autonomous-deployment-controller || bad "deployment controller missing"
[ -x ops/bin/as6-autonomous-change-approval-controller ] && capture "change approval" "$bundle/change-approval.out" ops/bin/as6-autonomous-change-approval-controller || soft "change approval controller missing"
[ -x ops/bin/as6-autonomous-governance-compliance-controller ] && capture "governance compliance" "$bundle/governance-compliance.out" ops/bin/as6-autonomous-governance-compliance-controller || soft "governance compliance controller missing"
[ -x ops/bin/as6-autonomous-incident-lifecycle-controller ] && capture "incident lifecycle" "$bundle/incident-lifecycle.out" ops/bin/as6-autonomous-incident-lifecycle-controller || soft "incident lifecycle controller missing"
[ -x ops/bin/as6-autonomous-knowledge-base-controller ] && capture "knowledge base" "$bundle/knowledge-base.out" ops/bin/as6-autonomous-knowledge-base-controller || soft "knowledge base controller missing"

say "--- evidence matrix ---"
printf "%s\t%s\t%s\t%s\n" "artifact" "exists" "result_marker" "evidence_pointer" > "$matrix"
for f in runtime/*/latest.out runtime/*/*.env runtime/*/*.tsv runtime/incidents/current.env; do
  [ -e "$f" ] || continue
  result="NO"
  pointer="NO"
  grep -Eq "RESULT=OK|=PASS|STATUS=NONE|VERIFICATION=OK|COMPLIANCE=OK|DRIFT_STATUS=NONE|DECISION=" "$f" && result="YES" || true
  grep -Eq "EVIDENCE=|runtime/|latest.out|MATRIX=" "$f" && pointer="YES" || true
  printf "%s\tYES\t%s\t%s\n" "$f" "$result" "$pointer" >> "$matrix"
  [ "$result" = "YES" ] && ok "result marker: $f" || soft "weak result marker: $f"
done

say "--- required evidence contracts ---"
check_contract(){ file="$1"; pattern="$2"; if [ -f "$file" ]; then if grep -q "$pattern" "$file"; then ok "contract OK: $file"; else soft "contract weak: $file pattern=$pattern"; fi; else soft "missing evidence file: $file"; fi; }
check_contract runtime/rollback-verification/latest.out AS6_AUTONOMOUS_ROLLBACK_VERIFICATION_RESULT=OK
check_contract runtime/deployment-controller/latest.out AS6_AUTONOMOUS_DEPLOYMENT_CONTROLLER_RESULT=OK
check_contract runtime/change-approval/latest.out AS6_CHANGE_APPROVAL_RESULT=OK
check_contract runtime/governance-compliance/latest.out AS6_GOVERNANCE_COMPLIANCE_RESULT=OK

say "--- orphan evidence scan ---"
orphan=0
for f in runtime/*/*.out runtime/*/*.env runtime/*/*.md runtime/*/*.tsv; do
  [ -e "$f" ] || continue
  case "$f" in runtime/evidence-correlation/*) ok "self evidence accepted: $f"; continue ;; esac
  base="$(basename "$f")"
  if grep -Rqs "$base" docs ops runtime/evidence-correlation 2>/dev/null; then ok "evidence discoverable: $f"; else soft "runtime-only evidence: $f"; orphan=$((orphan+1)); fi
done

say "--- secret safety ---"
if git ls-files .env 2>/dev/null | grep -Fxq ".env"; then bad ".env is tracked by git"; else ok ".env is not tracked by git"; fi
if [ -x ops/bin/as6-pre-commit-secret-scan ]; then capture "secret scan" "$bundle/secret-scan.out" ops/bin/as6-pre-commit-secret-scan; else soft "secret scan missing"; fi

printf "%s\n" "AS6_EVIDENCE_CORRELATION_ORPHAN_COUNT=$orphan" "AS6_EVIDENCE_CORRELATION_MATRIX=$matrix" "AS6_EVIDENCE_CORRELATION_EVIDENCE=$out" > "$summary"
ok "summary generated: $summary"

say "--- result ---"
if [ "$fail" -eq 0 ]; then
  say "AS6_EVIDENCE_CORRELATION=PASS"
  [ "$warn" -eq 1 ] && say "AS6_EVIDENCE_CORRELATION_WARNINGS=PRESENT" || say "AS6_EVIDENCE_CORRELATION_WARNINGS=NONE"
  say "AS6_EVIDENCE_CORRELATION_RESULT=OK"
else
  say "AS6_EVIDENCE_CORRELATION=FAIL"
  say "AS6_EVIDENCE_CORRELATION_RESULT=FAIL"
fi
say "AS6_EVIDENCE_CORRELATION_EVIDENCE=$out"
say "AS6_EVIDENCE_CORRELATION_MATRIX=$matrix"
exit "$fail"
