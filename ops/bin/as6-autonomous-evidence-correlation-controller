#!/usr/bin/env bash
set -euo pipefail
cd /var/www/ai-platform
fail=0; warn=0
dir="runtime/evidence-correlation"; mkdir -p "$dir/evidence"
out="$dir/latest.out"; matrix="$dir/evidence-correlation-matrix.tsv"; summary="$dir/evidence-summary.env"
: > "$out"; : > "$matrix"; : > "$summary"
say(){ echo "$1" | tee -a "$out"; }
ok(){ say "PASS: $1"; }
soft(){ say "WARN: $1"; warn=1; }
bad(){ say "FAIL: $1"; fail=1; }
say "=== AS6 AUTONOMOUS EVIDENCE CORRELATION CONTROLLER ==="
printf "%s\t%s\t%s\n" "artifact" "result_marker" "status" > "$matrix"
for f in runtime/*/latest.out runtime/*/*.env runtime/*/*.tsv runtime/incidents/current.env; do
  [ -e "$f" ] || continue
  if grep -Eq "RESULT=OK|=PASS|STATUS=NONE|COMPLIANCE=OK|DRIFT_STATUS=NONE|DECISION=" "$f"; then
    printf "%s\tYES\tPASS\n" "$f" >> "$matrix"; ok "evidence result marker: $f"
  else
    printf "%s\tNO\tWARN\n" "$f" >> "$matrix"; soft "weak evidence result marker: $f"
  fi
done
[ -f runtime/rollback-verification/latest.out ] && ok "rollback evidence exists" || soft "rollback evidence missing"
[ -f runtime/deployment-controller/latest.out ] && ok "deployment evidence exists" || soft "deployment evidence missing"
[ -f runtime/autonomy-score/latest.out ] && ok "autonomy score evidence exists" || soft "autonomy score evidence missing"
if git ls-files .env 2>/dev/null | grep -Fxq ".env"; then bad ".env is tracked by git"; else ok ".env is not tracked by git"; fi
[ -x ops/bin/as6-pre-commit-secret-scan ] && ops/bin/as6-pre-commit-secret-scan >> "$out" 2>&1 && ok "secret scan" || soft "secret scan unavailable or warning"
printf "%s\n" "AS6_EVIDENCE_CORRELATION_MATRIX=$matrix" "AS6_EVIDENCE_CORRELATION_EVIDENCE=$out" > "$summary"
if [ "$fail" -eq 0 ]; then say "AS6_EVIDENCE_CORRELATION=PASS"; say "AS6_EVIDENCE_CORRELATION_RESULT=OK"; exit 0; else say "AS6_EVIDENCE_CORRELATION=FAIL"; say "AS6_EVIDENCE_CORRELATION_RESULT=FAIL"; exit 1; fi
