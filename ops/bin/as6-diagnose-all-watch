#!/usr/bin/env bash
set -Eeuo pipefail

log="${AS6_DIAGNOSE_ALL_WATCH_LOG:-/tmp/as6-diagnose-all-watch.out}"
heartbeat="${AS6_WATCH_HEARTBEAT_SECONDS:-20}"
slow="${AS6_WATCH_SLOW_THRESHOLD:-60}"

: > "$log"

echo "AS6_DIAGNOSE_ALL_WATCH_LOG=$log"
echo "AS6_DIAGNOSE_ALL_WATCH_HEARTBEAT=${heartbeat}s"
echo "AS6_DIAGNOSE_ALL_WATCH_STARTED=$(date -u +%Y-%m-%dT%H:%M:%SZ)"

start="$(date +%s)"
last_heartbeat="$start"
ok=0
fail=0
current="starting"
current_start="$start"

run_check() {
  name="$1"
  shift

  current="$name"
  current_start="$(date +%s)"

  echo
  echo "=== RUN: $name ===" | tee -a "$log"

  tmp="$(mktemp)"
  set +e
  "$@" > "$tmp" 2>&1
  rc="$?"
  set -e

  cat "$tmp" | tee -a "$log"
  rm -f "$tmp"

  now="$(date +%s)"
  elapsed="$((now - start))"
  age="$((now - current_start))"

  if [ "$age" -ge "$slow" ]; then
    echo "AS6_WATCH_SLOW_CONTROLLER=${name}:${age}s" | tee -a "$log"
  fi

  if [ "$rc" -eq 0 ]; then
    ok="$((ok + 1))"
    echo "AS6_DIAGNOSE_ALL_CHECK=OK:$name" | tee -a "$log"
  else
    fail="$((fail + 1))"
    echo "NEW_FAIL_DETECTED=$(date -u +%Y-%m-%dT%H:%M:%SZ)" | tee -a "$log"
    echo "AS6_DIAGNOSE_ALL_CHECK=FAIL:$name" | tee -a "$log"
  fi

  echo "AS6_WATCH_PROGRESS elapsed=${elapsed}s OK=${ok} FAIL=${fail} current=${name}" | tee -a "$log"
}

heartbeat_line() {
  now="$(date +%s)"
  elapsed="$((now - start))"
  age="$((now - current_start))"
  echo "AS6_WATCH_HEARTBEAT time=$(date -u +%Y-%m-%dT%H:%M:%SZ) elapsed=${elapsed}s OK=${ok} FAIL=${fail} current=${current} current_age=${age}s" | tee -a "$log"
}

if [ ! -x ops/bin/as6-diagnose-all ]; then
  echo "AS6_DIAGNOSE_ALL_WATCH_RESULT=FAIL:no ops/bin/as6-diagnose-all"
  exit 1
fi

controllers="$(grep -Eo "as6-diagnose-[A-Za-z0-9_-]+" ops/bin/as6-diagnose-all | sed 's/^as6-diagnose-//' | awk '!seen[$0]++')"

if [ -z "$controllers" ]; then
  echo "AS6_DIAGNOSE_ALL_WATCH_RESULT=FAIL:no controllers found"
  exit 1
fi

for name in $controllers; do
  now="$(date +%s)"
  if [ "$((now - last_heartbeat))" -ge "$heartbeat" ]; then
    heartbeat_line
    last_heartbeat="$now"
  fi

  cmd="ops/bin/as6-diagnose-${name}"
  if [ -x "$cmd" ]; then
    run_check "$name" "$cmd"
  fi

  now="$(date +%s)"
  if [ "$((now - last_heartbeat))" -ge "$heartbeat" ]; then
    heartbeat_line
    last_heartbeat="$now"
  fi
done

echo
echo "AS6_DIAGNOSE_ALL_WATCH_SUMMARY OK=${ok} FAIL=${fail}" | tee -a "$log"

if [ "$fail" -eq 0 ]; then
  echo "AS6_DIAGNOSE_ALL_WATCH_RESULT=OK" | tee -a "$log"
  exit 0
else
  echo "AS6_DIAGNOSE_ALL_WATCH_RESULT=FAIL" | tee -a "$log"
  exit 1
fi
