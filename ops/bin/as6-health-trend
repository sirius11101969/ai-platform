#!/usr/bin/env bash
set -euo pipefail

ROOT="${AS6_REPO_ROOT:-$(git rev-parse --show-toplevel 2>/dev/null || pwd)}"
cd "$ROOT"

RECENT_WINDOW="${AS6_HEALTH_TREND_RECENT_WINDOW:-3}"
MIN_RECOVERY_OK="${AS6_HEALTH_TREND_MIN_RECOVERY_OK:-1}"

echo "=== AS6 Health Trend ==="

python3 - <<PY
import json
from pathlib import Path

history_dir = Path("runtime/health/history")
files = sorted(history_dir.glob("*.json"))[-20:]
recent_window = int("$RECENT_WINDOW")
min_recovery_ok = int("$MIN_RECOVERY_OK")

print(f"HEALTH_TREND_HISTORY_DIR={history_dir}")
print(f"HEALTH_TREND_TOTAL_SAMPLES={len(files)}")
print(f"HEALTH_TREND_RECENT_WINDOW={recent_window}")
print(f"HEALTH_TREND_MIN_RECOVERY_OK={min_recovery_ok}")

if not files:
    print("HEALTH_TREND_RESULT=NO_DATA")
    raise SystemExit(0)

ok = fail = warn = 0
latest = None
samples = []

for p in files:
    try:
        data = json.loads(p.read_text())
    except Exception:
        fail += 1
        samples.append(("FAIL", p.name, "invalid_json"))
        continue

    latest = data
    status = data.get("platform_status", "UNKNOWN")
    cache = data.get("health_cache_result", "UNKNOWN")
    root = data.get("root_cause", "unknown")

    if cache == "OK" and status == "OK" and root in ("none", "", "unknown"):
        ok += 1
        samples.append(("OK", p.name, root))
    elif cache == "OK" and status == "OK":
        warn += 1
        samples.append(("WARN", p.name, root))
    else:
        fail += 1
        samples.append(("FAIL", p.name, root))

print(f"HEALTH_TREND_OK_COUNT={ok}")
print(f"HEALTH_TREND_WARN_COUNT={warn}")
print(f"HEALTH_TREND_FAIL_COUNT={fail}")

if latest:
    print(f"HEALTH_TREND_LATEST_TIMESTAMP={latest.get('timestamp', 'unknown')}")
    print(f"HEALTH_TREND_LATEST_GIT_SHA={latest.get('git_sha', 'unknown')}")
    print(f"HEALTH_TREND_LATEST_PLATFORM={latest.get('platform_status', 'UNKNOWN')}")
    print(f"HEALTH_TREND_LATEST_ROOT_CAUSE={latest.get('root_cause', 'unknown')}")
    print(f"HEALTH_TREND_NEXT_ACTION={latest.get('next_action', 'inspect_health')}")

recent = samples[-recent_window:] if recent_window > 0 else []
recent_ok = sum(1 for item in recent if item[0] == "OK")
recent_warn = sum(1 for item in recent if item[0] == "WARN")
recent_fail = sum(1 for item in recent if item[0] == "FAIL")

last_fail_index = max((idx for idx, item in enumerate(samples) if item[0] == "FAIL"), default=-1)
ok_after_last_fail = sum(1 for item in samples[last_fail_index + 1:] if item[0] == "OK")
latest_state = samples[-1][0] if samples else "UNKNOWN"

print(f"HEALTH_TREND_RECENT_OK_COUNT={recent_ok}")
print(f"HEALTH_TREND_RECENT_WARN_COUNT={recent_warn}")
print(f"HEALTH_TREND_RECENT_FAIL_COUNT={recent_fail}")
print(f"HEALTH_TREND_OK_AFTER_LAST_FAIL={ok_after_last_fail}")
print(f"HEALTH_TREND_LATEST_STATE={latest_state}")

if latest_state == "OK" and ok_after_last_fail >= min_recovery_ok:
    print("HEALTH_TREND_HISTORICAL_FAILURES=YES" if fail else "HEALTH_TREND_HISTORICAL_FAILURES=NO")
    print("HEALTH_TREND_RECENT_RECOVERY=OK")
    print("HEALTH_TREND_RESULT=OK")
    raise SystemExit(0)

if recent and recent_fail == 0 and recent_ok + recent_warn == len(recent):
    print("HEALTH_TREND_HISTORICAL_FAILURES=YES" if fail else "HEALTH_TREND_HISTORICAL_FAILURES=NO")
    print("HEALTH_TREND_RECENT_RECOVERY=OK")
    if recent_warn > 0:
        print("HEALTH_TREND_RESULT=WARN")
        raise SystemExit(0)
    print("HEALTH_TREND_RESULT=OK")
    raise SystemExit(0)

print("HEALTH_TREND_HISTORICAL_FAILURES=YES" if fail else "HEALTH_TREND_HISTORICAL_FAILURES=NO")
print("HEALTH_TREND_RECENT_RECOVERY=NO")
if fail:
    print("HEALTH_TREND_RESULT=FAIL")
    raise SystemExit(1)
if warn:
    print("HEALTH_TREND_RESULT=WARN")
    raise SystemExit(0)

print("HEALTH_TREND_RESULT=OK")
PY
