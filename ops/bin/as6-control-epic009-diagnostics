#!/usr/bin/env bash
set -euo pipefail
ops/bin/as6-diagnose-epic009-diagnostics
grep -q AS6_OPERATING_SYSTEM_DIAGNOSTIC_BASELINE_MISSING ops/governance/as6-epic009-diagnostics-root-cause.md
