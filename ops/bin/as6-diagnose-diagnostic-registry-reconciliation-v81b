#!/usr/bin/env bash
set -euo pipefail
FAIL=0
find ops/bin -maxdepth 1 -type f \( -name "as6-diagnose-*" -o -name "as6-control-*" \) | sort > runtime/as6-v81b/reconciliation.index
while IFS= read -r artifact; do
  if ! grep -Rqs "$artifact" ops/registry; then
    echo "AS6_DIAGNOSTIC_ARTIFACT_REGISTRY_GAP_DISCOVERED=$artifact"
    FAIL=1
  fi
done < runtime/as6-v81b/reconciliation.index
if [ "$FAIL" -ne 0 ]; then exit 1; fi
echo "AS6_DIAGNOSTIC_REGISTRY_RECONCILIATION=PASS"
