#!/usr/bin/env bash
set -euo pipefail

test -x ops/bin/as6-grep-safe
test -f docs/epic015/AS6_EPIC015_CRM_NEXT_MODULE_SELECTION.md

ops/bin/as6-grep-safe -R "CRM_ACTIVITIES_TASKS" docs/epic015 ops docs
ops/bin/as6-grep-safe -R "AS6_EPIC015_SLICE01_CRM_ACTIVITIES_TASKS_DOMAIN_MODEL" docs/epic015
ops/bin/as6-grep-safe -R "REUSE_CONTACTS_FOUNDATION=TRUE" docs/epic015
ops/bin/as6-grep-safe -R "REUSE_COMPANIES_FOUNDATION=TRUE" docs/epic015
ops/bin/as6-grep-safe -R "REUSE_DEALS_FOUNDATION=TRUE" docs/epic015
ops/bin/as6-grep-safe -R "USE_EXISTING_CRM_WORKSPACE=TRUE" docs/epic015
ops/bin/as6-grep-safe -R "USE_EXISTING_CRM_LAYOUT=TRUE" docs/epic015
ops/bin/as6-grep-safe -R "USE_AS6_GREP_SAFE=TRUE" docs/epic015
ops/bin/as6-grep-safe -R "USE_EPIC_COMPLETION_MARKER_GUARD=TRUE" docs/epic015
ops/bin/as6-grep-safe -R "NO_PARALLEL_SHELL=TRUE" docs/epic015
ops/bin/as6-grep-safe -R "NO_OWN_ROUTER=TRUE" docs/epic015
ops/bin/as6-grep-safe -R "NO_OWN_STORE=TRUE" docs/epic015
ops/bin/as6-grep-safe -R "NO_STORAGE=TRUE" docs/epic015
ops/bin/as6-grep-safe -R "NO_API_CALLS=TRUE" docs/epic015
ops/bin/as6-grep-safe -R "NO_BUSINESS_WORKFLOW=TRUE" docs/epic015
ops/bin/as6-grep-safe -R "PLATFORM_MUTATION=FALSE" docs/epic015

ops/bin/as6-grep-safe -R "AS6_EPIC012_CRM_CONTACTS=PRODUCTION_VALIDATED" docs ops runtime
ops/bin/as6-grep-safe -R "AS6_EPIC013_CRM_COMPANIES=PRODUCTION_VALIDATED" docs ops runtime
ops/bin/as6-grep-safe -R "AS6_EPIC014_CRM_DEALS=PRODUCTION_VALIDATED" docs ops runtime

echo "AS6_EPIC015_CRM_NEXT_MODULE_SELECTION=PASS"
echo "AS6_EPIC015_NEXT_MODULE=CRM_ACTIVITIES_TASKS"
