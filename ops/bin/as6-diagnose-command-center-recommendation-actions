#!/usr/bin/env bash
set -euo pipefail
echo "=== AS6 Command Center Recommendation Actions Diagnostics ==="
f="frontend/src/pages/CommandCenterPage.jsx"
css="frontend/src/theme/as6Theme.css"
fail=0
grep -q "href: '/crm?filter=priority'" "$f" && echo "AS6_RECOMMENDATION_CARD_FOCUS_LINK=PASS" || { echo "AS6_RECOMMENDATION_CARD_FOCUS_LINK=FAIL"; fail=1; }
grep -q "href: '/ai-revenue-intelligence'" "$f" && echo "AS6_RECOMMENDATION_CARD_ANALYTICS_LINK=PASS" || { echo "AS6_RECOMMENDATION_CARD_ANALYTICS_LINK=FAIL"; fail=1; }
grep -q "href: '/ai-workforce-center'" "$f" && echo "AS6_RECOMMENDATION_CARD_OPTIMIZATION_LINK=PASS" || { echo "AS6_RECOMMENDATION_CARD_OPTIMIZATION_LINK=FAIL"; fail=1; }
grep -q "href: '/ai-executive-brain'" "$f" && echo "AS6_RECOMMENDATION_CARD_RISK_LINK=PASS" || { echo "AS6_RECOMMENDATION_CARD_RISK_LINK=FAIL"; fail=1; }
grep -q "recommendation-action" "$f" && grep -q "a.recommendation" "$css" && echo "AS6_RECOMMENDATION_CARD_CLICKABLE=PASS" || { echo "AS6_RECOMMENDATION_CARD_CLICKABLE=FAIL"; fail=1; }
if [ "$fail" -eq 0 ]; then echo "AS6_RECOMMENDATION_CARD_ACTIONS_RESULT=OK"; exit 0; fi
echo "AS6_RECOMMENDATION_CARD_ACTIONS_RESULT=FAIL"; exit 1
