#!/usr/bin/env bash
set -euo pipefail

cd "${AS6_REPO_ROOT:-$(git rev-parse --show-toplevel 2>/dev/null || pwd)}"

echo "=== AS6 Autonomous Engineering Constitution Diagnostics ==="
fail=0
DOC="docs/AS6_AUTONOMOUS_ENGINEERING_CONSTITUTION.md"
GOV="ops/governance/as6-engineering-standard.md"

check_file(){ test -s "$1" && echo "$2=PASS:$1" || { echo "$2=FAIL:$1"; fail=1; }; }
check_contains(){ grep -q "$2" "$1" && echo "$3=PASS" || { echo "$3=FAIL"; fail=1; }; }

check_file "$DOC" AS6_CONSTITUTION_DOCUMENT
check_file "$GOV" AS6_GOVERNANCE_MIRROR

for gate in AS6_PRE_INSPECTION AS6_DIAGNOSTICS AS6_FACT_CONFIRMATION AS6_ROOT_CAUSE_CONFIRMED AS6_ROLLBACK_READY AS6_ARCHITECTURE_VALIDATED AS6_POST_FIX_DIAGNOSTICS AS6_PRODUCTION_VALIDATED AS6_FIX_CONFIRMED AS6_COVERAGE_UPDATED AS6_REGISTRY_UPDATED AS6_ERROR_ADDED_TO_DIAGNOSTICS AS6_AUTO_DETECTION_ENABLED AS6_ARTIFACTS_CAPTURED AS6_GIT_CLEAN AS6_PR_ALLOWED AS6_CODEX_REVIEW AS6_GUARDIAN_REVIEW AS6_MERGE_ALLOWED AS6_POST_MERGE_VALIDATED AS6_HEREDOC_SAFETY; do
  check_contains "$DOC" "$gate" "$gate"
done

check_contains "$DOC" "Always write correct heredoc" AS6_RULE_HEREDOC_SAFETY
check_contains "$DOC" "Diagnostics First" AS6_RULE_DIAGNOSTICS_FIRST
check_contains "$DOC" "Root Cause First" AS6_RULE_ROOT_CAUSE_FIRST
check_contains "$DOC" "Backup Before Change" AS6_RULE_BACKUP_FIRST
check_contains "$DOC" "Every incident must become a diagnostic" AS6_RULE_INCIDENT_TO_DIAGNOSTIC
check_contains "$DOC" "Diagnostics must show only real problems" AS6_RULE_REAL_PROBLEMS_ONLY
check_contains "$DOC" "AS6_ENV_CONTRACT=PASS" "AS6_ENV_CONTRACT"
check_contains "$DOC" "AS6_ENV_SECRET_VALUES_HIDDEN=PASS" "AS6_ENV_SECRET_VALUES_HIDDEN"
check_contains "$DOC" "AS6_ENV_NOT_TRACKED=PASS" "AS6_ENV_NOT_TRACKED"
check_contains "$DOC" "AS6_ENV_CONTRACT_WARNINGS_ARE_NON_BLOCKING=PASS" "AS6_ENV_CONTRACT_WARNINGS_ARE_NON_BLOCKING"
check_contains "$DOC" "AS6_GENERATED_PYTHON_CONTRACT_COVERAGE=PASS" "AS6_GENERATED_PYTHON_CONTRACT_COVERAGE"
check_contains "$DOC" "AS6_GENERATED_PYTHON_CONTRACT_TRACKING_COVERAGE=PASS" "AS6_GENERATED_PYTHON_CONTRACT_TRACKING_COVERAGE"
check_contains "$DOC" "AS6_GENERATED_PYTHON_CONTRACT_REGISTRY_COVERAGE=PASS" "AS6_GENERATED_PYTHON_CONTRACT_REGISTRY_COVERAGE"
check_contains "$DOC" "AS6_GENERATED_PYTHON_HELPER_CONTRACT_COVERAGE=PASS" "AS6_GENERATED_PYTHON_HELPER_CONTRACT_COVERAGE"
check_contains "$DOC" "AS6_GENERATED_PYTHON_DIAGNOSTIC_CONTRACT_COVERAGE=PASS" "AS6_GENERATED_PYTHON_DIAGNOSTIC_CONTRACT_COVERAGE"
check_contains "$DOC" "AS6_DIAGNOSTIC_TRACKING_SINGLE_FILE_DRIFT=PASS" "AS6_DIAGNOSTIC_TRACKING_SINGLE_FILE_DRIFT"
check_contains "$DOC" "AS6_GENERATED_PYTHON_CONTRACT_HELPER_IMPORT_SAFE=PASS" "AS6_GENERATED_PYTHON_CONTRACT_HELPER_IMPORT_SAFE"
check_contains "$DOC" "AS6_GENERATED_PYTHON_CONTRACT_IMPORT_GUARD=PASS" "AS6_GENERATED_PYTHON_CONTRACT_IMPORT_GUARD"
check_contains "$DOC" "AS6_GENERATED_PYTHON_CONTRACTS=PASS" "AS6_GENERATED_PYTHON_CONTRACTS"
check_contains "$DOC" "AS6_GENERATED_PYTHON_HELPER_TRACKING=PASS" "AS6_GENERATED_PYTHON_HELPER_TRACKING"
check_contains "$DOC" "AS6_GENERATED_PYTHON_REGRESSION_CONTRACT=PASS" "AS6_GENERATED_PYTHON_REGRESSION_CONTRACT"
check_contains "$DOC" "AS6_GENERATED_PYTHON_COMPILE_CONTRACT=PASS" "AS6_GENERATED_PYTHON_COMPILE_CONTRACT"
check_contains "$DOC" "AS6_GENERATED_PYTHON_RUNTIME_CONTRACT_AGGREGATE=PASS" "AS6_GENERATED_PYTHON_RUNTIME_CONTRACT_AGGREGATE"
check_contains "$DOC" "AS6_GENERATED_PYTHON_NAMEERROR_CONTRACT=PASS" "AS6_GENERATED_PYTHON_NAMEERROR_CONTRACT"
check_contains "$DOC" "AS6_GENERATED_PYTHON_IMPORT_CONTRACT=PASS" "AS6_GENERATED_PYTHON_IMPORT_CONTRACT"
check_contains "$DOC" "AS6_DIAGNOSTIC_TRACKING_COVERAGE=PASS" "AS6_DIAGNOSTIC_TRACKING_COVERAGE"
check_contains "$DOC" "AS6_DIAGNOSTIC_TRACKING_CONSISTENCY=PASS" "AS6_DIAGNOSTIC_TRACKING_CONSISTENCY"
check_contains "$DOC" "AS6_DIAGNOSTIC_GIT_TRACKING=PASS" "AS6_DIAGNOSTIC_GIT_TRACKING"
check_contains "$DOC" "AS6_GENERATED_PYTHON_COMPILE_TARGET_SAFE=PASS" "AS6_GENERATED_PYTHON_COMPILE_TARGET_SAFE"
check_contains "$DOC" "AS6_GENERATED_PYTHON_IMPORT_SAFE=PASS" "AS6_GENERATED_PYTHON_IMPORT_SAFE"
check_contains "$DOC" "AS6_GENERATED_PYTHON_PYCACHE_CLEANUP=PASS" "AS6_GENERATED_PYTHON_PYCACHE_CLEANUP"
check_contains "$DOC" "AS6_GENERATED_PYTHON_RUNTIME_CLEANUP=PASS" "AS6_GENERATED_PYTHON_RUNTIME_CLEANUP"
check_contains "$DOC" "AS6_GENERATED_PYTHON_SELF_IMPORT_GUARD=PASS" "AS6_GENERATED_PYTHON_SELF_IMPORT_GUARD"
check_contains "$DOC" "AS6_GENERATED_PYTHON_SELF_IMPORT_EXCLUSION=PASS" "AS6_GENERATED_PYTHON_SELF_IMPORT_EXCLUSION"
check_contains "$DOC" "AS6_GENERATED_PYTHON_RUNTIME_CONTRACT=PASS" "AS6_GENERATED_PYTHON_RUNTIME_CONTRACT"
check_contains "$DOC" "AS6_GENERATED_PYTHON_REGRESSION=PASS" "AS6_GENERATED_PYTHON_REGRESSION"
check_contains "$DOC" "AS6_GENERATED_PYTHON_NAMEERROR=PASS" "AS6_GENERATED_PYTHON_NAMEERROR"
check_contains "$DOC" "AS6_GENERATED_PYTHON_IMPORTS=PASS" "AS6_GENERATED_PYTHON_IMPORTS"
check_contains "$DOC" "AS6_GENERATED_PYTHON_RUNTIME=PASS" "AS6_GENERATED_PYTHON_RUNTIME"
check_contains "$DOC" "AS6_NAMEERROR_SIGNATURE_SCOPE=PASS" "AS6_NAMEERROR_SIGNATURE_SCOPE"
check_contains "$DOC" "AS6_RUNTIME_DIAGNOSTIC_BACKUP_NOT_SCANNED=PASS" "AS6_RUNTIME_DIAGNOSTIC_BACKUP_NOT_SCANNED"
check_contains "$DOC" "AS6_BACKUP_ARTIFACT_EXCLUSION=PASS" "AS6_BACKUP_ARTIFACT_EXCLUSION"
check_contains "$DOC" "AS6_PYTHON_ARTIFACT_GIT_HYGIENE=PASS" "AS6_PYTHON_ARTIFACT_GIT_HYGIENE"
check_contains "$DOC" "AS6_NO_UNTRACKED_PYCACHE=PASS" "AS6_NO_UNTRACKED_PYCACHE"
check_contains "$DOC" "AS6_NO_TRACKED_PYCACHE=PASS" "AS6_NO_TRACKED_PYCACHE"
check_contains "$DOC" "AS6_NO_PYC_FILES=PASS" "AS6_NO_PYC_FILES"
check_contains "$DOC" "AS6_NO_PYCACHE_ARTIFACTS=PASS" "AS6_NO_PYCACHE_ARTIFACTS"
check_contains "$DOC" "AS6_VARIABLE_CONTRACT_FALSE_POSITIVE_SUPPRESSION=PASS" "AS6_VARIABLE_CONTRACT_FALSE_POSITIVE_SUPPRESSION"
check_contains "$DOC" "AS6_VARIABLE_CONTRACT_EXCEPT_HANDLER=PASS" "AS6_VARIABLE_CONTRACT_EXCEPT_HANDLER"
check_contains "$DOC" "AS6_GENERATED_PYTHON_SELF_REFERENCE_EXCLUSION=PASS" "AS6_GENERATED_PYTHON_SELF_REFERENCE_EXCLUSION"
check_contains "$DOC" "AS6_GENERATED_PYTHON_SAFETY_SCOPE=PASS" "AS6_GENERATED_PYTHON_SAFETY_SCOPE"
check_contains "$DOC" "AS6_REBOOT_FORENSICS_RUNTIME=PASS" "AS6_REBOOT_FORENSICS_RUNTIME"
check_contains "$DOC" "AS6_GENERATED_PYTHON_SAFETY=PASS" "AS6_GENERATED_PYTHON_SAFETY"
check_contains "$DOC" "AS6_NAMEERROR_SIGNATURES=PASS" "AS6_NAMEERROR_SIGNATURES"
check_contains "$DOC" "AS6_VARIABLE_CONTRACT=PASS" "AS6_VARIABLE_CONTRACT"
check_contains "$DOC" "AS6_GENERATED_VARIABLE_CONTRACT=PASS" "AS6_GENERATED_VARIABLE_CONTRACT"
check_contains "$DOC" "AS6_DIAGNOSTIC_HELPER_GIT_TRACKED=PASS" "AS6_DIAGNOSTIC_HELPER_GIT_TRACKED"
check_contains "$DOC" "AS6_DIAGNOSTIC_IN_COVERAGE=PASS" "AS6_DIAGNOSTIC_IN_COVERAGE"
check_contains "$DOC" "AS6_DIAGNOSTIC_IN_REGISTRY=PASS" "AS6_DIAGNOSTIC_IN_REGISTRY"
check_contains "$DOC" "AS6_DIAGNOSTIC_GIT_TRACKED=PASS" "AS6_DIAGNOSTIC_GIT_TRACKED"
check_contains "$DOC" "AS6_DIAGNOSTIC_FILE_EXISTS=PASS" "AS6_DIAGNOSTIC_FILE_EXISTS"
check_contains "$DOC" "AS6_DIAGNOSTIC_REGISTRATION=PASS" "AS6_DIAGNOSTIC_REGISTRATION"
check_contains "$DOC" "AS6_DIAGNOSTIC_CONTRACT_NO_RECURSION=PASS" "AS6_DIAGNOSTIC_CONTRACT_NO_RECURSION"
check_contains "$DOC" "AS6_ROOT_CAUSE_VALIDATION_PLAN=PASS" "AS6_ROOT_CAUSE_VALIDATION_PLAN"
check_contains "$DOC" "AS6_ROOT_CAUSE_REMEDIATION_PLAN=PASS" "AS6_ROOT_CAUSE_REMEDIATION_PLAN"
check_contains "$DOC" "AS6_ROOT_CAUSE_ROUTE_COUNT=PASS" "AS6_ROOT_CAUSE_ROUTE_COUNT"
check_contains "$DOC" "AS6_ROOT_CAUSE_VALIDATION=PASS" "AS6_ROOT_CAUSE_VALIDATION"
check_contains "$DOC" "AS6_ROOT_CAUSE_REMEDIATION=PASS" "AS6_ROOT_CAUSE_REMEDIATION"
check_contains "$DOC" "AS6_ROOT_CAUSE_ROUTER=PASS" "AS6_ROOT_CAUSE_ROUTER"
check_contains "$DOC" "AS6_NO_RUNTIME_HEREDOC_IN_GENERATED_DIAGNOSTICS=PASS" "AS6_NO_RUNTIME_HEREDOC_IN_GENERATED_DIAGNOSTICS"
check_contains "$DOC" "AS6_NO_AD_HOC_REGISTRY_GREP=PASS" "AS6_NO_AD_HOC_REGISTRY_GREP"
check_contains "$DOC" "AS6_REGISTRY_CONTRACT_COUNT=PASS" "AS6_REGISTRY_CONTRACT_COUNT"
check_contains "$DOC" "AS6_REGISTRY_CONTRACT=PASS" "AS6_REGISTRY_CONTRACT"
check_contains "$DOC" "AS6_DIAGNOSTIC_CONTRACT=PASS" "AS6_DIAGNOSTIC_CONTRACT"
check_contains "$DOC" "AS6_ROOT_CAUSE_ROLLBACK=PASS" "AS6_ROOT_CAUSE_ROLLBACK"
check_contains "$DOC" "AS6_ROOT_CAUSE_PREVENTION=PASS" "AS6_ROOT_CAUSE_PREVENTION"
check_contains "$DOC" "AS6_ROOT_CAUSE_REGISTRY=PASS" "AS6_ROOT_CAUSE_REGISTRY"
check_contains "$DOC" "AS6_ROOT_CAUSE_COVERAGE=PASS" "AS6_ROOT_CAUSE_COVERAGE"
check_contains "$DOC" "AS6_ROOT_CAUSE_DIAGNOSTIC=PASS" "AS6_ROOT_CAUSE_DIAGNOSTIC"
check_contains "$DOC" "AS6_ROOT_CAUSE_GOVERNANCE=PASS" "AS6_ROOT_CAUSE_GOVERNANCE"
check_contains "$DOC" "AS6_KNOWLEDGE_BASE_REFERENCE_EXCLUSION=PASS" "AS6_KNOWLEDGE_BASE_REFERENCE_EXCLUSION"
check_contains "$DOC" "AS6_REFERENCE_SOURCE_SUPPRESSION=PASS" "AS6_REFERENCE_SOURCE_SUPPRESSION"
check_contains "$DOC" "AS6_ROOT_CAUSE_HAS_PREVENTION=PASS" "AS6_ROOT_CAUSE_HAS_PREVENTION"
check_contains "$DOC" "AS6_ROOT_CAUSE_HAS_ROLLBACK=PASS" "AS6_ROOT_CAUSE_HAS_ROLLBACK"
check_contains "$DOC" "AS6_ROOT_CAUSE_HAS_FIX=PASS" "AS6_ROOT_CAUSE_HAS_FIX"
check_contains "$DOC" "AS6_ROOT_CAUSE_HAS_VERIFICATION=PASS" "AS6_ROOT_CAUSE_HAS_VERIFICATION"
check_contains "$DOC" "AS6_ROOT_CAUSE_HAS_SYMPTOMS=PASS" "AS6_ROOT_CAUSE_HAS_SYMPTOMS"
check_contains "$DOC" "AS6_ROOT_CAUSE_HAS_SEVERITY=PASS" "AS6_ROOT_CAUSE_HAS_SEVERITY"
check_contains "$DOC" "AS6_ROOT_CAUSE_CATALOG_EXISTS=PASS" "AS6_ROOT_CAUSE_CATALOG_EXISTS"
check_contains "$DOC" "AS6_ROOT_CAUSE_KNOWLEDGE_BASE=PASS" "AS6_ROOT_CAUSE_KNOWLEDGE_BASE"
check_contains "$DOC" "AS6_NO_NESTED_HEREDOC_PATCH=PASS" "AS6_NO_NESTED_HEREDOC_PATCH"
check_contains "$DOC" "AS6_PATCH_MODE=PASS" "AS6_PATCH_MODE"
check_contains "$DOC" "AS6_CODE_GENERATION_SAFETY=PASS" "AS6_CODE_GENERATION_SAFETY"
check_contains "$DOC" "AS6_COMMAND_LENGTH_SAFETY=PASS" "AS6_COMMAND_LENGTH_SAFETY"
check_contains "$DOC" "AS6_NO_GIANT_BASE64_PATCH=PASS" "AS6_NO_GIANT_BASE64_PATCH"
check_contains "$DOC" "AS6_NO_UNFINISHED_HEREDOC=PASS" "AS6_NO_UNFINISHED_HEREDOC"
check_contains "$DOC" "AS6_NEW_ARTIFACTS_DIAGNOSTICALLY_REGISTERED=PASS" "AS6_NEW_ARTIFACTS_DIAGNOSTICALLY_REGISTERED"
check_contains "$DOC" "AS6_NEW_CONTROLS_DIAGNOSTICALLY_REGISTERED=PASS" "AS6_NEW_CONTROLS_DIAGNOSTICALLY_REGISTERED"
check_contains "$DOC" "AS6_NEW_ERROR_CLASSES_DIAGNOSTICALLY_REGISTERED=PASS" "AS6_NEW_ERROR_CLASSES_DIAGNOSTICALLY_REGISTERED"
check_contains "$DOC" "AS6_AEC_RULES_EXECUTABLE=PASS" "AS6_AEC_RULES_EXECUTABLE"

if [ "$fail" -eq 0 ]; then
  echo "AS6_CONSTITUTION_GATE=PASS"
  echo "AS6_CONSTITUTION_RESULT=OK"
  exit 0
fi

echo "AS6_CONSTITUTION_GATE=FAIL"
echo "AS6_CONSTITUTION_RESULT=FAIL"
exit 1
