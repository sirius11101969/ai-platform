#!/usr/bin/env bash
set -Eeuo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
COMPOSE="$ROOT/docker-compose.yml"

test -f "$COMPOSE"

grep -q 'APP_URL: ${APP_URL:-https://www.as6.ru}' "$COMPOSE"
grep -q 'PAYMENT_MODE: ${PAYMENT_MODE:-disabled}' "$COMPOSE"
grep -q 'YOOKASSA_MODE: ${YOOKASSA_MODE:-disabled}' "$COMPOSE"
grep -q 'STRIPE_MODE: ${STRIPE_MODE:-disabled}' "$COMPOSE"

grep -q 'PAYMENT_WEBHOOK_SECRET: ${PAYMENT_WEBHOOK_SECRET:-}' "$COMPOSE"
grep -q 'YOOKASSA_SHOP_ID: ${YOOKASSA_SHOP_ID:-}' "$COMPOSE"
grep -q 'YOOKASSA_SECRET_KEY: ${YOOKASSA_SECRET_KEY:-}' "$COMPOSE"
grep -q 'STRIPE_SECRET_KEY: ${STRIPE_SECRET_KEY:-}' "$COMPOSE"
grep -q 'STRIPE_WEBHOOK_SECRET: ${STRIPE_WEBHOOK_SECRET:-}' "$COMPOSE"

! grep -Eq \
  'PAYMENT_WEBHOOK_SECRET: \$\{PAYMENT_WEBHOOK_SECRET\}$|YOOKASSA_SECRET_KEY: \$\{YOOKASSA_SECRET_KEY\}$|STRIPE_SECRET_KEY: \$\{STRIPE_SECRET_KEY\}$' \
  "$COMPOSE"

echo "AS6_PAYMENT_DEFAULT_MODE=disabled"
echo "AS6_YOOKASSA_DEFAULT_MODE=disabled"
echo "AS6_STRIPE_DEFAULT_MODE=disabled"
echo "AS6_PAYMENT_SECRETS_OPTIONAL_WHEN_DISABLED=PASS"
echo "AS6_PAYMENT_CONFIGURATION_FAIL_CLOSED=PASS"
echo "AS6_PAYMENT_CONFIGURATION_HARDENING=PASS"
