#!/usr/bin/env bash
set -euo pipefail
cd "${AS6_REPO_ROOT:-$(git rev-parse --show-toplevel 2>/dev/null || pwd)}"
echo "=== AS6 NameError Signature Diagnostics ==="
helper="ops/lib/as6-nameerror-signature-check.py"
if [ -s "$helper" ]; then echo "AS6_NAMEERROR_SIGNATURE_HELPER=PASS:$helper"; else echo "AS6_NAMEERROR_SIGNATURE_HELPER=FAIL:$helper"; exit 1; fi
python3 "$helper"
