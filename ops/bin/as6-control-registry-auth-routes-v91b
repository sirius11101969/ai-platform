ops/bin/as6-diagnose-crm-lazy-import-v89

grep -RIn "AS6_REGISTRY_AUTH_POLICY_DRIFT" docs ops frontend/src >/dev/null || { echo "AS6_CONTROL_REGISTRY_AUTH_ROUTES_V91B=FAIL auth_policy_drift_not_registered"; exit 1; }
grep -RIn "AS6_MANUAL_AUTH_WRAPPED_ROUTE_DRIFT" docs ops frontend/src >/dev/null || { echo "AS6_CONTROL_REGISTRY_AUTH_ROUTES_V91B=FAIL manual_auth_wrapped_route_drift_not_registered"; exit 1; }

echo "AS6_CONTROL_REGISTRY_DRIVEN_AUTH_ROUTE_REPAIR_V91B=PASS"
