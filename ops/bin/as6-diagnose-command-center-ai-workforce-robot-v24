#!/usr/bin/env bash
set -euo pipefail
echo "=== AS6 Command Center AI Workforce Robot V24 Diagnostics ==="
fail=0
test -f frontend/src/assets/as6-robot.png && echo "AS6_AI_WORKFORCE_ROBOT_ASSET=PASS" || { echo "AS6_AI_WORKFORCE_ROBOT_ASSET=FAIL"; fail=1; }
count="$(grep -c 'import as6Robot from "../assets/as6-robot.png"' frontend/src/pages/CommandCenterPage.jsx || true)"
if [ "$count" = "1" ]; then echo "AS6_AI_WORKFORCE_ROBOT_IMPORT_SINGLE=PASS"; else echo "AS6_AI_WORKFORCE_ROBOT_IMPORT_SINGLE=FAIL:$count"; fail=1; fi
grep -q "icon: <img src={as6Robot}" frontend/src/pages/CommandCenterPage.jsx && echo "AS6_AI_KPI_ROBOT_IMAGE=PASS" || { echo "AS6_AI_KPI_ROBOT_IMAGE=FAIL"; fail=1; }
grep -q "agent-avatar-image" frontend/src/pages/CommandCenterPage.jsx && echo "AS6_AI_AGENT_ROBOT_IMAGES=PASS" || { echo "AS6_AI_AGENT_ROBOT_IMAGES=FAIL"; fail=1; }
if grep -n "const aiEmployees" -A8 frontend/src/pages/CommandCenterPage.jsx | grep -Eq "🤖|👨|👩|🧠"; then echo "AS6_AI_AGENT_EMOJI_REMOVED=FAIL"; fail=1; else echo "AS6_AI_AGENT_EMOJI_REMOVED=PASS"; fi
grep -q "AS6 AI Workforce Robot Final V24" frontend/src/theme/as6Theme.css && echo "AS6_AI_WORKFORCE_ROBOT_CSS=PASS" || { echo "AS6_AI_WORKFORCE_ROBOT_CSS=FAIL"; fail=1; }
if [ "$fail" -eq 0 ]; then echo "AS6_AI_WORKFORCE_ROBOT_V24_RESULT=OK"; exit 0; fi
echo "AS6_AI_WORKFORCE_ROBOT_V24_RESULT=FAIL"; exit 1
