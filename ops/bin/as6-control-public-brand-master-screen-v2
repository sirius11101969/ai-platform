#!/usr/bin/env bash
set -Eeuo pipefail
ROOT="/var/www/ai-platform"
PAGE="$ROOT/frontend/src/pages/AS6PublicBrandHomeV1.jsx"
CSS="$ROOT/frontend/src/pages/AS6PublicBrandHomeV1.css"
test -f "$PAGE"
test -f "$CSS"
grep -Fq "data-as6-public-brand=\"master-v2\"" "$PAGE"
grep -Fq "Весь бизнес." "$PAGE"
grep -Fq "В одном месте." "$PAGE"
grep -Fq "Ваш помощник для бизнеса" "$PAGE"
grep -Fq "Попробовать бесплатно" "$PAGE"
test "$(grep -Fo "Попробовать бесплатно" "$PAGE" | wc -l | tr -d " ")" = "1"
! grep -Eqi "мультиагент|архитектур|оркестрац|enterprise|API" "$PAGE"
grep -Fq "as6-brand-living" "$PAGE"
grep -Fq "as6-brand-core" "$CSS"
grep -Fq "@media(max-width:640px)" "$CSS"
grep -Fq "prefers-reduced-motion" "$CSS"
echo "AS6_PUBLIC_ONE_SECOND_PROMISE=PASS"
echo "AS6_PUBLIC_SINGLE_PRIMARY_CTA=PASS"
echo "AS6_PUBLIC_CHILD_LANGUAGE=PASS"
echo "AS6_PUBLIC_LIVING_SPACE_CONTINUITY=PASS"
echo "AS6_PUBLIC_BRAND_MASTER_SCREEN_CONTROL=PASS"
