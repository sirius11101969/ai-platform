#!/usr/bin/env bash
set -Eeuo pipefail

ROOT="${AS6_ROOT:-$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)}"
REQUESTED_SHA="${1:?release commit is required}"
ENV_FILE="${AS6_STAGING_ENV_FILE:-$ROOT/.env.staging}"

cd "$ROOT"
RELEASE_SHA="$(git rev-parse "${REQUESTED_SHA}^{commit}")"
RELEASE_TAG="$(printf '%s' "$RELEASE_SHA" | cut -c1-12)"
BUILD_MANIFEST="$ROOT/runtime/as6-releases/$RELEASE_SHA/build.env"
ATTESTATION="$ROOT/runtime/as6-releases/$RELEASE_SHA/staging-passed.env"

test -f "$BUILD_MANIFEST"
AS6_RELEASE_TAG="$RELEASE_TAG" AS6_STAGING_ENV_FILE="$ENV_FILE" \
  ops/bin/as6-validate-staging-config-v1

test "$(docker image inspect "ai-platform-backend:$RELEASE_TAG" --format '{{ index .Config.Labels "org.opencontainers.image.revision" }}')" = "$RELEASE_SHA"
test "$(docker image inspect "ai-platform-nginx:$RELEASE_TAG" --format '{{ index .Config.Labels "org.opencontainers.image.revision" }}')" = "$RELEASE_SHA"

AS6_RELEASE_TAG="$RELEASE_TAG" docker compose --env-file "$ENV_FILE" \
  -p ai-platform-staging -f docker-compose.staging.yml up -d --no-build

AS6_RELEASE_TAG="$RELEASE_TAG" AS6_STAGING_ENV_FILE="$ENV_FILE" \
  ops/bin/as6-staging-smoke-v1

cat > "$ATTESTATION" <<EOF
AS6_RELEASE_SHA=$RELEASE_SHA
AS6_RELEASE_TAG=$RELEASE_TAG
AS6_BACKEND_IMAGE_ID=$(docker image inspect "ai-platform-backend:$RELEASE_TAG" --format '{{.Id}}')
AS6_NGINX_IMAGE_ID=$(docker image inspect "ai-platform-nginx:$RELEASE_TAG" --format '{{.Id}}')
AS6_STAGING_ENV_SHA256=$(sha256sum "$ENV_FILE" | awk '{print $1}')
AS6_STAGING_PASSED_AT=$(date -u +%Y-%m-%dT%H:%M:%SZ)
AS6_STAGING_RESULT=PASS
EOF
chmod 600 "$ATTESTATION"

echo "AS6_STAGING_DEPLOYMENT=PASS"
echo "AS6_STAGING_ATTESTATION=$ATTESTATION"
