#!/usr/bin/env bash
set -uo pipefail
echo "=== AS6 Unified Autonomy Orchestrator ==="
if [ -x ops/bin/as6-diagnose-unified-autonomy-orchestrator ]; then
  exec ops/bin/as6-diagnose-unified-autonomy-orchestrator
fi
echo "AS6_UNIFIED_AUTONOMY_ORCHESTRATOR=FAIL:diagnostic_missing"
echo "AS6_UNIFIED_AUTONOMY_ORCHESTRATOR_RESULT=FAIL"
exit 1
