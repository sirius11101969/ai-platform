#!/usr/bin/env bash
set -Eeuo pipefail

ROOT="${AS6_ROOT:-/var/www/ai-platform}"
MASTER="$ROOT/frontend/src/living/product-v2/AS6MasterScreen.jsx"
MODEL="$ROOT/frontend/src/living/product-v2/livingShellFoundation.js"
APP="$ROOT/frontend/src/living/product-v2/LivingCanonicalApp.jsx"
PLANS="$ROOT/backend/src/plans.js"

test -f "$MASTER"
test -f "$MODEL"
test -f "$APP"
test -f "$PLANS"

grep -Fq 'useLivingSpeechRecognition' "$MASTER"
grep -Fq 'setPanel("activity")' "$MASTER"
grep -Fq 'placeholder={priority.intent}' "$MASTER"
grep -Fq 'onCreateWorkspace' "$MASTER"
grep -Fq 'as6-master__plan-status' "$MASTER"
grep -Fq 'subscription:' "$MODEL"
grep -Fq 'onWorkspaceChange={changeWorkspace}' "$APP"
grep -Fq 'livingRequestIdRef' "$APP"
grep -Fq 'saveAuthSession(nextSession, { syncWorkspace: false })' "$ROOT/frontend/src/services/api.js"
grep -Fq 'onLocaleChange={changeLocale}' "$APP"
grep -Fq 'as6-living-settings__workspace-context' "$ROOT/frontend/src/living/product-v2/LivingSettingsSpace.jsx"
grep -Fq 'brandCoBranded", { company: companyLabel }' "$ROOT/frontend/src/living/product-v2/LivingSettingsSpace.jsx"
grep -Fq '!isAs6Company && <option value="co-branded">' "$ROOT/frontend/src/living/product-v2/LivingSettingsSpace.jsx"
grep -Fq 'body:has(.as6-reference-root[data-active-space="settings"]){overflow-x:hidden;overflow-y:auto}' "$ROOT/frontend/src/living/product-v2/LivingCanonicalApp.css"
grep -Fq 'data-theme={theme}' "$MASTER"
grep -Fq 'actionCount: livingData?.activity?.length || 0' "$MODEL"
grep -Fq 'selectedPriorityId' "$MODEL"
grep -Fq 'workspacesLimit: 3' "$PLANS"
grep -Fq 'WORKSPACE_LIMIT_REACHED' "$ROOT/backend/src/models/workspaceModel.js"
grep -Fq 'AS6PublicLivingHomePage' "$ROOT/frontend/src/App.jsx"
grep -Fq 'AS6PublicLivingHomePage isAuthenticated={isAuthenticated}' "$ROOT/frontend/src/App.jsx"
! grep -Fq 'if (isAuthenticated) return <Navigate to="/app" replace />' "$ROOT/frontend/src/App.jsx"
grep -Fq '.as6-master__space-status { pointer-events: auto; }' "$ROOT/frontend/src/living/product-v2/AS6MasterScreenReference.css"
grep -Fq 'AS6_SCREEN1_REFINEMENT_V6: identity-axis=logo+workspace+avatar; visual-left=22px' "$ROOT/frontend/src/living/product-v2/AS6MasterScreenReference.css"
grep -Fq 'AS6_IDENTITY_SCALE_V2: logo=70..150@workspace; avatar=70..150@profile; screens=master,conductor' "$ROOT/frontend/src/living/product-v2/AS6MasterScreenReference.css"
grep -Fq 'AS6_IDENTITY_SPACING_V1: workspace-gap=follows-positive-logo-overflow; menu=follows-workspace' "$ROOT/frontend/src/living/product-v2/AS6MasterScreenReference.css"
grep -Fq 'AS6_LIGHT_PALETTE_UNIFICATION_V1: temperature=cool-neutral; warm-cast=removed; dark=unchanged' "$ROOT/frontend/src/living/product-v2/AS6MasterScreenReference.css"
grep -Fq 'AS6_LIGHT_PALETTE_UNIFICATION_V2: background=solid-cool; diffuse-glow=none; graph-glow=none' "$ROOT/frontend/src/living/product-v2/AS6MasterScreenReference.css"
grep -Fq 'AS6_LIGHT_PALETTE_UNIFICATION_V3: background=pure-white; connections=7; finance-team=clear-of-metric' "$ROOT/frontend/src/living/product-v2/AS6MasterScreenReference.css"
grep -Fq 'companyLogoScale' "$ROOT/frontend/src/living/product-v2/LivingSettingsSpace.jsx"
grep -Fq 'avatarScale' "$ROOT/frontend/src/living/product-v2/LivingSettingsSpace.jsx"
grep -Fq 'company_logo_scale BETWEEN 70 AND 150' "$ROOT/backend/src/db/schema.js"
grep -Fq 'avatar_scale BETWEEN 70 AND 150' "$ROOT/backend/src/db/schema.js"
grep -Fq '.as6-master__intent input:focus,' "$ROOT/frontend/src/living/product-v2/AS6MasterScreenReference.css"
grep -Fq 'const resolvedIntent = intent.trim() || String(priority.intent || "").trim()' "$MASTER"
grep -Fq 'disabled={!resolvedIntent}' "$MASTER"
grep -Fq 'no-store, no-cache, must-revalidate' "$ROOT/frontend/nginx.conf"
grep -Fq 'max-age=31536000, immutable' "$ROOT/frontend/nginx.conf"

node "$ROOT/ops/diagnostics/as6-screen1-interaction-multi-workspace-v1.mjs"
node --check "$ROOT/backend/src/models/workspaceModel.js"
node --check "$ROOT/backend/src/models/crmModel.js"
node --check "$ROOT/backend/src/controllers/crmController.js"

AS6_ROOT="$ROOT" "$ROOT/ops/bin/as6-control-living-shell-foundation-v1"
AS6_ROOT="$ROOT" bash "$ROOT/ops/bin/as6-control-customizable-central-layout-v1"

echo "AS6_SCREEN1_INTERACTION_MULTI_WORKSPACE_V1=PASS"
echo "AS6_LIGHT_DARK_THEME=PASS"
echo "AS6_BROWSER_SPEECH_INPUT=PASS"
echo "AS6_PUBLIC_HOME_ROUTE=PASS"
echo "AS6_AUTHENTICATED_PUBLIC_HOME=PASS"
echo "AS6_CLICK_POINTER_ROUTING=PASS"
echo "AS6_HTML_CACHE_ISOLATION=PASS"
