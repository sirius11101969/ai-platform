#!/usr/bin/env bash
set -euo pipefail
cd /var/www/ai-platform
fail=0
warn=0
incident=0
decision="OBSERVE"
class="NO_ACTIVE_INCIDENT"
evidence_dir="runtime/incident-commander"
mkdir -p "$evidence_dir"
evidence_file="$evidence_dir/latest.out"
: > "$evidence_file"
say(){ echo "$1" | tee -a "$evidence_file"; }
ok(){ say "PASS: $1"; }
soft(){ say "WARN: $1"; warn=1; }
bad(){ say "FAIL: $1"; fail=1; incident=1; }
capture_gate(){ name="$1"; shift; say "--- evidence gate: $name ---"; if "$@" >> "$evidence_file" 2>&1; then ok "$name"; else bad "$name"; fi; }

say "=== AS6 AUTONOMOUS INCIDENT COMMANDER ==="

say "--- incident detection: production health ---"
if curl -fsS --max-time 15 https://www.as6.ru/api/health 2>/dev/null | grep -q "\"status\":\"OK\""; then
  ok "public production health OK"
else
  bad "public production health failed"
  class="PRODUCTION_HEALTH_INCIDENT"
fi

say "--- incident detection: infrastructure gates ---"
capture_gate "production drift" ops/bin/as6-autonomous-production-drift-controller
capture_gate "architecture compliance" ops/bin/as6-autonomous-architecture-compliance-controller
capture_gate "rollback verification" ops/bin/as6-autonomous-rollback-verification-controller
capture_gate "deployment controller" ops/bin/as6-autonomous-deployment-controller

say "--- incident detection: existing diagnostics ---"
if [ -x ops/bin/as6-diagnose-provider-control-plane ]; then capture_gate "provider control plane" ops/bin/as6-diagnose-provider-control-plane; else soft "provider control plane diagnostic missing"; fi
if [ -x ops/bin/as6-diagnose-vps-baseline ]; then capture_gate "vps baseline" ops/bin/as6-diagnose-vps-baseline; else soft "vps baseline diagnostic missing"; fi
if [ -x ops/bin/as6-diagnose-change-pipeline-controller ]; then capture_gate "change pipeline controller" ops/bin/as6-diagnose-change-pipeline-controller; else soft "change pipeline diagnostic missing"; fi

say "--- root cause route readiness ---"
if [ -x ops/bin/as6-diagnose-root-cause-router ]; then capture_gate "root cause router" ops/bin/as6-diagnose-root-cause-router; else soft "root cause router diagnostic missing"; fi
if [ -x ops/bin/as6-diagnose-root-cause-knowledge-base ]; then capture_gate "root cause knowledge base" ops/bin/as6-diagnose-root-cause-knowledge-base; else soft "root cause knowledge base diagnostic missing"; fi
if [ -x ops/bin/as6-diagnose-root-cause-governance ]; then capture_gate "root cause governance" ops/bin/as6-diagnose-root-cause-governance; else soft "root cause governance diagnostic missing"; fi

say "--- incident classification ---"
if [ "$fail" -eq 0 ]; then
  class="NO_ACTIVE_INCIDENT"
  decision="OBSERVE"
  ok "no active incident detected"
else
  decision="ESCALATE_AND_BLOCK_AUTO_APPLY"
  say "INCIDENT_CLASS=$class"
  say "INCIDENT_DECISION=$decision"
fi

say "--- commander safety policy ---"
say "AS6_INCIDENT_COMMANDER_AUTO_REPAIR_APPLY=NO"
say "AS6_INCIDENT_COMMANDER_HUMAN_APPROVAL_REQUIRED=YES"
ok "incident commander classifies and routes, but does not auto-apply repairs"

say "--- result ---"
say "AS6_INCIDENT_CLASS=$class"
say "AS6_INCIDENT_DECISION=$decision"
if [ "$fail" -eq 0 ]; then
  say "AUTONOMOUS_INCIDENT_COMMANDER=PASS"
  if [ "$warn" -eq 1 ]; then say "AUTONOMOUS_INCIDENT_COMMANDER_WARNINGS=PRESENT"; else say "AUTONOMOUS_INCIDENT_COMMANDER_WARNINGS=NONE"; fi
  say "AS6_AUTONOMOUS_INCIDENT_COMMANDER_RESULT=OK"
else
  say "AUTONOMOUS_INCIDENT_COMMANDER=FAIL"
  say "AS6_AUTONOMOUS_INCIDENT_COMMANDER_RESULT=FAIL"
fi
say "AS6_AUTONOMOUS_INCIDENT_COMMANDER_EVIDENCE=$evidence_file"
exit "$fail"
