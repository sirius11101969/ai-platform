  echo "- docs/AS6_PROJECT_STATE.md"
  echo "- docs/AS6_CODEX_PROMPT.md"
  echo "- ops/registry/as6-diagnostic-registry.md"
  echo "- ops/registry/as6-coverage-registry.md"
  echo "- ops/status/as6-detected-errors.md"
  echo
  echo "## Mandatory New Chat Start"
  echo "Продолжаем AS6. Прочитай docs/AS6_MASTER_CONTEXT.md, docs/AS6_HANDOFF.md и docs/AS6_CODEX_PROMPT.md из GitHub репозитория sirius11101969/ai-platform. Продолжай с последнего завершённого этапа по AS6 Diagnostics First."
  echo
  echo "## Mandatory Workflow"
