  echo "ops/bin/as6-finish"
  echo
  echo "## AEC Rule"
  echo "AEC-MASTER-CONTEXT-001: every AS6 patch must update docs/AS6_MASTER_CONTEXT.md and docs/AS6_HANDOFF.md through ops/bin/as6-update-handoff before commit."
