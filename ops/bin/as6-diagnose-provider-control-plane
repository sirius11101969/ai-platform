#!/usr/bin/env bash
set -euo pipefail
cd "${AS6_REPO_ROOT:-$(git rev-parse --show-toplevel 2>/dev/null || pwd)}"
echo "=== AS6 Provider Control Plane Diagnostics ==="
fail=0
./ops/bin/as6-diagnose-control-panel-reboot-correlation >/tmp/as6-provider-control-correlation.out 2>&1 && echo "AS6_PROVIDER_CONTROL_PLANE_CORRELATION=PASS" || { echo "AS6_PROVIDER_CONTROL_PLANE_CORRELATION=FAIL"; fail=1; }
AS6_REBOOT_FORENSICS_PROVIDER_SUPPRESSOR=1 ./ops/bin/as6-diagnose-reboot-forensics >/tmp/as6-provider-reboot-forensics.out 2>&1 && echo "AS6_PROVIDER_CONTROL_PLANE_REBOOT_EVIDENCE=PASS" || { echo "AS6_PROVIDER_CONTROL_PLANE_REBOOT_EVIDENCE=FAIL"; fail=1; }
test -d runtime/reboot-forensics && echo "AS6_PROVIDER_CONTROL_PLANE_AUDIT=PASS" || { echo "AS6_PROVIDER_CONTROL_PLANE_AUDIT=FAIL"; fail=1; }
grep -q "AEC_PROVIDER_CONTROL_PLANE=PASS" docs/AS6_AUTONOMOUS_ENGINEERING_CONSTITUTION.md && echo "AS6_PROVIDER_CONTROL_PLANE_AEC_RULE=PASS" || { echo "AS6_PROVIDER_CONTROL_PLANE_AEC_RULE=FAIL"; fail=1; }
if [ "$fail" -eq 0 ]; then echo "AS6_PROVIDER_CONTROL_PLANE=PASS"; echo "AS6_PROVIDER_CONTROL_PLANE_RESULT=OK"; exit 0; fi
echo "AS6_PROVIDER_CONTROL_PLANE=FAIL"; echo "AS6_PROVIDER_CONTROL_PLANE_RESULT=FAIL"; exit 1
