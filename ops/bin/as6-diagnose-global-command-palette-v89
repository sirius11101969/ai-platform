#!/usr/bin/env bash
set -euo pipefail
FAIL=0
for f in frontend/src/components/AS6GlobalCommandPalette.jsx frontend/src/styles/as6-global-command-palette.css; do
  if [ ! -f "$f" ]; then echo "AS6_COMMAND_PALETTE_FILE_MISSING $f"; FAIL=1; fi
done
if ! grep -Rqs "AS6GlobalCommandPalette.jsx" frontend/src/App.jsx; then echo "AS6_COMMAND_PALETTE_IMPORT_MISSING"; FAIL=1; fi
for item in "as6-global-command-palette-root" "AS6 Command" "Command Center" "CRM" "Diagnostics" "Ctrl" "Escape"; do
  if ! grep -Rqs "$item" frontend/src/components/AS6GlobalCommandPalette.jsx frontend/src/styles/as6-global-command-palette.css ops/governance docs ops/status ops/registry; then echo "AS6_COMMAND_PALETTE_ITEM_MISSING $item"; FAIL=1; fi
done
for cls in GLOBAL_COMMAND_PALETTE_MISSING COMMAND_PALETTE_SHORTCUT_GAP COMMAND_DISCOVERY_DRIFT CROSS_PAGE_NAVIGATION_FRICTION COMMAND_PALETTE_MOBILE_LAYOUT_DRIFT COMMAND_PALETTE_MOUNT_GAP; do
  if ! grep -Rqs "$cls" ops/registry ops/governance ops/status docs; then echo "AS6_COMMAND_PALETTE_CLASS_MISSING $cls"; FAIL=1; fi
done
if git diff --cached --name-only | grep -q "^runtime/"; then echo "AS6_RUNTIME_STAGING_FAIL"; FAIL=1; fi
if [ "$FAIL" -ne 0 ]; then exit 1; fi
echo "AS6_GLOBAL_COMMAND_PALETTE=PASS"
