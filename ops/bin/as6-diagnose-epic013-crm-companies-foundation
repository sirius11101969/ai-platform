#!/usr/bin/env bash
set -euo pipefail

for f in \
  crmCompanyCapabilities \
  crmCompanyManifest \
  crmCompanyRegistry \
  crmCompanyResolver \
  crmCompanyRuntime \
  crmCompanyNavigation \
  crmCompanyPanels \
  crmCompanyFoundationTracer \
  crmCompanyFoundationDiagnostics \
  crmCompanyHealthSnapshot \
  crmCompanyFoundationDescriptor
do
  test -f "frontend/src/crm/companies/foundation/${f}.js"
done

grep -R "CRM_COMPANIES_FOUNDATION_ONLY" frontend/src/crm/companies/foundation
grep -R "crm.companies" frontend/src/crm/companies/foundation
grep -R "declarative-foundation-only" frontend/src/crm/companies/foundation
grep -R "/crm/companies" frontend/src/crm/companies/foundation
grep -R "traceCrmCompanyFoundation" frontend/src/crm/companies/foundation
grep -R "getCrmCompanyHealthSnapshot" frontend/src/crm/companies/foundation
grep -R "storageEnabled: false" frontend/src/crm/companies/foundation/crmCompanyRuntime.js
grep -R "apiEnabled: false" frontend/src/crm/companies/foundation/crmCompanyRuntime.js
grep -R "workflowEnabled: false" frontend/src/crm/companies/foundation/crmCompanyRuntime.js
grep -R "platformMutation: false" frontend/src/crm/companies/foundation/crmCompanyRuntime.js

echo "AS6_EPIC013_CRM_COMPANIES_FOUNDATION=PASS"
