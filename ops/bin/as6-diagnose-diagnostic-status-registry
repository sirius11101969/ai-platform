#!/usr/bin/env bash
set -euo pipefail

ROOT="${AS6_REPO_ROOT:-$(git rev-parse --show-toplevel 2>/dev/null || pwd)}"
cd "$ROOT"

REGISTRY="ops/status/diagnostic-status-registry.json"
fail=0

echo "=== AS6 Diagnostic Status Registry Diagnostics ==="

if [ -f "$REGISTRY" ]; then
  echo "DIAGNOSTIC_STATUS_REGISTRY_FILE=OK:$REGISTRY"
else
  echo "DIAGNOSTIC_STATUS_REGISTRY_FILE=FAIL:missing"
  echo "DIAGNOSTIC_STATUS_REGISTRY_RESULT=FAIL"
  exit 1
fi

python3 - <<'PY' || fail=1
import json
from collections import Counter
from pathlib import Path

registry = Path("ops/status/diagnostic-status-registry.json")
valid_statuses = {"ACTIVE", "ARCHIVED", "DEPRECATED", "REMOVED"}
try:
    data = json.loads(registry.read_text())
except json.JSONDecodeError as exc:
    print(f"DIAGNOSTIC_STATUS_REGISTRY_CORRUPT=FAIL:{exc}")
    raise SystemExit(1)

items = data.get("diagnostics")
if not isinstance(items, list):
    print("DIAGNOSTIC_STATUS_REGISTRY_CORRUPT=FAIL:diagnostics_not_list")
    raise SystemExit(1)

paths = []
fail = False
for index, item in enumerate(items):
    if not isinstance(item, dict):
        print(f"DIAGNOSTIC_STATUS_REGISTRY_CORRUPT=FAIL:item_{index}_not_object")
        fail = True
        continue
    path = item.get("path")
    status = item.get("lifecycle_status")
    if not path or not isinstance(path, str):
        print(f"DIAGNOSTIC_STATUS_REGISTRY_CORRUPT=FAIL:item_{index}_missing_path")
        fail = True
        continue
    paths.append(path)
    if status not in valid_statuses:
        print(f"DIAGNOSTIC_STATUS_HISTORICAL_ENTRY_MISCLASSIFIED=FAIL:{path}:status={status}")
        fail = True
        continue
    if status == "ACTIVE" and not Path(path).is_file():
        print(f"DIAGNOSTIC_STATUS_ACTIVE_ENTRY_MISSING=FAIL:{path}")
        fail = True

for path, count in sorted(Counter(paths).items()):
    if count > 1:
        print(f"DIAGNOSTIC_STATUS_REGISTRY_DUPLICATE=FAIL:{path}:count={count}")
        fail = True

active_paths = {item.get("path") for item in items if isinstance(item, dict) and item.get("lifecycle_status") == "ACTIVE"}
missing_active_registrations = []
for p in sorted(Path("ops/bin").glob("as6-diagnose-*")):
    if p.name.endswith(".backup") or ".backup." in p.name or not p.is_file():
        continue
    if str(p) not in active_paths:
        missing_active_registrations.append(str(p))

for path in missing_active_registrations:
    print(f"DIAGNOSTIC_STATUS_ARCHIVE_NOT_SUPPORTED=FAIL:{path}:existing_diagnostic_not_ACTIVE")
    fail = True

print(f"DIAGNOSTIC_STATUS_REGISTRY_COUNT={len(paths)}")
print(f"DIAGNOSTIC_STATUS_REGISTRY_ACTIVE_COUNT={len(active_paths)}")
if fail:
    raise SystemExit(1)
print("DIAGNOSTIC_STATUS_REGISTRY_COMPLETE=OK")
PY

if [ "$fail" -eq 0 ]; then
  echo "DIAGNOSTIC_STATUS_REGISTRY_RESULT=PASS"
  exit 0
fi

echo "DIAGNOSTIC_STATUS_REGISTRY_RESULT=FAIL"
exit 1
