#!/usr/bin/env bash
set -euo pipefail

ROOT="${AS6_REPO_ROOT:-$(git rev-parse --show-toplevel 2>/dev/null || pwd)}"
cd "$ROOT"

REGISTRY="ops/status/diagnostic-status-registry.json"
fail=0

echo "=== AS6 Diagnostic Status Registry Diagnostics ==="

if [ -f "$REGISTRY" ]; then
  echo "DIAGNOSTIC_STATUS_REGISTRY_FILE=OK:$REGISTRY"
else
  echo "DIAGNOSTIC_STATUS_REGISTRY_FILE=FAIL:missing"
  echo "DIAGNOSTIC_STATUS_REGISTRY_RESULT=FAIL"
  exit 1
fi

python3 - <<'PY' || fail=1
import json
from collections import Counter
from pathlib import Path

registry = Path("ops/status/diagnostic-status-registry.json")
valid_statuses = {"ACTIVE", "ARCHIVED", "DEPRECATED", "REMOVED"}

try:
    data = json.loads(registry.read_text())
except Exception as exc:
    print(f"DIAGNOSTIC_STATUS_REGISTRY_JSON=FAIL:{exc}")
    raise SystemExit(1)

if not isinstance(data, dict) or not isinstance(data.get("diagnostics"), list):
    print("DIAGNOSTIC_STATUS_REGISTRY_JSON=FAIL:expected object with diagnostics list")
    raise SystemExit(1)

items = data["diagnostics"]
paths = [item.get("path") for item in items if isinstance(item, dict)]
counts = Counter(paths)
duplicates = sorted(path for path, count in counts.items() if path and count > 1)

fail = False
if len(paths) != len(items) or any(not path for path in paths):
    print("DIAGNOSTIC_STATUS_REGISTRY_ENTRY=FAIL:all entries must be objects with path")
    fail = True

for path in duplicates:
    print(f"DIAGNOSTIC_STATUS_REGISTRY_DUPLICATE=FAIL:{path}")
    fail = True

active_missing = []
invalid_status = []
for item in items:
    if not isinstance(item, dict):
        continue
    path = item.get("path")
    status = item.get("status")
    if status not in valid_statuses:
        invalid_status.append(path or "<missing-path>")
        continue
    if status == "ACTIVE" and path and not Path(path).is_file():
        active_missing.append(path)

for path in invalid_status:
    print(f"DIAGNOSTIC_STATUS_REGISTRY_STATUS=FAIL:{path}")
    fail = True

for path in sorted(active_missing):
    print(f"DIAGNOSTIC_STATUS_REGISTRY_ACTIVE_MISSING=FAIL:{path}")
    fail = True

print(f"DIAGNOSTIC_STATUS_REGISTRY_COUNT={len(items)}")
print(f"DIAGNOSTIC_STATUS_REGISTRY_ACTIVE_COUNT={sum(1 for item in items if isinstance(item, dict) and item.get('status') == 'ACTIVE')}")
if fail:
    raise SystemExit(1)

print("DIAGNOSTIC_STATUS_REGISTRY_COMPLETE=OK")
PY

if [ "$fail" -eq 0 ]; then
  echo "DIAGNOSTIC_STATUS_REGISTRY_RESULT=PASS"
  exit 0
fi

echo "DIAGNOSTIC_STATUS_REGISTRY_RESULT=FAIL"
exit 1
