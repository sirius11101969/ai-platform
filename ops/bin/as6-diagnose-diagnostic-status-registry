#!/usr/bin/env bash
set -euo pipefail

ROOT="${AS6_REPO_ROOT:-$(git rev-parse --show-toplevel 2>/dev/null || pwd)}"
cd "$ROOT"

REGISTRY="ops/status/diagnostic-status-registry.json"
fail=0

echo "=== AS6 Diagnostic Status Registry Diagnostics ==="

if [ -f "$REGISTRY" ]; then
  echo "DIAGNOSTIC_STATUS_REGISTRY_FILE=OK:$REGISTRY"
else
  echo "DIAGNOSTIC_STATUS_REGISTRY_FILE=FAIL:missing"
  echo "DIAGNOSTIC_STATUS_REGISTRY_RESULT=FAIL"
  exit 1
fi

python3 - <<'PY' || fail=1
import json
from pathlib import Path
from collections import Counter

registry = Path("ops/status/diagnostic-status-registry.json")
try:
    data = json.loads(registry.read_text())
except Exception as exc:
    print(f"DIAGNOSTIC_STATUS_REGISTRY_JSON=FAIL:{exc}")
    raise SystemExit(1)

items = data.get("diagnostics", [])
paths = [item.get("path") for item in items]
checks = [item.get("check") for item in items]
path_dupes = sorted(p for p, n in Counter(paths).items() if p and n > 1)
check_dupes = sorted(c for c, n in Counter(checks).items() if c and n > 1)
if path_dupes or check_dupes:
    for p in path_dupes:
        print(f"DIAGNOSTIC_STATUS_REGISTRY_DUPLICATE=FAIL:path:{p}")
    for c in check_dupes:
        print(f"DIAGNOSTIC_STATUS_REGISTRY_DUPLICATE=FAIL:check:{c}")
    raise SystemExit(1)

active_missing = []
for item in items:
    if item.get("lifecycle_status", "ACTIVE") == "ACTIVE":
        path = item.get("path")
        if not path or not Path(path).is_file():
            active_missing.append(path or "<missing-path>")

print(f"DIAGNOSTIC_STATUS_REGISTRY_COUNT={len(items)}")
if active_missing:
    for p in sorted(active_missing):
        print(f"DIAGNOSTIC_STATUS_ACTIVE_ENTRY_MISSING=FAIL:{p}")
    raise SystemExit(1)

print("DIAGNOSTIC_STATUS_REGISTRY_COMPLETE=OK")
PY

if [ "$fail" -eq 0 ]; then
  echo "DIAGNOSTIC_STATUS_REGISTRY_RESULT=PASS"
  exit 0
fi

echo "DIAGNOSTIC_STATUS_REGISTRY_RESULT=FAIL"
exit 1
