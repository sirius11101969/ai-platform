#!/usr/bin/env bash
set -euo pipefail
REG="ops/status/diagnostic-status-registry.json"
echo "=== AS6 Diagnostic Status Registry Diagnostics ==="
if [ ! -f "$REG" ]; then echo "DIAGNOSTIC_STATUS_REGISTRY_FILE=FAIL:$REG"; exit 1; fi
echo "DIAGNOSTIC_STATUS_REGISTRY_FILE=OK:$REG"
node - "$REG" <<'NODE'
const fs = require("fs");
const regPath = process.argv[2];
let data;
try { data = JSON.parse(fs.readFileSync(regPath, "utf8")); } catch (e) { console.log("DIAGNOSTIC_STATUS_REGISTRY_JSON=FAIL"); process.exit(1); }
const entries = Array.isArray(data) ? data : Array.isArray(data.entries) ? data.entries : Object.entries(data || {}).map(([path, value]) => ({ path, ...(typeof value === "object" && value ? value : {}) }));
const allowed = new Set(["ACTIVE","ARCHIVED","DEPRECATED","REMOVED"]);
const seen = new Set();
let fail = 0;
console.log(`DIAGNOSTIC_STATUS_REGISTRY_COUNT=${entries.length}`);
for (const e of entries) {
  const p = e.path || e.diagnostic || e.file || e.name;
  const status = e.status || "ACTIVE";
  if (!p) { console.log("DIAGNOSTIC_STATUS_REGISTRY_ENTRY=FAIL:missing-path"); fail++; continue; }
  if (seen.has(p)) { console.log(`DIAGNOSTIC_STATUS_REGISTRY_DUPLICATE=FAIL:${p}`); fail++; continue; }
  seen.add(p);
  if (!allowed.has(status)) { console.log(`DIAGNOSTIC_STATUS_REGISTRY_STATUS=FAIL:${p}:${status}`); fail++; continue; }
  if (status === "ACTIVE" && !fs.existsSync(p)) { console.log(`DIAGNOSTIC_STATUS_REGISTRY_ACTIVE_MISSING=FAIL:${p}`); fail++; continue; }
}
if (fail) { console.log("DIAGNOSTIC_STATUS_REGISTRY_RESULT=FAIL"); process.exit(1); }
console.log("DIAGNOSTIC_STATUS_REGISTRY_RESULT=PASS");
NODE
