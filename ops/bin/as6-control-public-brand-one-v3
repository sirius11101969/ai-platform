#!/usr/bin/env bash
set -Eeuo pipefail
ROOT="/var/www/ai-platform"
PAGE="$ROOT/frontend/src/pages/AS6PublicBrandHomeV1.jsx"
STYLE="$ROOT/frontend/src/pages/AS6PublicBrandHomeV1.css"
test -f "$PAGE"
test -f "$STYLE"
grep -Fq "data-as6-public-brand=\"one-v3\"" "$PAGE"
grep -Fq "Вы видите главное." "$PAGE"
grep -Fq "AS6 делает остальное." "$PAGE"
test "$(grep -Fc "Попробовать бесплатно" "$PAGE")" = "1"
grep -Fq "Посмотреть, как это выглядит" "$PAGE"
grep -Fq "AS6 показывает один следующий шаг." "$PAGE"
grep -Fq "@media(max-width:640px)" "$STYLE"
grep -Fq "prefers-reduced-motion" "$STYLE"
echo "AS6_PUBLIC_HUMAN_RESULT_FIRST=PASS"
echo "AS6_PUBLIC_SINGLE_PRIMARY_ACTION=PASS"
echo "AS6_PUBLIC_LIVING_PREVIEW=PASS"
echo "AS6_PUBLIC_CHILD_LANGUAGE=PASS"
echo "AS6_PUBLIC_BRAND_ONE_V3_CONTROL=PASS"
