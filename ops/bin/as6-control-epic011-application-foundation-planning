#!/usr/bin/env bash
set -euo pipefail

ops/bin/as6-diagnose-epic011-application-foundation-planning

grep -Rh "^IMPLEMENTATION_AUTHORIZED=TRUE$" docs/epic011 docs/portfolio >/tmp/as6-epic011-auth-scope.txt
grep -q "^IMPLEMENTATION_AUTHORIZED=TRUE$" /tmp/as6-epic011-auth-scope.txt

! grep -Rh "AS6_OPERATING_SYSTEM_V1=BASELINED.*MUTATED\|AS6_WORKSPACE_EXPERIENCE_V1=BASELINED.*MUTATED" docs/epic011 docs/portfolio

echo EPIC_CHARTER=APPROVED
echo ADR_STATUS=APPROVED
echo DIAGNOSTICS_PLAN=APPROVED
echo VALIDATION_PLAN=APPROVED
echo DEFINITION_OF_DONE=APPROVED
echo ROLLBACK_STRATEGY=APPROVED
echo BASELINE_COMPATIBILITY=CONFIRMED
echo OBSERVABILITY_REQUIREMENTS=APPROVED
echo IMPLEMENTATION_AUTHORIZED=TRUE
echo AS6_EPIC011_APPLICATION_FOUNDATION_PLANNING_CONTROL=PASS
