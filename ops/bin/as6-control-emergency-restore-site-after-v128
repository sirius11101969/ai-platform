#!/usr/bin/env bash
set -euo pipefail
ops/bin/as6-diagnose-emergency-restore-site-after-v128
if command -v npm >/dev/null 2>&1; then npm --prefix frontend run build; else docker run --rm -v "$PWD/frontend:/frontend" -w /frontend node:20-alpine sh -lc "npm ci && npm run build"; fi
curl -kfsS https://www.as6.ru/api/health >/dev/null
echo "AS6_CONTROL_EMERGENCY_RESTORE_SITE_AFTER_V128=PASS"
