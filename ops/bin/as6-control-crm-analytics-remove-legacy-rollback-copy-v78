#!/usr/bin/env bash
set -euo pipefail
ops/bin/as6-diagnose-crm-analytics-remove-legacy-rollback-copy-v78
if command -v npm >/dev/null 2>&1; then
  npm --prefix frontend run build
elif command -v docker >/dev/null 2>&1; then
  docker run --rm -v "$PWD/frontend:/frontend" -w /frontend node:20-alpine sh -lc "npm ci && npm run build"
else
  echo "AS6_FRONTEND_BUILD_RUNNER=FAIL:no npm and no docker image runner"
  exit 1
fi
curl -kfsS https://www.as6.ru/api/health >/dev/null
echo "AS6_FRONTEND_BUILD_RUNNER=PASS"
echo "AS6_CONTROL_CRM_ANALYTICS_REMOVE_LEGACY_ROLLBACK_COPY_V78=PASS"
