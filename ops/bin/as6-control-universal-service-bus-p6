#!/usr/bin/env bash
set -euo pipefail

ops/bin/as6-diagnose-universal-service-bus-p6

grep -RIn "AS6_UNIVERSAL_SERVICE_BUS_DRIFT" README.md docs ops .github frontend/src >/dev/null || {
  echo "AS6_CONTROL_UNIVERSAL_SERVICE_BUS_P6=FAIL drift_class_missing"
  exit 1
}

echo "AS6_CONTROL_UNIVERSAL_SERVICE_BUS_P6=PASS"
