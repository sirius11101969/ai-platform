#!/usr/bin/env bash
set -euo pipefail

cd "${AS6_REPO_ROOT:-$(git rev-parse --show-toplevel 2>/dev/null || pwd)}"

echo "=== AS6 Backup Integrity Diagnostics ==="

fail=0
backup="backup_v1_stable.sql"

if [ -f "$backup" ]; then
  echo "BACKUP_INTEGRITY_FILE=OK:$backup"
else
  echo "BACKUP_INTEGRITY_FILE=FAIL:$backup"
  fail=1
fi

if [ -s "$backup" ]; then
  size="$(stat -c%s "$backup" 2>/dev/null || echo 0)"
  echo "BACKUP_INTEGRITY_SIZE=OK:$size"
else
  echo "BACKUP_INTEGRITY_SIZE=FAIL"
  fail=1
fi

if head -50 "$backup" 2>/dev/null | grep -Eiq 'PostgreSQL|CREATE|COPY|INSERT|SET'; then
  echo "BACKUP_INTEGRITY_SQL_SIGNATURE=OK"
else
  echo "BACKUP_INTEGRITY_SQL_SIGNATURE=FAIL"
  fail=1
fi

if grep -Eiq 'CREATE TABLE|COPY .* FROM stdin|INSERT INTO' "$backup" 2>/dev/null; then
  echo "BACKUP_INTEGRITY_CONTENT=OK"
else
  echo "BACKUP_INTEGRITY_CONTENT=FAIL"
  fail=1
fi

if [ "$fail" -eq 0 ]; then
  echo "BACKUP_INTEGRITY_RESULT=OK"
  exit 0
fi

echo "BACKUP_INTEGRITY_RESULT=FAIL"
exit 1
