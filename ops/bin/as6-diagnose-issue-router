#!/usr/bin/env bash
set -euo pipefail
ROOT="${AS6_REPO_ROOT:-$(git rev-parse --show-toplevel 2>/dev/null || pwd)}"
cd "$ROOT"

WF=".github/workflows/as6-issue-router.yml"
fail=0

test -f "$WF" && echo "ISSUE_ROUTER_FILE=OK" || { echo "ISSUE_ROUTER_FILE=FAIL"; fail=1; }
grep -q "issues:" "$WF" && echo "ISSUE_ROUTER_TRIGGER=OK" || { echo "ISSUE_ROUTER_TRIGGER=FAIL"; fail=1; }
grep -q "actions: write" "$WF" && echo "ISSUE_ROUTER_ACTIONS_PERMISSION=OK" || { echo "ISSUE_ROUTER_ACTIONS_PERMISSION=FAIL"; fail=1; }
grep -q "as6-backend-agent.yml" "$WF" && echo "ISSUE_ROUTER_BACKEND=OK" || { echo "ISSUE_ROUTER_BACKEND=FAIL"; fail=1; }
grep -q "as6-frontend-agent.yml" "$WF" && echo "ISSUE_ROUTER_FRONTEND=OK" || { echo "ISSUE_ROUTER_FRONTEND=FAIL"; fail=1; }
grep -q "as6-devops-agent.yml" "$WF" && echo "ISSUE_ROUTER_DEVOPS=OK" || { echo "ISSUE_ROUTER_DEVOPS=FAIL"; fail=1; }

if [ "$fail" -eq 0 ]; then
  echo "ISSUE_ROUTER_RESULT=OK"
  exit 0
fi

echo "ISSUE_ROUTER_RESULT=FAIL"
exit 1
