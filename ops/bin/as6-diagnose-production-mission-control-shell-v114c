#!/usr/bin/env bash
set -euo pipefail
FAIL=0
SHELL="frontend/src/components/AS6ProductionMissionControlShell.jsx"
CSS="frontend/src/styles/as6-production-mission-control-shell.css"
DOC="docs/AS6_REAL_PRODUCTION_MISSION_CONTROL_SHELL_V114C.md"
for f in "$SHELL" "$CSS" "$DOC"; do test -f "$f" || FAIL=1; done
grep -Rqs "AS6ProductionMissionControlShell.jsx" frontend/src/main.jsx || FAIL=1
grep -Rqs "as6-production-brand-shell-active" "$CSS" || FAIL=1
grep -Rqs "Command Center" "$SHELL" || FAIL=1
for cls in MAIN_ENTRY_SHELL_MOUNT_MISSING PRODUCTION_STATIC_BUNDLE_NOT_REPLACED LEGACY_AI_OS_VISIBLE_AFTER_DEPLOY NGINX_STATIC_RELOAD_MISSING REAL_VISUAL_MIGRATION_NOT_VISIBLE; do grep -Rqs "$cls" ops docs || FAIL=1; done
if git diff --cached --name-only | grep -q "^runtime/"; then FAIL=1; fi
if [ "$FAIL" -ne 0 ]; then echo "AS6_PRODUCTION_MISSION_CONTROL_SHELL=FAIL"; exit 1; fi
echo "AS6_PRODUCTION_MISSION_CONTROL_SHELL=PASS"
