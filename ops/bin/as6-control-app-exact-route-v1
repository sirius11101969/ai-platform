#!/usr/bin/env bash
set -Eeuo pipefail
ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
APP="$ROOT/frontend/src/App.jsx"
node -e 'const fs=require("fs");const s=fs.readFileSync(process.argv[1],"utf8");const exactGuarded=`<Route path="/app" element={<RequirePrimaryAuth><LivingProductPreviewPage /></RequirePrimaryAuth>} />`;const splatGuarded=`<Route path="/app/*" element={<RequirePrimaryAuth><LivingProductPreviewPage /></RequirePrimaryAuth>} />`;const exactLegacy=`<Route path="/app" element={<LivingProductPreviewPage />} />`;const splatLegacy=`<Route path="/app/*" element={<LivingProductPreviewPage />} />`;const exact=s.includes(exactGuarded)?exactGuarded:exactLegacy;const splat=s.includes(splatGuarded)?splatGuarded:splatLegacy;if(!s.includes(exact)||!s.includes(splat)||s.indexOf(exact)>s.indexOf(splat))process.exit(1);' "$APP"
echo "AS6_APP_EXACT_ROUTE=PASS"
echo "AS6_APP_NESTED_ROUTE=PASS"
echo "AS6_APP_ROUTE_ORDER=PASS"
echo "AS6_APP_EXACT_ROUTE_AUTH_WRAPPER_COMPATIBILITY=PASS"
echo "AS6_APP_EXACT_ROUTE_CONTROL=PASS"
