#!/usr/bin/env bash
set -euo pipefail
FAIL=0
COMPONENT="frontend/src/components/AS6UnifiedDataSurface.jsx"
CSS="frontend/src/styles/as6-unified-data-surface-system.css"
MANIFEST="docs/AS6_UNIFIED_DATA_SURFACE_SYSTEM_V101.md"
for f in "$COMPONENT" "$CSS" "$MANIFEST"; do
  if [ ! -f "$f" ]; then echo "AS6_DATA_SURFACE_FILE_MISSING $f"; FAIL=1; fi
done
if ! grep -Rqs "as6-unified-data-surface-system.css" frontend/src/App.jsx; then echo "AS6_DATA_SURFACE_IMPORT_MISSING"; FAIL=1; fi
for item in "AS6DataSurface" "AS6DataKPI" "AS6DataTable" "AS6DataActionBar" "AS6DataState" "KPI Strip" "CRM Cards" "Kanban Columns"; do
  if ! grep -Rqs "$item" "$COMPONENT" "$CSS" "$MANIFEST" ops/governance docs ops/status ops/registry; then echo "AS6_DATA_SURFACE_ITEM_MISSING $item"; FAIL=1; fi
done
for cls in UNIFIED_DATA_SURFACE_MISSING KPI_SURFACE_DRIFT TABLE_SURFACE_DRIFT CRM_CARD_SURFACE_DRIFT KANBAN_SURFACE_DRIFT FILTER_FORM_SURFACE_DRIFT CHART_SURFACE_DRIFT ACTION_BAR_SURFACE_DRIFT MODAL_DRAWER_SURFACE_DRIFT STATE_SURFACE_DRIFT; do
  if ! grep -Rqs "$cls" ops/registry ops/governance ops/status docs; then echo "AS6_DATA_SURFACE_CLASS_MISSING $cls"; FAIL=1; fi
done
if git diff --cached --name-only | grep -q "^runtime/"; then echo "AS6_RUNTIME_STAGING_FAIL"; FAIL=1; fi
if [ "$FAIL" -ne 0 ]; then exit 1; fi
echo "AS6_UNIFIED_DATA_SURFACE_SYSTEM=PASS"
