#!/usr/bin/env bash
set -Eeuo pipefail
ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
PREVIEW="$ROOT/frontend/src/living/product-v1/LivingProductPreviewPage.jsx"
APP="$ROOT/frontend/src/living/product-v2/LivingCanonicalApp.jsx"
CSS="$ROOT/frontend/src/living/product-v2/LivingCanonicalApp.css"
grep -Fq "LivingCanonicalApp" "$PREVIEW"
grep -Fq "data-as6-runtime=\"canonical-reference-v1\"" "$APP"
grep -Fq "LivingDocumentsSpace" "$APP"
grep -Fq "as6-reference-root" "$CSS"
grep -Fq "height:100svh" "$CSS"
test ! -e "$ROOT/frontend/src/living/product-v2/LivingShellV2.jsx"
test ! -e "$ROOT/frontend/src/living/product-v2/LivingShellV2.css"
test ! -e "$ROOT/frontend/src/living/product-v2/LivingDocumentsSpace.css"
! grep -Rqs "as6-v2-sidebar\|as6-v2-topbar" "$PREVIEW" "$APP" "$CSS"
echo "AS6_CANONICAL_ROOT_RUNTIME_OWNER=PASS"
echo "AS6_OBSOLETE_RUNTIME_UI_REMOVED=PASS"
echo "AS6_REFERENCE_BASELINE_CONTROL=PASS"
echo "AS6_CANONICAL_REFERENCE_RESET_CONTROL=PASS"
