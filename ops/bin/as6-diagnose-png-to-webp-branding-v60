#!/usr/bin/env bash
set -euo pipefail
BRAND="frontend/src/components/branding/AS6Logo.jsx"
PNG="frontend/src/assets/as6-logo.png"
WEBP="frontend/src/assets/as6-logo.webp"
BUILD_LOG="${1:-}"
fail=0
check(){ n="$1"; shift; if "$@"; then echo "PASS:$n"; else echo "FAIL:$n"; fail=1; fi; }

check branding_component_exists test -f "$BRAND"
check logo_png_exists test -f "$PNG"
check logo_webp_exists test -f "$WEBP"
check branding_uses_webp grep -q "as6-logo.webp" "$BRAND"
check branding_png_import_absent bash -c '! grep -q "as6-logo.png" frontend/src/components/branding/AS6Logo.jsx'
check branding_class_preserved grep -q "as6-real-logo-image" "$BRAND"
check command_center_webp_logo grep -q "as6-logo.webp" frontend/src/pages/CommandCenterPage.jsx
check duplicate_top_logo_absent bash -c '! grep -q as6-command-center-logo-image frontend/src/pages/CommandCenterPage.jsx'

png_bytes="$(wc -c < "$PNG")"
webp_bytes="$(wc -c < "$WEBP")"
echo "SOURCE_LOGO_PNG_BYTES=$png_bytes"
echo "SOURCE_LOGO_WEBP_BYTES=$webp_bytes"
if test "$webp_bytes" -lt "$png_bytes"; then echo "PASS:webp_smaller_than_png"; else echo "FAIL:webp_smaller_than_png"; fail=1; fi
if test "$webp_bytes" -lt 120000; then echo "PASS:webp_logo_budget"; else echo "FAIL:webp_logo_budget"; fail=1; fi

if test -n "$BUILD_LOG" && test -f "$BUILD_LOG"; then
  check frontend_build_clean bash -c '! grep -q "css-syntax-error\|Expected identifier but found\|Unexpected \"}\"\|lazy is not defined\|Suspense is not defined" "$0"' "$BUILD_LOG"
  check build_webp_logo_present grep -q "dist/assets/as6-logo-.*\.webp" "$BUILD_LOG"
  if grep -q "dist/assets/as6-logo-.*\.png" "$BUILD_LOG"; then
    echo "WARN:png_logo_still_emitted_check_css_or_unused_backup"
  else
    echo "PASS:png_logo_not_emitted"
  fi
fi

exit "$fail"
