#!/usr/bin/env bash
set -euo pipefail

ops/bin/as6-diagnose-plugin-marketplace-runtime-p10

grep -RIn "AS6_PLUGIN_MARKETPLACE_RUNTIME_DRIFT" README.md docs ops .github frontend/src >/dev/null || {
  echo "AS6_CONTROL_PLUGIN_MARKETPLACE_RUNTIME_P10=FAIL drift_class_missing"
  exit 1
}

echo "AS6_CONTROL_PLUGIN_MARKETPLACE_RUNTIME_P10=PASS"
