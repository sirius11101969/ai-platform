#!/usr/bin/env bash
set -euo pipefail
echo "=== AS6 Command Center Pixel Polish V11 Diagnostics ==="
css="frontend/src/theme/as6Theme.css"
fail=0
grep -q "AS6 Command Center Pixel Polish V11" "$css" && echo "AS6_V11_CSS=PASS" || { echo "AS6_V11_CSS=FAIL"; fail=1; }
grep -q "5.5% 0,100% 0,94.5% 100%,0 100%" "$css" && echo "AS6_V11_FUNNEL_GEOMETRY=PASS" || { echo "AS6_V11_FUNNEL_GEOMETRY=FAIL"; fail=1; }
grep -q "robot-icon.copilot-avatar-v2 { width:116px" "$css" && echo "AS6_V11_COPILOT_SIZE=PASS" || { echo "AS6_V11_COPILOT_SIZE=FAIL"; fail=1; }
grep -q "as6-sidebar-brand strong" "$css" && echo "AS6_V11_BRAND_LOCKUP=PASS" || { echo "AS6_V11_BRAND_LOCKUP=FAIL"; fail=1; }
grep -q "quick-actions-primary a:hover" "$css" && echo "AS6_V11_QUICK_ACTION_INTERACTION=PASS" || { echo "AS6_V11_QUICK_ACTION_INTERACTION=FAIL"; fail=1; }
grep -q ".recommendation { min-height:122px" "$css" && echo "AS6_V11_RECOMMENDATION_POLISH=PASS" || { echo "AS6_V11_RECOMMENDATION_POLISH=FAIL"; fail=1; }
if [ "$fail" -eq 0 ]; then echo "AS6_COMMAND_CENTER_PIXEL_POLISH_V11_RESULT=OK"; exit 0; fi
echo "AS6_COMMAND_CENTER_PIXEL_POLISH_V11_RESULT=FAIL"; exit 1
