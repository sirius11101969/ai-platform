#!/usr/bin/env bash
set -euo pipefail
test -f frontend/src/as6-one/AS6OneShellAdapter.jsx || { echo "AS6_ONE_SHELL_REAL_WIRING_V86=FAIL adapter_missing"; exit 1; }
grep -q "AS6Shell" frontend/src/as6-one/AS6OneShellAdapter.jsx || { echo "AS6_ONE_SHELL_REAL_WIRING_V86=FAIL shell_import_missing"; exit 1; }
grep -q "AS6OnePage" frontend/src/as6-one/AS6OneShellAdapter.jsx || { echo "AS6_ONE_SHELL_REAL_WIRING_V86=FAIL page_import_missing"; exit 1; }
grep -q "livingSpaceTarget=\"/as6-sales\"" frontend/src/as6-one/AS6OneShellAdapter.jsx || { echo "AS6_ONE_SHELL_REAL_WIRING_V86=FAIL living_space_target_missing"; exit 1; }
grep -RIn "/as6-one" frontend/src >/dev/null || { echo "AS6_ONE_SHELL_REAL_WIRING_V86=FAIL route_missing"; exit 1; }
grep -RIn "AS6OneShellAdapter" frontend/src/App.* frontend/src/main.* >/dev/null || { echo "AS6_ONE_SHELL_REAL_WIRING_V86=FAIL route_adapter_reference_missing"; exit 1; }
echo "AS6_ONE_SHELL_REAL_WIRING_V86=PASS"
