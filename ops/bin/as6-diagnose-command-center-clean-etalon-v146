#!/usr/bin/env bash
set -euo pipefail
echo "AS6_DIAGNOSTIC=command-center-clean-etalon-v146"
fail=0

grep -q "AS6 V146 clean Command Center etalon" frontend/src/styles/as6-command-center-visual-etalon-v134.css || { echo "FAIL v146-clean-css-missing"; fail=1; }

bad_css="$(grep -nE "V137|V138|z-index: 2147483647|workspace::after|Mission Control Layout 2.0|AS6 Mission Control" frontend/src/styles/as6-command-center-visual-etalon-v134.css || true)"
if [ -n "$bad_css" ]; then
  echo "FAIL accumulated-old-css-remains"
  echo "$bad_css"
  fail=1
else
  echo "PASS accumulated-old-css-removed"
fi

if [ "$fail" -eq 0 ]; then
  echo "AS6_COMMAND_CENTER_CLEAN_ETALON_V146=PASS"
else
  echo "AS6_COMMAND_CENTER_CLEAN_ETALON_V146=FAIL"
  exit 1
fi
