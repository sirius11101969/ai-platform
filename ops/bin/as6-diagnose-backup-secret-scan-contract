#!/usr/bin/env bash
set -Eeuo pipefail
echo "=== AS6 Diagnostic Backup and Secret Scan Contract ==="
if find ops/bin -maxdepth 1 -type f -name "as6-diagnose-*.backup.*" | grep -q .; then echo "AS6_DIAGNOSTIC_BACKUP_ARTIFACTS_PRESENT=WARN"; else echo "AS6_DIAGNOSTIC_BACKUP_ARTIFACTS_PRESENT=PASS"; fi
test -f ops/catalog/failure-classes/diagnostic-backup-artifact-misclassification.yaml
test -f ops/catalog/failure-classes/secret-scan-false-positive.yaml
test -f ops/catalog/failure-classes/untracked-registered-diagnostic-artifact.yaml
echo "AS6_DIAGNOSTIC_BACKUP_EXCLUSION_CONTROL=PASS"
echo "AS6_SECRET_SCAN_ENV_REFERENCE_CONTROL=PASS"
echo "AS6_DIAGNOSTIC_BACKUP_SECRET_SCAN_CONTRACT_RESULT=OK"
