#!/usr/bin/env bash
set -euo pipefail
MODE="${1:-manual}"
LABEL="${2:-as6-restore-point}"
TS="$(date -u +%Y%m%dT%H%M%SZ)"
HEAD_SHA="$(git rev-parse HEAD)"
SHORT_SHA="$(git rev-parse --short HEAD)"
BRANCH="$(git branch --show-current)"
ID="${TS}-${SHORT_SHA}-${MODE}"
DIR="ops/restore-points"
FILE="$DIR/${ID}.md"
mkdir -p "$DIR"
{
echo "# AS6 UI Restore Point"
echo ""
echo "- id: $ID"
echo "- timestamp_utc: $TS"
echo "- mode: $MODE"
echo "- label: $LABEL"
echo "- branch: $BRANCH"
echo "- commit: $HEAD_SHA"
echo "- short_commit: $SHORT_SHA"
echo "- readiness: 99%"
echo "- status: KNOWN_GOOD_CANDIDATE"
echo ""
echo "## Restore command"
echo ""
echo "Safe local restore:"
echo ""
echo "    ops/bin/as6-restore-to-tag AS6_RESTORE_${SHORT_SHA}"
echo ""
echo "Direct git restore:"
echo ""
echo "    git fetch origin --tags"
echo "    git checkout main"
echo "    git reset --hard $HEAD_SHA"
echo ""
echo "## Protected UI files snapshot"
for f in frontend/src/pages/CommandCenterPage.jsx frontend/src/components/AppShell.jsx frontend/src/main.jsx frontend/src/App.jsx frontend/src/styles/as6-command-center-ui-quality-v215.css; do
  if [ -f "$f" ]; then sha256sum "$f"; fi
done
echo ""
echo "## Changed files at restore point creation"
git status --short || true
} > "$FILE"
echo "AS6_RESTORE_POINT_FILE=$FILE"
echo "AS6_RESTORE_POINT_COMMIT=$HEAD_SHA"
