#!/usr/bin/env bash
set -euo pipefail
test -f frontend/src/as6os/workspaceExperience/workspaceExperienceRuntime.jsx
test -f frontend/src/as6os/workspaceExperience/AS6WorkspaceExperienceFoundation.jsx
test -f frontend/src/as6os/workspaceExperience/workspaceExperience.css
