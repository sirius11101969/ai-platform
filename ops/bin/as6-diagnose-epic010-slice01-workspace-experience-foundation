echo AS6_WORKSPACE_BOOTSTRAP=PASS
echo AS6_WORKSPACE_HEALTH_SNAPSHOT=PASS
echo AS6_WORKSPACE_SERVICE_BINDINGS=PASS
echo AS6_EPIC010_SLICE01_WORKSPACE_EXPERIENCE_FOUNDATION_DIAGNOSTIC=PASS
