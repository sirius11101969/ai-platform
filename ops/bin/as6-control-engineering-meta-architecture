#!/usr/bin/env bash
set -euo pipefail
ops/bin/as6-diagnose-engineering-meta-architecture
grep -q AS6_ENGINEERING_META_ARCHITECTURE_MISSING ops/governance/as6-engineering-meta-architecture-root-cause.md
grep -q AS6_AEC_ENGINEERING_META_ARCHITECTURE_REQUIRED ops/governance/as6-engineering-meta-architecture-aec.md
grep -q AS6_AEC_META_ARCHITECTURE_NOT_SUPERSTANDARD ops/governance/as6-engineering-meta-architecture-aec.md
grep -q AS6_AEC_AUTHORITY_TRACEABILITY_SEPARATION_REQUIRED ops/governance/as6-engineering-meta-architecture-aec.md
echo AS6_ENGINEERING_META_ARCHITECTURE_CONTROL=PASS
