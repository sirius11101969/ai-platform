#!/usr/bin/env bash
set -euo pipefail
ops/bin/as6-diagnose-mission-control-layout-engine-v90
ops/bin/as6-diagnose-global-command-palette-v89
ops/bin/as6-diagnose-global-health-bar-v88
if command -v npm >/dev/null 2>&1; then
  npm --prefix frontend run build
elif command -v docker >/dev/null 2>&1; then
  docker run --rm -v "$PWD/frontend:/frontend" -w /frontend node:20-alpine sh -lc "npm ci && npm run build"
else
  echo "AS6_FRONTEND_BUILD_RUNNER_FAIL"
  exit 1
fi
curl -kfsS https://www.as6.ru/api/health >/dev/null
AS6_ENFORCEMENT_MODE=same-cycle ops/bin/as6-pre-commit-push-enforcement
echo "AS6_CONTROL_MISSION_CONTROL_LAYOUT_ENGINE_V90=PASS"
