#!/usr/bin/env bash
set -euo pipefail

REGISTRY="frontend/src/as6/living-spaces/as6LivingSpaceRegistry.js"
CONTRACT="frontend/src/as6/living-spaces/AS6LivingSpaceRegistry.contract.md"
APP_FILE="frontend/src/App.jsx"

test -f "$REGISTRY" || { echo "AS6_LIVING_SPACE_REGISTRY_V90=FAIL registry_missing"; exit 1; }
test -f "$CONTRACT" || { echo "AS6_LIVING_SPACE_REGISTRY_V90=FAIL contract_missing"; exit 1; }

grep -q 'id: "as6-one"' "$REGISTRY" || { echo "AS6_LIVING_SPACE_REGISTRY_V90=FAIL as6_one_id_missing"; exit 1; }
grep -q 'route: "/as6-one"' "$REGISTRY" || { echo "AS6_LIVING_SPACE_REGISTRY_V90=FAIL as6_one_route_missing"; exit 1; }
grep -q 'adapter: "AS6OneShellAdapter"' "$REGISTRY" || { echo "AS6_LIVING_SPACE_REGISTRY_V90=FAIL as6_one_adapter_missing"; exit 1; }

grep -q 'id: "as6-sales"' "$REGISTRY" || { echo "AS6_LIVING_SPACE_REGISTRY_V90=FAIL as6_sales_id_missing"; exit 1; }
grep -q 'route: "/as6-sales"' "$REGISTRY" || { echo "AS6_LIVING_SPACE_REGISTRY_V90=FAIL as6_sales_route_missing"; exit 1; }
grep -q 'adapter: "AS6SalesShellAdapter"' "$REGISTRY" || { echo "AS6_LIVING_SPACE_REGISTRY_V90=FAIL as6_sales_adapter_missing"; exit 1; }

grep -q 'contextBarMode: "adaptive"' "$REGISTRY" || { echo "AS6_LIVING_SPACE_REGISTRY_V90=FAIL context_bar_policy_missing"; exit 1; }
grep -q 'intelligenceRailMode: "adaptive"' "$REGISTRY" || { echo "AS6_LIVING_SPACE_REGISTRY_V90=FAIL intelligence_rail_policy_missing"; exit 1; }
grep -q 'businessLogicPolicy:' "$REGISTRY" || { echo "AS6_LIVING_SPACE_REGISTRY_V90=FAIL business_logic_policy_missing"; exit 1; }

grep -q 'path="/as6-one"' "$APP_FILE" || { echo "AS6_LIVING_SPACE_REGISTRY_V90=FAIL app_as6_one_route_missing"; exit 1; }
grep -q 'path="/as6-sales"' "$APP_FILE" || { echo "AS6_LIVING_SPACE_REGISTRY_V90=FAIL app_as6_sales_route_missing"; exit 1; }

echo "AS6_LIVING_SPACE_REGISTRY_V90=PASS"
