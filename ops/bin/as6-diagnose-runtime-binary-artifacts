#!/usr/bin/env bash
set -euo pipefail
cd /var/www/ai-platform

echo "=== AS6 Runtime Binary Artifacts Diagnostics ==="

fail=0

for f in /tmp/as6-*; do
  [ -e "$f" ] || continue

  case "$f" in
    /tmp/as6-node20-actions.out|/tmp/as6-node24-legacy.out)
      echo "RUNTIME_BINARY_ARTIFACT=SKIP:external_tool_output:$f"
      continue
      ;;
  esac

  if [ ! -s "$f" ]; then
    echo "RUNTIME_BINARY_ARTIFACT=SKIP:empty_runtime_tmp:$f"
    continue
  fi

  if LC_ALL=C grep -Iq . "$f"; then
    echo "RUNTIME_BINARY_ARTIFACT=SKIP:text_runtime_tmp:$f"
    continue
  fi

  echo "RUNTIME_BINARY_ARTIFACT=FAIL:$f"
  fail=1
done

if [ "$fail" -eq 0 ]; then
  echo "RUNTIME_BINARY_ARTIFACTS_RESULT=OK"
  exit 0
fi

echo "RUNTIME_BINARY_ARTIFACTS_RESULT=FAIL"
exit 1
