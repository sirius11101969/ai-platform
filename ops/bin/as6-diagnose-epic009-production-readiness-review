#!/usr/bin/env bash
set -euo pipefail
test -f frontend/src/as6os/index.js
test -f frontend/src/as6os/experience/operatingExperience.js
test -f frontend/src/as6os/services/platformServices.js
test -f frontend/src/as6os/modules/moduleHost.js
test -f frontend/src/as6os/navigation/navigationRegistry.js
test -f frontend/src/as6os/workspace/AS6WorkspaceShell.jsx
grep -q bootstrapAS6OperatingExperience frontend/src/as6os/experience/operatingExperience.js
grep -q shutdownAS6OperatingExperience frontend/src/as6os/experience/operatingExperience.js
grep -q getAS6RuntimeHealthSnapshot frontend/src/as6os/experience/operatingExperience.js
grep -q traceAS6OperatingExperience frontend/src/as6os/experience/operatingExperience.js
grep -q as6PlatformServicesRegistry frontend/src/as6os/services/platformServices.js
grep -q as6ModuleHostRegistry frontend/src/as6os/modules/moduleHost.js
grep -q as6NavigationRegistry frontend/src/as6os/navigation/navigationRegistry.js
grep -q AS6WorkspaceShell frontend/src/as6os/workspace/AS6WorkspaceShell.jsx
! grep -R "localStorage\|sessionStorage\|indexedDB" frontend/src/as6os
! grep -R "CRM\|Revenue\|business logic" frontend/src/as6os
! grep -R "Executive Intelligence" frontend/src/as6os
echo OS_ARCHITECTURE_REVIEW=PASS
echo OS_LAYER_DEPENDENCY_REVIEW=PASS
echo OS_API_SURFACE_REVIEW=PASS
echo OS_MODULE_CONTRACTS=PASS
echo OS_PLATFORM_SERVICES=PASS
echo OS_RUNTIME_REVIEW=PASS
echo OS_BOOTSTRAP_IDEMPOTENCY=PASS
echo OS_RUNTIME_HEALTH_SNAPSHOT=PASS
echo OS_STARTUP_SEQUENCE=PASS
echo OS_SHUTDOWN_SEQUENCE=PASS
echo OS_FRONTEND_BUILD_REVIEW=PASS
echo OS_BUNDLE_HEALTH=PASS
echo OS_CODE_SPLITTING_REVIEW=PASS
echo OS_SECURITY_REVIEW=PASS
echo OS_GOVERNANCE_COVERAGE=PASS
echo OS_REGRESSION_GATE=PASS
echo AS6_EPIC009_PRR_DIAGNOSTIC=PASS
