#!/usr/bin/env bash
set -Eeuo pipefail

ROOT="${AS6_ROOT:-$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)}"
cd "$ROOT"

for file in \
  nginx.conf \
  docker-compose.yml \
  docker-compose.staging.yml \
  ops/bin/as6-configure-secure-staging-access-v1 \
  ops/bin/as6-secure-staging-smoke-v1; do
  test -f "$file"
done

bash -n ops/bin/as6-configure-secure-staging-access-v1
bash -n ops/bin/as6-secure-staging-smoke-v1
grep -q 'server_name staging.as6.ru' nginx.conf
grep -Fq 'auth_basic $as6_staging_api_basic_realm;' nginx.conf
grep -Fq '~*^Bearer[[:space:]]+ off;' nginx.conf
grep -Fq 'auth_basic "AS6 protected staging";' nginx.conf
grep -q 'X-Robots-Tag "noindex, nofollow, noarchive"' nginx.conf
grep -q 'return 200 "User-agent: \*\\nDisallow: /\\n"' nginx.conf
grep -Fq 'set $as6_staging_upstream http://as6-staging-edge:80;' nginx.conf
grep -q 'as6-staging-edge' docker-compose.yml
grep -q 'as6-staging-edge' docker-compose.staging.yml
grep -q '127.0.0.1:${AS6_STAGING_HTTP_PORT:-18080}:80' docker-compose.staging.yml
grep -q 'APP_URL=https://staging.as6.ru' .env.staging.example
grep -q 'AS6_STAGING_CANONICAL_ORIGIN=PASS' ops/bin/as6-init-staging-v1
grep -q 'UNAUTH_CODE.*401' ops/bin/as6-secure-staging-smoke-v1
grep -q 'BEARER_SHELL_CODE.*401' ops/bin/as6-secure-staging-smoke-v1
grep -q 'AS6_STAGING_ORIGIN_ISOLATION=PASS' ops/bin/as6-secure-staging-smoke-v1
! grep -Eq 'echo.*AS6_STAGING_BASIC_AUTH_PASSWORD|set -x' ops/bin/as6-configure-secure-staging-access-v1
grep -q 'ops/bin/as6-ensure-staging-edge-network-v1' ops/bin/as6-staging-deploy-v1
grep -q 'ops/bin/as6-ensure-staging-edge-network-v1' ops/bin/as6-promote-production-v1
grep -Fq 'ai-platform-nginx)' ops/bin/as6-configure-secure-staging-access-v1
grep -Fq "printf '%s\\n' latest" ops/bin/as6-configure-secure-staging-access-v1
grep -Fq 'AS6_STAGING_ACME_ATTEMPT_${attempt}=WAIT' ops/bin/as6-configure-secure-staging-access-v1
grep -Fq 'ACME_PROBE_READY' ops/bin/as6-configure-secure-staging-access-v1
grep -Fq -- '--resolve "$DOMAIN:80:127.0.0.1"' ops/bin/as6-configure-secure-staging-access-v1
grep -Fq 'AS6_STAGING_TLS_ATTEMPT_${attempt}=WAIT' ops/bin/as6-configure-secure-staging-access-v1
grep -Fq -- '--resolve "$DOMAIN:443:127.0.0.1"' ops/bin/as6-configure-secure-staging-access-v1
grep -Fq 'chmod 644 "$PROBE_FILE"' ops/bin/as6-configure-secure-staging-access-v1
grep -Fq 'umask 022' ops/bin/as6-configure-secure-staging-access-v1
grep -Fq 'NGINX_GID="$(docker exec ai-platform-nginx-1 id -g nginx)"' ops/bin/as6-configure-secure-staging-access-v1
grep -Fq 'chmod 750 "$ACCESS_DIR"' ops/bin/as6-configure-secure-staging-access-v1
grep -Fq 'chmod 640 "$HTPASSWD_FILE"' ops/bin/as6-configure-secure-staging-access-v1

TEST_ROOT="$(mktemp -d)"
trap 'rm -rf -- "$TEST_ROOT"' EXIT
mkdir -p "$TEST_ROOT/certs/live/as6.ru" "$TEST_ROOT/access" "$TEST_ROOT/webroot"
openssl req -x509 -nodes -newkey rsa:2048 -days 1 \
  -subj '/CN=staging.as6.ru' \
  -keyout "$TEST_ROOT/certs/live/as6.ru/privkey.pem" \
  -out "$TEST_ROOT/certs/live/as6.ru/fullchain.pem" >/dev/null 2>&1
printf 'control:%s\n' "$(printf 'control-password' | openssl passwd -apr1 -stdin)" > "$TEST_ROOT/access/staging.htpasswd"

docker run --rm \
  --add-host backend:127.0.0.1 \
  -v "$ROOT/nginx.conf:/etc/nginx/nginx.conf:ro" \
  -v "$TEST_ROOT/certs:/etc/letsencrypt:ro" \
  -v "$TEST_ROOT/access:/etc/nginx/as6:ro" \
  -v "$TEST_ROOT/webroot:/var/www/certbot:ro" \
  nginx:alpine nginx -t >/dev/null

echo "AS6_STAGING_EDGE_NETWORK_CONTRACT=PASS"
echo "AS6_STAGING_BEARER_AUTH_COMPATIBILITY=PASS"
echo "AS6_STAGING_NOINDEX_CONTRACT=PASS"
echo "AS6_SECURE_STAGING_ACCESS_V1=PASS"
