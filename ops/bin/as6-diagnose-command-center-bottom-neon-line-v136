#!/usr/bin/env bash
set -euo pipefail
echo "AS6_DIAGNOSTIC=command-center-bottom-neon-line-v136"
fail=0
grep -q "AS6 V136 remove bottom neon line" frontend/src/styles/as6-command-center-visual-etalon-v134.css || { echo "FAIL v136-css-missing"; fail=1; }
grep -q "overflow-x: hidden" frontend/src/styles/as6-command-center-visual-etalon-v134.css || { echo "FAIL overflow-x-control-missing"; fail=1; }
grep -q "command-main-grid::after" frontend/src/styles/as6-command-center-visual-etalon-v134.css || { echo "FAIL bottom-pseudo-control-missing"; fail=1; }
bad="$(grep -RInE "final-runtime-style-v127|hard-fix-v128|reference-polish-v123c|arrow-fix-v126|createElement\(\"style\"\)|appendChild\(style\)|style\.textContent|insertAdjacentHTML" frontend/src frontend/index.html frontend/public 2>/dev/null || true)"
if [ -n "$bad" ]; then echo "FAIL forbidden-runtime-or-old-patch"; echo "$bad"; fail=1; else echo "PASS forbidden-runtime-or-old-patch"; fi
if [ "$fail" -eq 0 ]; then echo "AS6_COMMAND_CENTER_BOTTOM_NEON_LINE_V136=PASS"; else echo "AS6_COMMAND_CENTER_BOTTOM_NEON_LINE_V136=FAIL"; exit 1; fi
