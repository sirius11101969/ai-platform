#!/usr/bin/env bash
set -euo pipefail
echo "AS6_DIAGNOSTIC=command-center-real-horizontal-strip-v137"
fail=0
grep -q "AS6 V137 remove real horizontal strip" frontend/src/styles/as6-command-center-visual-etalon-v134.css || { echo "FAIL v137-css-missing"; fail=1; }
grep -q "overflow-x: clip" frontend/src/styles/as6-command-center-visual-etalon-v134.css || { echo "FAIL overflow-clip-control-missing"; fail=1; }
grep -q "::-webkit-scrollbar:horizontal" frontend/src/styles/as6-command-center-visual-etalon-v134.css || { echo "FAIL horizontal-scrollbar-control-missing"; fail=1; }
bad="$(grep -RInE "final-runtime-style-v127|hard-fix-v128|reference-polish-v123c|arrow-fix-v126|createElement\(\"style\"\)|appendChild\(style\)|style\.textContent|insertAdjacentHTML" frontend/src frontend/index.html frontend/public 2>/dev/null || true)"
if [ -n "$bad" ]; then echo "FAIL forbidden-runtime-or-old-patch"; echo "$bad"; fail=1; else echo "PASS forbidden-runtime-or-old-patch"; fi
if [ "$fail" -eq 0 ]; then echo "AS6_COMMAND_CENTER_REAL_HORIZONTAL_STRIP_V137=PASS"; else echo "AS6_COMMAND_CENTER_REAL_HORIZONTAL_STRIP_V137=FAIL"; exit 1; fi
