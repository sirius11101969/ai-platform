#!/usr/bin/env bash
set -euo pipefail
test -f docs/epic009/as6-epic009-solution-design-package.md
test -f docs/epic009/as6-operating-system-specification.md
test -f docs/epic009/as6-operating-system-capability-map.md
test -f docs/epic009/as6-workspace-architecture.md
test -f docs/epic009/as6-platform-contracts.md
test -f docs/epic009/as6-operating-experience-specification.md
test -f docs/epic009/as6-runtime-observability-model.md
test -f docs/epic009/as6-compatibility-migration-package.md
test -f docs/epic009/as6-epic009-implementation-blueprint.md
grep -q "SOLUTION_DESIGN_PACKAGE=APPROVED" docs/epic009/as6-epic009-solution-design-package.md
grep -q "AS6_OS_CORE=APPROVED" docs/epic009/as6-operating-system-specification.md
grep -q "WORKSPACE=REQUIRED" docs/epic009/as6-operating-system-capability-map.md
grep -q "MODULE_HOST_CONTRACT=APPROVED" docs/epic009/as6-platform-contracts.md
