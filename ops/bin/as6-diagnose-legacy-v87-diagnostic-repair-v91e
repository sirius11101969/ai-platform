#!/usr/bin/env bash
set -euo pipefail

APP_FILE="frontend/src/App.jsx"
ROUTES="frontend/src/as6/living-spaces/AS6LivingSpaceRoutes.jsx"
REGISTRY="frontend/src/as6/living-spaces/as6LivingSpaceRegistry.js"
V87_DIAG="ops/bin/as6-diagnose-context-rail-contract-v87"

ops/bin/as6-diagnose-context-rail-contract-v87
ops/bin/as6-diagnose-crm-lazy-import-v89
ops/bin/as6-diagnose-living-space-registry-v90
ops/bin/as6-diagnose-registry-auth-routes-v91b
ops/bin/as6-diagnose-legacy-v90-diagnostic-repair-v91c
ops/bin/as6-diagnose-legacy-v89-diagnostic-repair-v91d

grep -q "<AS6LivingSpaceRoutes />" "$APP_FILE" || { echo "AS6_LEGACY_V87_DIAGNOSTIC_REPAIR_V91E=FAIL app_registry_delegate_missing"; exit 1; }
grep -q "AS6OneShellAdapter" "$ROUTES" || { echo "AS6_LEGACY_V87_DIAGNOSTIC_REPAIR_V91E=FAIL routes_as6_one_adapter_missing"; exit 1; }
grep -q 'contextBarMode: "adaptive"' "$REGISTRY" || { echo "AS6_LEGACY_V87_DIAGNOSTIC_REPAIR_V91E=FAIL registry_context_policy_missing"; exit 1; }
grep -q "AS6LivingSpaceRoutes" "$V87_DIAG" || { echo "AS6_LEGACY_V87_DIAGNOSTIC_REPAIR_V91E=FAIL v87_diag_not_registry_aware"; exit 1; }

echo "AS6_LEGACY_V87_DIAGNOSTIC_REPAIR_V91E=PASS"
