#!/usr/bin/env bash
set -euo pipefail

ROOT="${AS6_REPO_ROOT:-$(git rev-parse --show-toplevel 2>/dev/null || pwd)}"
cd "$ROOT"

OUT="ops/status/diagnostic-status-registry.json"
TMP="$(mktemp)"

python3 - <<'PY' > "$TMP"
import json
from pathlib import Path

OUT = Path("ops/status/diagnostic-status-registry.json")
ACTIVE = "ACTIVE"
HISTORICAL = {"ARCHIVED", "DEPRECATED", "REMOVED"}
SUPPORTED = {ACTIVE, *HISTORICAL}

if OUT.exists():
    data = json.loads(OUT.read_text())
    diagnostics = data.get("diagnostics", [])
else:
    diagnostics = []

by_path = {}
for item in diagnostics:
    if not isinstance(item, dict) or not item.get("path"):
        continue
    item = dict(item)
    item["status"] = item.get("status", ACTIVE)
    if item["status"] not in SUPPORTED:
        item["status"] = ACTIVE
    by_path.setdefault(item["path"], item)

for p in sorted(Path("ops/bin").glob("as6-diagnose-*")):
    if p.name.endswith(".backup") or ".backup." in p.name or not p.is_file():
        continue
    path = str(p)
    if path in by_path:
        if by_path[path].get("status") not in HISTORICAL:
            by_path[path]["status"] = ACTIVE
        continue
    by_path[path] = {
        "check": p.name.replace("as6-diagnose-", ""),
        "path": path,
        "status": ACTIVE,
        "status_visible": True,
        "source": "auto",
    }

items = sorted(by_path.values(), key=lambda item: (item.get("path", ""), item.get("check", "")))
Path("ops/status").mkdir(parents=True, exist_ok=True)
print(json.dumps({"version": 2, "diagnostics": items}, ensure_ascii=False, indent=2))
PY

mv "$TMP" "$OUT"
echo "DIAGNOSTIC_STATUS_REGISTRY_UPDATED=$OUT"
echo "DIAGNOSTIC_STATUS_REGISTRY_COUNT=$(python3 - <<'PY'
import json
print(len(json.load(open("ops/status/diagnostic-status-registry.json")).get("diagnostics", [])))
PY
)"
echo "DIAGNOSTIC_STATUS_REGISTRY_UPDATE_RESULT=OK"
