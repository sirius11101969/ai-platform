#!/usr/bin/env bash
set -euo pipefail

ROOT="${AS6_REPO_ROOT:-$(git rev-parse --show-toplevel 2>/dev/null || pwd)}"
cd "$ROOT"

fail=0
AS6_DIAGNOSTIC_TIMEOUT_SECONDS="${AS6_DIAGNOSTIC_TIMEOUT_SECONDS:-240}"

echo "=== AS6 Diagnose All ==="


run_check() {
  local name="$1"
  local cmd="$2"

  echo
  echo "=== RUN: ${name} ==="

  if timeout "$AS6_DIAGNOSTIC_TIMEOUT_SECONDS" bash -lc "$cmd"; then
    echo "AS6_DIAGNOSE_ALL_CHECK=OK:${name}"
  else
    echo "AS6_DIAGNOSE_ALL_CHECK=FAIL:${name}"
    fail=1
  fi
}

run_check "backup-integrity" ./ops/bin/as6-diagnose-backup-integrity
run_check "restore-readiness" ./ops/bin/as6-diagnose-restore-readiness
