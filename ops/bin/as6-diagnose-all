#!/usr/bin/env bash
set -euo pipefail

ROOT="${AS6_REPO_ROOT:-$(git rev-parse --show-toplevel 2>/dev/null || pwd)}"
cd "$ROOT"

fail=0

echo "=== AS6 Diagnose All ==="

run_check() {
  local name="$1"
  local cmd="$2"

  echo
  echo "=== RUN: ${name} ==="

  local timeout_seconds="${AS6_DIAGNOSE_ALL_TIMEOUT_SECONDS:-60}"

  if timeout "$timeout_seconds" bash -lc "$cmd"; then
    echo "AS6_DIAGNOSE_ALL_CHECK=OK:${name}"
  else
    local rc="$?"
    if [ "$rc" -eq 124 ]; then
      echo "AS6_DIAGNOSE_ALL_TIMEOUT=FAIL:${name}:${timeout_seconds}s"
    fi
    echo "AS6_DIAGNOSE_ALL_CHECK=FAIL:${name}"
    fail=1
  fi
}

if [ ! -x ops/bin/as6-diagnostic-registry ]; then
  echo "AS6_DIAGNOSE_ALL_REGISTRY=FAIL:missing_or_not_executable"
  echo "AS6_DIAGNOSE_ALL_RESULT=FAIL"
  exit 1
fi

echo "AS6_DIAGNOSE_ALL_REGISTRY=OK"

while read -r diag; do
  case "$diag" in
    ops/bin/as6-diagnose-all)
      echo "AS6_DIAGNOSE_ALL_SKIP=OK:self"
      continue
      ;;
    ops/bin/as6-diagnose-diagnostic-flow)
      echo "AS6_DIAGNOSE_ALL_SKIP=OK:diagnostic-flow_prevents_recursion"
      continue
      ;;
    ops/bin/as6-diagnose-diagnostic-coverage)
      echo "AS6_DIAGNOSE_ALL_SKIP=OK:diagnostic-coverage_prevents_recursion"
      continue
      ;;
    ops/bin/as6-diagnose-health-dashboard-integration|ops/bin/as6-diagnose-health-timer-dashboard|ops/bin/as6-diagnose-command-center)
      echo "AS6_DIAGNOSE_ALL_SKIP=OK:heavy_dashboard_check_prevents_nested_diagnose_all:$diag"
      continue
      ;;
  esac

  name="${diag#ops/bin/as6-diagnose-}"
  run_check "$name" "./$diag"
done < <(
  ./ops/bin/as6-diagnostic-registry \
    | awk -F= '/^DIAGNOSTIC_REGISTRY_ENTRY=OK:/ {print $2}' \
    | sed 's#^OK:##' \
    | sort
)

run_check "ai-workforce-status" "./ops/bin/as6-ai-workforce-status"

echo
if [ "$fail" -eq 0 ]; then
  echo "AS6_DIAGNOSE_ALL_RESULT=OK"
  exit 0
fi

echo "AS6_DIAGNOSE_ALL_RESULT=FAIL"
exit 1
