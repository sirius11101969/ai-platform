#!/usr/bin/env bash
set -euo pipefail

ROOT="${AS6_REPO_ROOT:-$(git rev-parse --show-toplevel 2>/dev/null || pwd)}"
cd "$ROOT"

fail=0
AS6_DIAGNOSTIC_TIMEOUT_SECONDS="${AS6_DIAGNOSTIC_TIMEOUT_SECONDS:-240}"

echo "=== AS6 Diagnose All ==="


run_check() {
  local name="$1"
  local cmd="$2"

  echo
  echo "=== RUN: ${name} ==="

  if timeout "$AS6_DIAGNOSTIC_TIMEOUT_SECONDS" bash -lc "$cmd"; then
    echo "AS6_DIAGNOSE_ALL_CHECK=OK:${name}"
  else
    echo "AS6_DIAGNOSE_ALL_CHECK=FAIL:${name}"
    fail=1
  fi
}

run_check "backup-integrity" ./ops/bin/as6-diagnose-backup-integrity
run_check "restore-readiness" ./ops/bin/as6-diagnose-restore-readiness
run_check "disaster-recovery" ./ops/bin/as6-diagnose-disaster-recovery
echo "AS6_DIAGNOSE_ALL_CHECK=SKIP:restore-drill:emergency_safe_mode"
run_check "backup-governance" ./ops/bin/as6-diagnose-backup-governance
echo "AS6_DIAGNOSE_ALL_CHECK=SKIP:restore-drill-history:emergency_safe_mode"
run_check "diagnostic-insertion-points" ./ops/bin/as6-diagnose-diagnostic-insertion-points
run_check "function-order" ./ops/bin/as6-diagnose-function-order
echo "AS6_DIAGNOSE_ALL_CHECK=SKIP:diagnostic-governance:emergency_safe_mode"
run_check "diagnostic-timeout-governance" ./ops/bin/as6-diagnose-diagnostic-timeout-governance


run_check "git-main-sync" "./ops/bin/as6-diagnose-git-main-sync"
run_check "diagnostic-coverage" "./ops/bin/as6-diagnose-diagnostic-coverage"
run_check "constitution" ./ops/bin/as6-diagnose-constitution
run_check "heredoc-safety" ./ops/bin/as6-diagnose-heredoc-safety
run_check "patch-structure" ./ops/bin/as6-diagnose-patch-structure
run_check "git-hygiene" ./ops/bin/as6-diagnose-git-hygiene
run_check "output-format" ./ops/bin/as6-diagnose-output-format
run_check "diagnostic-status-registry" "./ops/bin/as6-diagnose-diagnostic-status-registry"
run_check "diagnostic-flow" "./ops/bin/as6-diagnose-diagnostic-flow"
run_check "workflow-yaml" "./ops/bin/as6-diagnose-workflow-yaml"
run_check "actions-node24" "./ops/bin/as6-diagnose-actions-node24"
run_check "actions-node24-migration" "./ops/bin/as6-diagnose-actions-node24-migration"
run_check "agent-branch-writer" "./ops/bin/as6-diagnose-agent-branch-writer"
run_check "agent-branch-writer-e2e" "./ops/bin/as6-diagnose-agent-branch-writer-e2e"
run_check "agent-pr-factory-e2e" "./ops/bin/as6-diagnose-agent-pr-factory-e2e"
run_check "controlled-branch-writer" "./ops/bin/as6-diagnose-controlled-branch-writer"
run_check "controlled-write-mode" "./ops/bin/as6-diagnose-controlled-write-mode"
run_check "issue-router" "./ops/bin/as6-diagnose-issue-router"
run_check "pr-factory" "./ops/bin/as6-diagnose-pr-factory"
run_check "codex-workflow" "./ops/bin/as6-diagnose-codex-workflow"
run_check "ai-workforce-status" "./ops/bin/as6-ai-workforce-status"
run_check "health-history-corruption" "./ops/bin/as6-diagnose-health-history-corruption"
run_check "health-history-anomaly" "./ops/bin/as6-diagnose-health-history-anomaly"
run_check "health-history-recovery-window" "./ops/bin/as6-diagnose-health-history-recovery-window"
run_check "health-recovery" "./ops/bin/as6-diagnose-health-recovery"
run_check "host-freeze-history" "./ops/bin/as6-diagnose-host-freeze-history"
run_check "historical-incident-suppressor" "./ops/bin/as6-diagnose-historical-incident-suppressor"
run_check "historical-incident-archive" "./ops/bin/as6-diagnose-historical-incident-archive"
run_check "historical-gap-aging" "./ops/bin/as6-diagnose-historical-gap-aging"
run_check "historical-incident-canonicalization" "./ops/bin/as6-diagnose-historical-incident-canonicalization"
run_check "historical-incident-api" "./ops/bin/as6-diagnose-historical-incident-api"
run_check "raw-fail-consumers" "./ops/bin/as6-diagnose-raw-fail-consumers"
run_check "historical-incident-autoclose" "./ops/bin/as6-diagnose-historical-incident-autoclose"
run_check "freeze-correlation" "./ops/bin/as6-diagnose-freeze-correlation"
echo "AS6_DIAGNOSE_ALL_CHECK=SKIP:root-cause-v3:emergency_safe_mode"
run_check "root-cause-staleness" "./ops/bin/as6-diagnose-root-cause-staleness"
run_check "root-cause-canonicalization" "./ops/bin/as6-diagnose-root-cause-canonicalization"
run_check "root-cause-token-policy" "./ops/bin/as6-diagnose-root-cause-token-policy"
run_check "runtime-binary-artifacts" "./ops/bin/as6-diagnose-runtime-binary-artifacts"
run_check "status-registry-consistency" "./ops/bin/as6-diagnose-status-registry-consistency"
run_check "runtime-artifact-format" "./ops/bin/as6-diagnose-runtime-artifact-format"
run_check "runtime-stale-tmp-artifacts" "./ops/bin/as6-diagnose-runtime-stale-tmp-artifacts"
run_check "unreachable-diagnostic-blocks" "./ops/bin/as6-diagnose-unreachable-diagnostic-blocks"
# AS6 health/root-cause automation checks
run_check "health-cache-timer-freshness" "./ops/bin/as6-diagnose-health-cache-timer-freshness"
run_check "automation-sources" ./ops/bin/as6-diagnose-automation-sources
run_check "ops-agent" ./ops/bin/as6-diagnose-ops-agent
run_check "host-freeze-network" ./ops/bin/as6-diagnose-host-freeze-network
run_check "hypervisor-reboot" ./ops/bin/as6-diagnose-hypervisor-reboot
run_check "provider-hypervisor-reboot" ./ops/bin/as6-diagnose-provider-hypervisor-reboot
run_check "reboot-origin" ./ops/bin/as6-diagnose-reboot-origin
run_check "reboot-forensics" "AS6_REBOOT_FORENSICS_LIGHTWEIGHT=1 ./ops/bin/as6-diagnose-reboot-forensics"
run_check "provider-event-correlation" ./ops/bin/as6-diagnose-provider-event-correlation
run_check "reboot-evidence-cache" ./ops/bin/as6-diagnose-reboot-evidence-cache
run_check "reboot-evidence-symbols" ./ops/bin/as6-diagnose-reboot-evidence-symbols
run_check "reboot-evidence-self-heal" ./ops/bin/as6-diagnose-reboot-evidence-self-heal
run_check "pre-reboot-forensics" ./ops/bin/as6-diagnose-pre-reboot-forensics
run_check "health-anomaly-root-cause" "./ops/bin/as6-diagnose-health-anomaly-root-cause"
run_check "root-cause-v3-refresh-cache" "./ops/bin/as6-root-cause-v3-refresh-cache"
run_check "health-history-gap-suppression" "./ops/bin/as6-diagnose-health-history-gap-suppression"
run_check "historical-only" "./ops/bin/as6-diagnose-health-history-historical-only"
run_check "strategic-readiness" "./ops/bin/as6-diagnose-strategic-readiness"


echo
if [ "$fail" -eq 0 ]; then


  echo "AS6_DIAGNOSE_ALL_RESULT=OK"
  exit 0
fi


echo "AS6_DIAGNOSE_ALL_RESULT=FAIL"
exit 1




