#!/usr/bin/env bash
set -euo pipefail

ROOT="${AS6_REPO_ROOT:-$(git rev-parse --show-toplevel 2>/dev/null || pwd)}"
cd "$ROOT"

mkdir -p runtime/health/history

NOW="$(date -u +"%Y-%m-%dT%H:%M:%SZ")"
SHA="$(git rev-parse --short HEAD 2>/dev/null || echo unknown)"

WORKFORCE_OUT="/tmp/as6-health-cache-workforce.out"
TIMER_OUT="/tmp/as6-health-cache-timer-runtime.out"
CLEANUP_OUT="/tmp/as6-health-cache-cleanup.out"

echo "=== AS6 Health Cache ==="
echo "HEALTH_CACHE_MODE=lightweight_snapshot"

if ./ops/bin/as6-ai-workforce-status >"$WORKFORCE_OUT" 2>&1; then
  workforce="OK"
else
  workforce="FAIL"
fi

if ./ops/bin/as6-diagnose-health-timer-runtime >"$TIMER_OUT" 2>&1; then
  timer_runtime="OK"
else
  timer_runtime="FAIL"
fi

if ./ops/bin/as6-diagnose-health-cleanup >"$CLEANUP_OUT" 2>&1; then
  cleanup="OK"
else
  cleanup="FAIL"
fi

if [ "$workforce" = "OK" ] && [ "$timer_runtime" = "OK" ] && [ "$cleanup" = "OK" ]; then
  RESULT="OK"
  platform="OK"
  owner="OK"
  root_cause="none"
  next_action="continue"
  next_command="./ops/bin/as6-health-status"
else
  RESULT="FAIL"
  platform="FAIL"
  owner="FAIL"
  root_cause="workforce=${workforce};timer_runtime=${timer_runtime};cleanup=${cleanup}"
  next_action="inspect_failed_lightweight_health_checks"
  next_command="./ops/bin/as6-diagnose-all"
fi

python3 - <<PY
import json
from pathlib import Path

data = {
    "timestamp": "$NOW",
    "git_sha": "$SHA",
    "health_cache_result": "$RESULT",
    "health_cache_mode": "lightweight_snapshot",
    "platform_status": "$platform",
    "owner_dashboard": "$owner",
    "workforce_status": "$workforce",
    "health_timer_runtime": "$timer_runtime",
    "health_cleanup": "$cleanup",
    "root_cause": "$root_cause",
    "next_action": "$next_action",
    "next_command": "$next_command",
}

latest = Path("runtime/health/latest.json")
history = Path("runtime/health/history") / f"{data['timestamp'].replace(':', '-')}-{data['git_sha']}.json"

latest.write_text(json.dumps(data, ensure_ascii=False, indent=2) + "\\n")
history.write_text(json.dumps(data, ensure_ascii=False, indent=2) + "\\n")

print("HEALTH_CACHE_LATEST=runtime/health/latest.json")
print(f"HEALTH_CACHE_HISTORY={history}")
print(f"HEALTH_CACHE_MODE={data['health_cache_mode']}")
print(f"HEALTH_CACHE_RESULT={data['health_cache_result']}")
PY

if [ "$RESULT" = "OK" ]; then
  echo "AS6_HEALTH_CACHE_RESULT=OK"
  exit 0
fi

echo "AS6_HEALTH_CACHE_RESULT=FAIL"
exit 1
