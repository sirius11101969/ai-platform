#!/usr/bin/env bash
set -euo pipefail

ROOT="${AS6_REPO_ROOT:-$(git rev-parse --show-toplevel 2>/dev/null || pwd)}"
cd "$ROOT"

mkdir -p runtime/health/history

OUT="/tmp/as6-health-cache-platform-command-center.out"
NOW="$(date -u +"%Y-%m-%dT%H:%M:%SZ")"
SHA="$(git rev-parse --short HEAD 2>/dev/null || echo unknown)"

echo "=== AS6 Health Cache ==="

if ./ops/bin/as6-owner-dashboard-root-cause-v3 >"$OUT" 2>&1; then
  RESULT="OK"
else
  RESULT="FAIL"
fi

get_last_value() {
  local pattern="$1"
  grep -E "$pattern" "$OUT" | tail -1 | cut -d= -f2- || true
}

platform="$(get_last_value '^(PLATFORM_COMMAND_CENTER_STATUS|OWNER_DASHBOARD_PLATFORM_STATUS|PROJECT_HEALTH_STATUS|ROOT_CAUSE_V3_RESULT|ROOT_CAUSE_V3_OVERALL_STATUS)=')"
owner="$(get_last_value '^(PLATFORM_COMMAND_CENTER_OWNER_DASHBOARD|OWNER_DASHBOARD_STATUS|OWNER_DASHBOARD_RESULT|AS6_OWNER_DASHBOARD_RESULT)=')"
workforce="$(get_last_value '^(PLATFORM_COMMAND_CENTER_WORKFORCE|AS6_AI_WORKFORCE_STATUS|WORKFORCE_STATUS)=')"
root_cause="$(get_last_value '^(PLATFORM_COMMAND_CENTER_ROOT_CAUSE|ROOT_CAUSE_V3_ROOT_CAUSE|PROJECT_ROOT_CAUSE|ROOT_CAUSE)=')"
next_action="$(get_last_value '^(PLATFORM_COMMAND_CENTER_NEXT_ACTION|ROOT_CAUSE_V3_RECOMMENDED_ACTION|NEXT_PRIORITY_ACTION|NEXT_ACTION)=')"
next_command="$(get_last_value '^(PLATFORM_COMMAND_CENTER_NEXT_COMMAND|HEALTH_STATUS_NEXT_COMMAND|NEXT_COMMAND)=')"

owner_v3_result="$(get_last_value '^(OWNER_DASHBOARD_ROOT_CAUSE_V3_RESULT)=')"

if [ -z "${platform:-}" ] && [ "${owner_v3_result:-}" = "OK" ]; then
  platform="OK"
fi

if [ -z "${owner:-}" ] && [ "${owner_v3_result:-}" = "OK" ]; then
  owner="OK"
fi

if [ -z "${workforce:-}" ] && [ "${owner_v3_result:-}" = "OK" ]; then
  workforce="OK"
fi

if [ -z "${root_cause:-}" ] && [ "${owner_v3_result:-}" = "OK" ]; then
  root_cause="none"
fi

if [ -z "${next_action:-}" ] && [ "${root_cause:-}" = "none" ]; then
  next_action="none"
fi

python3 - <<PY
import json
from pathlib import Path

data = {
    "timestamp": "$NOW",
    "git_sha": "$SHA",
    "health_cache_result": "$RESULT",
    "platform_status": "${platform:-UNKNOWN}",
    "owner_dashboard": "${owner:-UNKNOWN}",
    "workforce_status": "${workforce:-UNKNOWN}",
    "root_cause": "${root_cause:-unknown}",
    "next_action": "${next_action:-inspect_platform_command_center}",
    "next_command": "${next_command:-./ops/bin/as6-owner-dashboard-root-cause-v3}",
}

latest = Path("runtime/health/latest.json")
history = Path("runtime/health/history") / f"{data['timestamp'].replace(':', '-')}-{data['git_sha']}.json"

latest.write_text(json.dumps(data, ensure_ascii=False, indent=2) + "\\n")
history.write_text(json.dumps(data, ensure_ascii=False, indent=2) + "\\n")

print("HEALTH_CACHE_LATEST=runtime/health/latest.json")
print(f"HEALTH_CACHE_HISTORY={history}")
print(f"HEALTH_CACHE_RESULT={data['health_cache_result']}")
PY

echo "AS6_HEALTH_CACHE_PLATFORM_RESULT=$RESULT"
echo "AS6_HEALTH_CACHE_WRITE_RESULT=OK"
echo "AS6_HEALTH_CACHE_RESULT=OK"
exit 0
