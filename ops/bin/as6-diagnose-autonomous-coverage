#!/usr/bin/env bash
set -uo pipefail
echo "=== AS6 Autonomous Coverage Gate Diagnostics ==="
fail=0
[ -f ops/catalog/failure-classes/autonomous-coverage-gate-linkage-repair.yaml ] && echo "AS6_AUTONOMOUS_COVERAGE_ROOT_CAUSE=PASS" || { echo "AS6_AUTONOMOUS_COVERAGE_ROOT_CAUSE=FAIL"; fail=1; }
[ -f docs/diagnostics/as6-autonomous-coverage-diagnostics.md ] && echo "AS6_AUTONOMOUS_COVERAGE_DIAGNOSTIC=PASS" || { echo "AS6_AUTONOMOUS_COVERAGE_DIAGNOSTIC=FAIL"; fail=1; }
grep -Fq "ops/bin/as6-diagnose-autonomous-coverage" ops/registry/as6-diagnostic-registry.md && echo "AS6_AUTONOMOUS_COVERAGE_REGISTRY=PASS" || { echo "AS6_AUTONOMOUS_COVERAGE_REGISTRY=FAIL"; fail=1; }
grep -Fq "ops/bin/as6-diagnose-autonomous-coverage" ops/registry/as6-coverage-registry.md && echo "AS6_AUTONOMOUS_COVERAGE_COVERAGE=PASS" || { echo "AS6_AUTONOMOUS_COVERAGE_COVERAGE=FAIL"; fail=1; }
grep -Fq "AUTONOMOUS_COVERAGE" ops/registry/as6-prevention-registry.md && echo "AS6_AUTONOMOUS_COVERAGE_PREVENTION=PASS" || { echo "AS6_AUTONOMOUS_COVERAGE_PREVENTION=FAIL"; fail=1; }
[ -f docs/coverage/as6-autonomous-coverage-coverage.md ] && echo "AS6_AUTONOMOUS_COVERAGE_ROLLBACK=PASS" || { echo "AS6_AUTONOMOUS_COVERAGE_ROLLBACK=FAIL"; fail=1; }
[ -f docs/coverage/as6-autonomous-coverage-coverage.md ] && echo "AS6_AUTONOMOUS_COVERAGE_EVIDENCE=PASS" || { echo "AS6_AUTONOMOUS_COVERAGE_EVIDENCE=FAIL"; fail=1; }
grep -Fq "AUTONOMOUS_COVERAGE" ops/registry/as6-aec-registry.md && echo "AS6_AUTONOMOUS_COVERAGE_AEC_RULE=PASS" || { echo "AS6_AUTONOMOUS_COVERAGE_AEC_RULE=FAIL"; fail=1; }
if [ "$fail" -eq 0 ]; then echo "AS6_AUTONOMOUS_COVERAGE_GATE=PASS"; echo "AS6_AUTONOMOUS_COVERAGE_GATE_RESULT=OK"; exit 0; else echo "AS6_AUTONOMOUS_COVERAGE_GATE=FAIL"; echo "AS6_AUTONOMOUS_COVERAGE_GATE_RESULT=FAIL"; exit 1; fi
