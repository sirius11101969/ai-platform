#!/usr/bin/env bash
set -euo pipefail
cd "${AS6_REPO_ROOT:-$(git rev-parse --show-toplevel 2>/dev/null || pwd)}"
echo "=== AS6 Production Deployment Safety Diagnostics ==="
fail=0
test -f backup_v1_stable.sql && echo "AS6_PRODUCTION_DEPLOYMENT_BACKUP=PASS" || { echo "AS6_PRODUCTION_DEPLOYMENT_BACKUP=FAIL"; fail=1; }
test -f docker-compose.yml && echo "AS6_PRODUCTION_DEPLOYMENT_COMPOSE=PASS" || { echo "AS6_PRODUCTION_DEPLOYMENT_COMPOSE=FAIL"; fail=1; }
./ops/bin/as6-diagnose-restore-readiness >/tmp/as6-prod-restore-readiness.out 2>&1 && echo "AS6_PRODUCTION_DEPLOYMENT_ROLLBACK=PASS" || { echo "AS6_PRODUCTION_DEPLOYMENT_ROLLBACK=FAIL"; fail=1; }
./ops/bin/as6-diagnose-env-contract >/tmp/as6-prod-env-contract.out 2>&1 && echo "AS6_PRODUCTION_DEPLOYMENT_VALIDATION=PASS" || { echo "AS6_PRODUCTION_DEPLOYMENT_VALIDATION=FAIL"; fail=1; }
grep -q "AEC_PRODUCTION_DEPLOYMENT_SAFETY=PASS" docs/AS6_AUTONOMOUS_ENGINEERING_CONSTITUTION.md && echo "AS6_PRODUCTION_DEPLOYMENT_AEC_RULE=PASS" || { echo "AS6_PRODUCTION_DEPLOYMENT_AEC_RULE=FAIL"; fail=1; }
if [ "$fail" -eq 0 ]; then echo "AS6_PRODUCTION_DEPLOYMENT_GATE=PASS"; echo "AS6_PRODUCTION_DEPLOYMENT_SAFETY=PASS"; echo "AS6_PRODUCTION_DEPLOYMENT_SAFETY_RESULT=OK"; exit 0; fi
echo "AS6_PRODUCTION_DEPLOYMENT_SAFETY=FAIL"; echo "AS6_PRODUCTION_DEPLOYMENT_SAFETY_RESULT=FAIL"; exit 1
