#!/usr/bin/env bash
set -euo pipefail

ops/bin/as6-diagnose-precommit-secret-hook-v91i
grep -RIn "AS6_PRECOMMIT_SECRET_SCAN_CONTEXT_FALSE_POSITIVE" docs ops >/dev/null || {
