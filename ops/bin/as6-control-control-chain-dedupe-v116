#!/usr/bin/env bash
set -euo pipefail

ops/bin/as6-diagnose-control-chain-dedupe-v116

grep -RIn "AS6_CONTROL_DIRECT_CHAIN_DRIFT" README.md docs ops .github frontend/src >/dev/null || {
  echo "AS6_CONTROL_CONTROL_CHAIN_DEDUPE_V116=FAIL direct_chain_drift_class_missing"
  exit 1
}

echo "AS6_CONTROL_CONTROL_CHAIN_DEDUPE_V116=PASS"
