#!/usr/bin/env bash
set -euo pipefail
echo "=== AS6 Command Center Executive V10 Diagnostics ==="
f="frontend/src/pages/CommandCenterPage.jsx"
css="frontend/src/theme/as6Theme.css"
fail=0
grep -q "quickActionLinks" "$f" && echo "AS6_V10_QUICK_ACTION_ROUTES=PASS" || { echo "AS6_V10_QUICK_ACTION_ROUTES=FAIL"; fail=1; }
grep -q "AS6 Command Center Executive V10" "$css" && echo "AS6_V10_CSS=PASS" || { echo "AS6_V10_CSS=FAIL"; fail=1; }
grep -q "robot-icon.copilot-avatar-v2::after" "$css" && echo "AS6_V10_COPILOT_AVATAR=PASS" || { echo "AS6_V10_COPILOT_AVATAR=FAIL"; fail=1; }
grep -q "as6-sidebar-brand strong" "$css" && echo "AS6_V10_BRAND_LOGO=PASS" || { echo "AS6_V10_BRAND_LOGO=FAIL"; fail=1; }
grep -q "clip-path:polygon(0 0,100% 0,93% 100%,7% 100%)" "$css" && echo "AS6_V10_SYMMETRIC_FUNNEL=PASS" || { echo "AS6_V10_SYMMETRIC_FUNNEL=FAIL"; fail=1; }
if [ "$fail" -eq 0 ]; then echo "AS6_COMMAND_CENTER_EXECUTIVE_V10_RESULT=OK"; exit 0; fi
echo "AS6_COMMAND_CENTER_EXECUTIVE_V10_RESULT=FAIL"; exit 1
