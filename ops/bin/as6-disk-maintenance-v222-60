#!/usr/bin/env bash
set -euo pipefail

BACKUP_DIR="/var/backups/project"
KEEP_BACKUPS="3"
LOG_DIR="/var/log/as6"
LOG_FILE="${LOG_DIR}/disk-maintenance.log"

mkdir -p "$LOG_DIR"

{
  echo "=== AS6 disk maintenance $(date -u +%Y-%m-%dT%H:%M:%SZ) ==="
  echo "--- df before ---"
  df -h /

  if [ -d "$BACKUP_DIR" ]; then
    echo "--- backup rotation: keep latest ${KEEP_BACKUPS} ---"
    cd "$BACKUP_DIR"
    ls -1t ai-platform_*.tar.gz 2>/dev/null | tail -n +"$((KEEP_BACKUPS + 1))" | xargs -r rm -f
    du -sh "$BACKUP_DIR" || true
  fi

  echo "--- docker cleanup safe ---"
  docker container prune -f || true
  docker image prune -af || true
  docker builder prune -af || true

  echo "--- tmp cleanup ---"
  find /tmp -mindepth 1 -maxdepth 1 -mtime +2 -exec rm -rf {} + 2>/dev/null || true

  echo "--- journal cleanup ---"
  journalctl --vacuum-time=14d || true

  echo "--- df after ---"
  df -h /
  echo "AS6_DISK_MAINTENANCE=PASS"
} >> "$LOG_FILE" 2>&1
