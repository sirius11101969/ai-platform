#!/usr/bin/env bash
set -euo pipefail

FAIL=0

for f in \
 docs/AS6_AUTONOMOUS_UI_GOVERNANCE_ENGINE_V113.md \
 docs/AS6_UI_GOVERNANCE_INVENTORY_V113.md
do
  test -f "$f" || FAIL=1
done

grep -q "Autonomous UI Governance Engine" docs/AS6_AUTONOMOUS_UI_GOVERNANCE_ENGINE_V113.md || FAIL=1

for cls in \
 UI_GOVERNANCE_ENGINE_MISSING \
 PAGE_REGISTRY_DRIFT \
 COMPONENT_REGISTRY_DRIFT \
 KPI_REGISTRY_DRIFT \
 TABLE_REGISTRY_DRIFT \
 FORM_REGISTRY_DRIFT \
 STATE_REGISTRY_DRIFT \
 UI_INVENTORY_MISSING \
 UI_AUTONOMY_GAP
do
  grep -Rqs "$cls" docs ops || FAIL=1
done

if [ "$FAIL" -ne 0 ]; then
  echo "AS6_AUTONOMOUS_UI_GOVERNANCE_ENGINE=FAIL"
  exit 1
fi

echo "AS6_AUTONOMOUS_UI_GOVERNANCE_ENGINE=PASS"
