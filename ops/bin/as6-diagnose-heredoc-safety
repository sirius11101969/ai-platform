#!/usr/bin/env bash\nset -euo pipefail\ncd "${AS6_REPO_ROOT:-$(git rev-parse --show-toplevel 2>/dev/null || pwd)}"\necho "=== AS6 Heredoc Safety Diagnostics ==="\nfail=0\nhits="$(grep -RInE "<<[\\'"]?(EOF|END|MD|EOF2)[\\'"]?" .github ops 2>/dev/null | grep -Ev "runtime/diagnostic-backups|runtime/pre-reboot-forensics|runtime/reboot-forensics|ops/bin/as6-diagnose-heredoc-safety" || true)"\necho "AS6_HEREDOC_SCAN_SCOPE=.github,ops"\nif [ -n "$hits" ]; then echo "AS6_HEREDOC_SHORT_MARKER_POLICY=FAIL"; echo "$hits"; fail=1; else echo "AS6_HEREDOC_SHORT_MARKER_POLICY=PASS"; fi\nif grep -q "AS6_HEREDOC_REAL_SCAN=PASS" docs/AS6_AUTONOMOUS_ENGINEERING_CONSTITUTION.md; then echo "AS6_HEREDOC_CONSTITUTION_RULE=PASS"; else echo "AS6_HEREDOC_CONSTITUTION_RULE=FAIL"; fail=1; fi\nif [ "$fail" -eq 0 ]; then echo "AS6_HEREDOC_REAL_SCAN=PASS"; echo "AS6_HEREDOC_SAFETY=PASS"; echo "AS6_HEREDOC_SAFETY_RESULT=OK"; exit 0; fi\necho "AS6_HEREDOC_REAL_SCAN=FAIL"\necho "AS6_HEREDOC_SAFETY=FAIL"\necho "AS6_HEREDOC_SAFETY_RESULT=FAIL"\nexit 1\n