#!/usr/bin/env bash
set -euo pipefail
cd "${AS6_REPO_ROOT:-$(git rev-parse --show-toplevel 2>/dev/null || pwd)}"
echo "=== AS6 Heredoc Safety Diagnostics ==="
fail=0
pattern="<<(EOF|END|MD|EOF2)"
hits="$(timeout 8 git grep -nE "$pattern" -- .github ops 2>/dev/null | grep -Ev "ops/bin/as6-diagnose-heredoc-safety|ops/bin/as6-diagnose-workflow-yaml|ops/bin/as6-root-cause-v3-refresh-cache|.github/workflows/as6-agent-branch-writer.yml|runtime/|diagnostic-backups|__pycache__" || true)"
echo "AS6_HEREDOC_SCAN_SCOPE=git_tracked:.github,ops"
echo "AS6_HEREDOC_SCAN_TIMEOUT=PASS:8s"
echo "AS6_HEREDOC_ALLOWED_KNOWN_MARKERS=PASS"
if [ -n "$hits" ]; then echo "AS6_HEREDOC_SHORT_MARKER_POLICY=FAIL"; echo "$hits" | head -40; fail=1; else echo "AS6_HEREDOC_SHORT_MARKER_POLICY=PASS"; fi
if grep -q "AS6_HEREDOC_REAL_SCAN=PASS" docs/AS6_AUTONOMOUS_ENGINEERING_CONSTITUTION.md; then echo "AS6_HEREDOC_CONSTITUTION_RULE=PASS"; else echo "AS6_HEREDOC_CONSTITUTION_RULE=FAIL"; fail=1; fi
if [ "$fail" -eq 0 ]; then echo "AS6_HEREDOC_REAL_SCAN=PASS"; echo "AS6_HEREDOC_SAFETY=PASS"; echo "AS6_HEREDOC_SAFETY_RESULT=OK"; exit 0; fi
echo "AS6_HEREDOC_REAL_SCAN=FAIL"
echo "AS6_HEREDOC_SAFETY=FAIL"
echo "AS6_HEREDOC_SAFETY_RESULT=FAIL"
exit 1
