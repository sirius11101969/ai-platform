#!/usr/bin/env bash
set -euo pipefail

ops/bin/as6-diagnose-build-once-validation-v117

grep -RIn "AS6_BUILD_ONCE_VALIDATION_DRIFT" README.md docs ops .github frontend/src >/dev/null || {
  echo "AS6_CONTROL_BUILD_ONCE_VALIDATION_V117=FAIL drift_class_missing"
  exit 1
}

echo "AS6_CONTROL_BUILD_ONCE_VALIDATION_V117=PASS"
