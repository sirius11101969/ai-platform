#!/usr/bin/env bash
set -euo pipefail
cd "${AS6_REPO_ROOT:-$(git rev-parse --show-toplevel 2>/dev/null || pwd)}"
echo "=== AS6 Command Length Safety Diagnostics ==="
fail=0
if grep -RIn "base64.b64decode" ops .github 2>/dev/null | grep -Ev "ops/bin/as6-diagnose-command-length-safety|ops/bin/as6-diagnose-patch-mode|ops/lib/as6-generated-python-safety-check.py|ops/governance/|docs/"; then echo "AS6_NO_GIANT_BASE64_PATCH=FAIL"; fail=1; else echo "AS6_NO_GIANT_BASE64_PATCH=PASS"; fi
if grep -q "AS6_COMMAND_LENGTH_SAFETY=PASS" docs/AS6_AUTONOMOUS_ENGINEERING_CONSTITUTION.md; then echo "AS6_COMMAND_LENGTH_RULE=PASS"; else echo "AS6_COMMAND_LENGTH_RULE=FAIL"; fail=1; fi
if [ "$fail" -eq 0 ]; then echo "AS6_COMMAND_LENGTH_SAFETY=PASS"; echo "AS6_COMMAND_LENGTH_SAFETY_RESULT=OK"; exit 0; fi
echo "AS6_COMMAND_LENGTH_SAFETY=FAIL"; echo "AS6_COMMAND_LENGTH_SAFETY_RESULT=FAIL"; exit 1
