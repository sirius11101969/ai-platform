#!/usr/bin/env bash
set -euo pipefail

test -x ops/bin/as6-grep-safe

for f in \
  crmActivitiesWorkspacePanel \
  crmActivitiesWorkspaceNavigation \
  crmActivitiesWorkspaceState \
  crmActivitiesWorkspaceIntegration \
  crmActivitiesWorkspaceTracer \
  crmActivitiesWorkspaceDiagnostics \
  crmActivitiesWorkspaceHealthSnapshot \
  crmActivitiesWorkspaceDescriptor
do
  test -f "frontend/src/crm/activities/workspace/${f}.js"
done

test -f frontend/src/crm/activities/workspace/index.js

ops/bin/as6-grep-safe -R "crm.activities.tasks.workspace.integration" frontend/src/crm/activities/workspace
ops/bin/as6-grep-safe -R "crm.activities.tasks.workspace.panel" frontend/src/crm/activities/workspace
ops/bin/as6-grep-safe -R "crm.activities.tasks.workspace.navigation" frontend/src/crm/activities/workspace
ops/bin/as6-grep-safe -R "crm.activities.tasks.workspace.state" frontend/src/crm/activities/workspace
ops/bin/as6-grep-safe -R "CRM_ACTIVITIES_TASKS_WORKSPACE_TRACE" frontend/src/crm/activities/workspace
ops/bin/as6-grep-safe -R "diagnoseCrmActivitiesWorkspaceIntegration" frontend/src/crm/activities/workspace
ops/bin/as6-grep-safe -R "getCrmActivitiesWorkspaceHealthSnapshot" frontend/src/crm/activities/workspace
ops/bin/as6-grep-safe -R "ActivitiesUiFoundation" frontend/src/crm/activities/workspace
ops/bin/as6-grep-safe -R "useExistingCrmWorkspace: true" frontend/src/crm/activities/workspace
ops/bin/as6-grep-safe -R "useExistingCrmLayout: true" frontend/src/crm/activities/workspace
ops/bin/as6-grep-safe -R "noParallelShell: true" frontend/src/crm/activities/workspace
ops/bin/as6-grep-safe -R "noParallelLayout: true" frontend/src/crm/activities/workspace
ops/bin/as6-grep-safe -R "ownRouter: false" frontend/src/crm/activities/workspace
ops/bin/as6-grep-safe -R "ownStore: false" frontend/src/crm/activities/workspace
ops/bin/as6-grep-safe -R "storageEnabled: false" frontend/src/crm/activities/workspace
ops/bin/as6-grep-safe -R "apiEnabled: false" frontend/src/crm/activities/workspace
ops/bin/as6-grep-safe -R "workflowEnabled: false" frontend/src/crm/activities/workspace
ops/bin/as6-grep-safe -R "platformMutation: false" frontend/src/crm/activities/workspace

echo "AS6_EPIC015_CRM_ACTIVITIES_TASKS_WORKSPACE_INTEGRATION=PASS"
