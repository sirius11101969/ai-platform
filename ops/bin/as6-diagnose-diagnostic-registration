#!/usr/bin/env bash
set -uo pipefail
ROOT="${AS6_REPO_ROOT:-$(git rev-parse --show-toplevel 2>/dev/null || pwd)}"
cd "$ROOT"
echo "=== AS6 Diagnostic Registration Governance Diagnostics ==="
if [ -x ops/lib/as6-diagnostic-registration-check.py ]; then
  echo "AS6_DIAGNOSTIC_REGISTRATION_HELPER=PASS:ops/lib/as6-diagnostic-registration-check.py"
  exec python3 ops/lib/as6-diagnostic-registration-check.py
fi
echo "AS6_DIAGNOSTIC_REGISTRATION_HELPER=FAIL:ops/lib/as6-diagnostic-registration-check.py"
echo "AS6_DIAGNOSTIC_REGISTRATION_RESULT=FAIL"
exit 1
