#!/usr/bin/env bash
set -euo pipefail

test -x ops/bin/as6-grep-safe

for f in \
  crmActivitiesProductionContract \
  crmActivitiesProductionTracer \
  crmActivitiesProductionDiagnostics \
  crmActivitiesProductionHealthSnapshot \
  crmActivitiesProductionDescriptor
do
  test -f "frontend/src/crm/activities/production/${f}.js"
done

test -f frontend/src/crm/activities/production/crmActivitiesProductionPolish.css
test -f frontend/src/crm/activities/production/index.js

ops/bin/as6-grep-safe -R "crm.activities.tasks.production.contract" frontend/src/crm/activities/production
ops/bin/as6-grep-safe -R "CRM_ACTIVITIES_TASKS_PRODUCTION_TRACE" frontend/src/crm/activities/production
ops/bin/as6-grep-safe -R "diagnoseCrmActivitiesProductionPolish" frontend/src/crm/activities/production
ops/bin/as6-grep-safe -R "getCrmActivitiesProductionHealthSnapshot" frontend/src/crm/activities/production
ops/bin/as6-grep-safe -R "productionReady: true" frontend/src/crm/activities/production
ops/bin/as6-grep-safe -R "aria: true" frontend/src/crm/activities/production
ops/bin/as6-grep-safe -R "liveRegions: true" frontend/src/crm/activities/production
ops/bin/as6-grep-safe -R "visibleFocus: true" frontend/src/crm/activities/production
ops/bin/as6-grep-safe -R "semanticSections: true" frontend/src/crm/activities/production
ops/bin/as6-grep-safe -R "prefersReducedMotion: true" frontend/src/crm/activities/production
ops/bin/as6-grep-safe -R "heavyDependencies: false" frontend/src/crm/activities/production
ops/bin/as6-grep-safe -R "runtimeFetch: false" frontend/src/crm/activities/production
ops/bin/as6-grep-safe -R "runtimeStorage: false" frontend/src/crm/activities/production
ops/bin/as6-grep-safe -R "businessWorkflow: false" frontend/src/crm/activities/production
ops/bin/as6-grep-safe -R "contain: layout paint" frontend/src/crm/activities/production
ops/bin/as6-grep-safe -R "focus-visible" frontend/src/crm/activities/production
ops/bin/as6-grep-safe -R "prefers-reduced-motion" frontend/src/crm/activities/production
ops/bin/as6-grep-safe -R "USE_EXISTING_CRM_LAYOUT: true" frontend/src/crm/activities/production
ops/bin/as6-grep-safe -R "USE_EXISTING_CRM_WORKSPACE: true" frontend/src/crm/activities/production
ops/bin/as6-grep-safe -R "USE_EXISTING_HEADER: true" frontend/src/crm/activities/production
ops/bin/as6-grep-safe -R "USE_EXISTING_SIDEBAR: true" frontend/src/crm/activities/production
ops/bin/as6-grep-safe -R "NO_PARALLEL_LAYOUT: true" frontend/src/crm/activities/production
ops/bin/as6-grep-safe -R "NO_PARALLEL_SHELL: true" frontend/src/crm/activities/production
ops/bin/as6-grep-safe -R "NO_OWN_ROUTER: true" frontend/src/crm/activities/production
ops/bin/as6-grep-safe -R "NO_OWN_STORE: true" frontend/src/crm/activities/production
ops/bin/as6-grep-safe -R "NO_STORAGE: true" frontend/src/crm/activities/production
ops/bin/as6-grep-safe -R "NO_API_CALLS: true" frontend/src/crm/activities/production
ops/bin/as6-grep-safe -R "PLATFORM_MUTATION: false" frontend/src/crm/activities/production

echo "AS6_EPIC015_CRM_ACTIVITIES_TASKS_PRODUCTION_POLISH=PASS"
