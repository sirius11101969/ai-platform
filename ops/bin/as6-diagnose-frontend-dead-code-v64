#!/usr/bin/env bash
set -euo pipefail

OUT_DIR="${1:-runtime/as6-frontend-dead-code-v64}"
BUILD_LOG="${2:-}"
ASSET_LIST="${3:-}"
mkdir -p "$OUT_DIR"
fail=0

check(){ n="$1"; shift; if "$@"; then echo "PASS:$n"; else echo "FAIL:$n"; fail=1; fi; }

check frontend_src_exists test -d frontend/src
check app_exists test -f frontend/src/App.jsx
check vite_exists test -f frontend/vite.config.js
check pages_dir_exists test -d frontend/src/pages
check components_dir_exists test -d frontend/src/components
check lazy_suspense_import grep -q "lazy, Suspense" frontend/src/App.jsx
check duplicate_top_logo_absent bash -c '! grep -q as6-command-center-logo-image frontend/src/pages/CommandCenterPage.jsx'
check sidebar_branding_webp grep -q "as6-logo.webp" frontend/src/components/branding/AS6Logo.jsx

find frontend/src -type f \( -name "*.jsx" -o -name "*.js" -o -name "*.css" \) -printf "%s %p\n" | sort -nr | head -40 | tee "$OUT_DIR/top40-source-files.out"

find frontend/src/pages -maxdepth 1 -type f -name "*.jsx" | sort > "$OUT_DIR/pages.files"
sed 's#^frontend/src/pages/##; s#\.jsx$##' "$OUT_DIR/pages.files" | sort > "$OUT_DIR/pages.names"

grep -RohE 'import\("./pages/[A-Za-z0-9_/-]+"\)|from "\./pages/[A-Za-z0-9_/-]+"' frontend/src/App.jsx frontend/src 2>/dev/null \
  | sed -E 's#.*\./pages/([^"]+)".*#\1#; s#\.jsx$##' \
  | sort -u > "$OUT_DIR/pages.imported.names"

comm -23 "$OUT_DIR/pages.names" "$OUT_DIR/pages.imported.names" > "$OUT_DIR/pages.unused.probable"

find frontend/src/components -type f \( -name "*.jsx" -o -name "*.js" \) | sort > "$OUT_DIR/components.files"
sed 's#^frontend/src/components/##; s#\.[jt]sx\?$##' "$OUT_DIR/components.files" | sort > "$OUT_DIR/components.names"

grep -RohE 'from "\./components/[A-Za-z0-9_./-]+"|from "\../components/[A-Za-z0-9_./-]+"|from "\../../components/[A-Za-z0-9_./-]+"' frontend/src 2>/dev/null \
  | sed -E 's#.*components/([^"]+)".*#\1#; s#\.[jt]sx?$##' \
  | sort -u > "$OUT_DIR/components.imported.names" || true

comm -23 "$OUT_DIR/components.names" "$OUT_DIR/components.imported.names" > "$OUT_DIR/components.unused.probable" || true

grep -RhoE '\.[A-Za-z_-][A-Za-z0-9_-]+' frontend/src/styles.css frontend/src/theme/as6Theme.css 2>/dev/null | sed 's/^\.//' | sort -u > "$OUT_DIR/css-selectors.all"
grep -RohE 'className=("|\047|`)[^"\047`]+("|\047|`)' frontend/src 2>/dev/null | sed -E 's/^className=("|\047|`)//; s/("|\047|`)$//' | tr ' ' '\n' | sed '/^$/d' | sed 's/[^A-Za-z0-9_-].*$//' | grep -E '^[A-Za-z_-][A-Za-z0-9_-]*$' | sort -u > "$OUT_DIR/jsx-class-tokens.static" || true
comm -23 "$OUT_DIR/css-selectors.all" "$OUT_DIR/jsx-class-tokens.static" > "$OUT_DIR/css-selectors.unused.probable" || true

grep -n "AS6 Command Center .*V[0-9]\|Command Center .*V[0-9]\|Pixel Perfect\|Pixel Polish\|Final Pixel\|Visual Fix\|Screenshot Match" frontend/src/theme/as6Theme.css frontend/src/styles.css 2>/dev/null | tee "$OUT_DIR/legacy-command-center-css-blocks.out" || true

page_count="$(wc -l < "$OUT_DIR/pages.names" | tr -d ' ')"
unused_page_count="$(wc -l < "$OUT_DIR/pages.unused.probable" | tr -d ' ')"
component_count="$(wc -l < "$OUT_DIR/components.names" | tr -d ' ')"
unused_component_count="$(wc -l < "$OUT_DIR/components.unused.probable" | tr -d ' ')"
css_selector_count="$(wc -l < "$OUT_DIR/css-selectors.all" | tr -d ' ')"
unused_css_selector_count="$(wc -l < "$OUT_DIR/css-selectors.unused.probable" | tr -d ' ')"
legacy_css_count="$(wc -l < "$OUT_DIR/legacy-command-center-css-blocks.out" | tr -d ' ')"

echo "FRONTEND_PAGE_COUNT=$page_count"
echo "FRONTEND_UNUSED_PAGE_PROBABLE_COUNT=$unused_page_count"
echo "FRONTEND_COMPONENT_COUNT=$component_count"
echo "FRONTEND_UNUSED_COMPONENT_PROBABLE_COUNT=$unused_component_count"
echo "CSS_SELECTOR_COUNT=$css_selector_count"
echo "CSS_UNUSED_SELECTOR_PROBABLE_COUNT=$unused_css_selector_count"
echo "LEGACY_COMMAND_CENTER_CSS_BLOCK_COUNT=$legacy_css_count"

head -30 "$OUT_DIR/pages.unused.probable" | tee "$OUT_DIR/top30-unused-pages.probable.out"
head -30 "$OUT_DIR/components.unused.probable" | tee "$OUT_DIR/top30-unused-components.probable.out"
head -50 "$OUT_DIR/css-selectors.unused.probable" | tee "$OUT_DIR/top50-unused-css-selectors.probable.out"

if test "$unused_page_count" -lt 80; then echo "PASS:unused_page_inventory_budget"; else echo "FAIL:unused_page_inventory_budget"; fail=1; fi
if test "$unused_component_count" -lt 200; then echo "PASS:unused_component_inventory_budget"; else echo "FAIL:unused_component_inventory_budget"; fail=1; fi
if test "$legacy_css_count" -lt 80; then echo "PASS:legacy_css_inventory_budget"; else echo "FAIL:legacy_css_inventory_budget"; fail=1; fi

if test -n "$BUILD_LOG" && test -f "$BUILD_LOG"; then
  if grep -q 'css-syntax-error\|Expected identifier but found\|Unexpected "}"\|lazy is not defined\|Suspense is not defined' "$BUILD_LOG"; then
    echo "FAIL:frontend_build_clean"
    fail=1
  else
    echo "PASS:frontend_build_clean"
  fi
fi

if test -n "$ASSET_LIST" && test -f "$ASSET_LIST"; then
  check crm_chunk_present grep -q "crm-page-" "$ASSET_LIST"
  check dashboard_chunk_present grep -q "dashboard-page-" "$ASSET_LIST"
  check command_center_chunk_present grep -q "command-center-" "$ASSET_LIST"
fi

exit "$fail"
