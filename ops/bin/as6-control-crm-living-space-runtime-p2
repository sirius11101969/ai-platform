#!/usr/bin/env bash
set -euo pipefail

ops/bin/as6-diagnose-crm-living-space-runtime-p2

grep -RIn "AS6_CRM_LIVING_SPACE_RUNTIME_DRIFT" README.md docs ops .github frontend/src >/dev/null || {
