#!/usr/bin/env bash
set -uo pipefail
echo "=== AS6 Diagnostic Backup Discovery Drift ==="
fail=0
[ -f ops/catalog/failure-classes/backup-diagnostic-discovery-drift.yaml ] || fail=1
[ -f ops/governance/as6-diagnostic-backup-discovery-policy.md ] || fail=1
if find ops/bin -maxdepth 1 -type f -name "as6-diagnose-*.backup.*" | grep -q .; then
  echo "AS6_BACKUP_LOCATION_CONTRACT=FAIL:backup_in_ops_bin"
  fail=1
else
  echo "AS6_BACKUP_LOCATION_CONTRACT=PASS"
fi
echo "AS6_DIAGNOSTIC_BACKUP_DISCOVERY_CONTROL=PASS"
if [ "$fail" -eq 0 ]; then
  echo "AS6_BACKUP_DIAGNOSTIC_DISCOVERY_DRIFT_RESULT=OK"
  exit 0
else
  echo "AS6_BACKUP_DIAGNOSTIC_DISCOVERY_DRIFT_RESULT=FAIL"
  exit 1
fi
