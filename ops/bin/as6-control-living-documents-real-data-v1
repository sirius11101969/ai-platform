#!/usr/bin/env bash
set -Eeuo pipefail
ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
APP="$ROOT/frontend/src/living/product-v2/LivingCanonicalApp.jsx"
DATA="$ROOT/frontend/src/living/product-v2/livingReadOnlyData.js"
DOCS="$ROOT/frontend/src/living/product-v2/LivingDocumentsSpace.jsx"
API="$ROOT/frontend/src/services/api.js"
test -f "$APP"
test -f "$DATA"
test -f "$DOCS"
test -f "$API"
test ! -e "$ROOT/frontend/src/living/product-v2/LivingShellV2.jsx"
grep -Fq "LivingDocumentsSpace" "$APP"
grep -Fq "activeId === \"documents\"" "$APP"
grep -Fq "LivingSpaceEngine" "$DOCS"
grep -Fq "fetchEmailAttachments()" "$DATA"
grep -Fq "readOnly: true" "$DATA"
grep -Fq "downloadUrl:" "$DATA"
grep -Fq "getActiveWorkspaceId" "$API"
grep -Fq "workspaceId" "$API"
MUTATIONS="$(grep -Eoc 'method:[[:space:]]*(POST|PUT|PATCH|DELETE)' "$DOCS" || true)"
test "$MUTATIONS" = "0"
echo "AS6_DOCUMENT_SPACE_REAL_DATA=PASS"
echo "AS6_DOCUMENT_SPACE_READ_ONLY=PASS"
echo "AS6_DOCUMENT_SPACE_WORKSPACE_ISOLATION=PASS"
echo "AS6_DOCUMENT_CANONICAL_RUNTIME_OWNER=PASS"
echo "AS6_DOCUMENT_SEMANTIC_CONTROL=PASS"
echo "AS6_LIVING_DOCUMENTS_REAL_DATA_CONTROL=PASS"
