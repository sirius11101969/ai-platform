#!/usr/bin/env bash
set -euo pipefail

test -x .git/hooks/pre-commit || { echo "AS6_PRECOMMIT_HARD_SECRET_SCAN_V91J=FAIL hook_missing"; exit 1; }
grep -q 'git diff --cached -U0' .git/hooks/pre-commit || { echo "AS6_PRECOMMIT_HARD_SECRET_SCAN_V91J=FAIL zero_context_missing"; exit 1; }
grep -q 'AuthContext = createContext({ token:' .git/hooks/pre-commit || { echo "AS6_PRECOMMIT_HARD_SECRET_SCAN_V91J=FAIL safe_authcontext_filter_missing"; exit 1; }
grep -q 'localStorage.getItem("as6-token")' .git/hooks/pre-commit || { echo "AS6_PRECOMMIT_HARD_SECRET_SCAN_V91J=FAIL safe_as6_token_filter_missing"; exit 1; }

echo "AS6_PRECOMMIT_HARD_SECRET_SCAN_REPAIR_V91J=PASS"
