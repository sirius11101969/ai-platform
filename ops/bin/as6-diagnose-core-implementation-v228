#!/usr/bin/env bash
set -euo pipefail
test -f frontend/src/components/as6-workspace/AS6Core.jsx
test -f frontend/src/styles/as6-core-v228.css
grep -q "export function AS6CoreShell" frontend/src/components/as6-workspace/AS6Core.jsx
grep -q "export function AS6CoreMark" frontend/src/components/as6-workspace/AS6Core.jsx
grep -q "export function AS6CorePromise" frontend/src/components/as6-workspace/AS6Core.jsx
grep -q "export function AS6CoreAction" frontend/src/components/as6-workspace/AS6Core.jsx
grep -q "export function AS6CoreSignal" frontend/src/components/as6-workspace/AS6Core.jsx
grep -q "AS6_CORE_PROMISE" frontend/src/components/as6-workspace/AS6Core.jsx
grep -q "AS6_CORE_ACTION" frontend/src/components/as6-workspace/AS6Core.jsx
grep -q "AS6CoreShell" frontend/src/components/as6-workspace/AS6Workspace.jsx
grep -q "data-as6-core" frontend/src/components/as6-workspace/AS6Core.jsx
grep -q "as6-core-v228.css" frontend/src/App.jsx
printf '%s\n' 'AS6_CORE_IMPLEMENTATION_V228=PASS'
