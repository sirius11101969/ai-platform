#!/usr/bin/env bash
set -uo pipefail
echo "=== AS6 Runtime Stage Gap Final Marker Contract ==="
fail=0
[ -f ops/catalog/failure-classes/runtime-stage-gap-diagnostic-premature-exit.yaml ] || fail=1
[ -f ops/governance/as6-diagnostic-final-result-marker-contract.md ] || fail=1
out="$(mktemp)"
if ops/bin/as6-diagnose-runtime-stage-gap >"$out" 2>&1; then
  if grep -Fq "AS6_RUNTIME_STAGE_GAP_RESULT=OK" "$out"; then
    echo "AS6_RUNTIME_STAGE_GAP_FINAL_MARKER_CONTROL=PASS"
  else
    cat "$out"
    echo "AS6_RUNTIME_STAGE_GAP_FINAL_MARKER_CONTROL=FAIL:missing_ok_marker"
    fail=1
  fi
else
  cat "$out"
  if grep -Fq "AS6_RUNTIME_STAGE_GAP_RESULT=FAIL" "$out"; then
    echo "AS6_RUNTIME_STAGE_GAP_FINAL_MARKER_CONTROL=PASS:fail_marker_present"
  else
    echo "AS6_RUNTIME_STAGE_GAP_FINAL_MARKER_CONTROL=FAIL:missing_fail_marker"
    fail=1
  fi
fi
rm -f "$out"
if [ "$fail" -eq 0 ]; then
  echo "AS6_FINAL_RESULT_MARKER_CONTRACT=PASS"
  echo "AS6_RUNTIME_STAGE_GAP_FINAL_MARKER_RESULT=OK"
  exit 0
else
  echo "AS6_FINAL_RESULT_MARKER_CONTRACT=FAIL"
  echo "AS6_RUNTIME_STAGE_GAP_FINAL_MARKER_RESULT=FAIL"
  exit 1
fi
