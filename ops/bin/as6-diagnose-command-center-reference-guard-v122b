#!/usr/bin/env bash
set -euo pipefail
FAIL=0
test -f frontend/src/pages/CommandCenterPage.jsx || FAIL=1
test -f frontend/src/as6-command-center-reference-guard.js || FAIL=1
test -f frontend/src/styles/as6-command-center-reference-guard.css || FAIL=1
grep -Rqs "as6-command-center-reference-guard.js" frontend/src/main.jsx || FAIL=1
grep -Rqs "as6-global-health-bar-root" frontend/src/as6-command-center-reference-guard.js || FAIL=1
grep -Rqs "as6-mission-control-layout-engine-root" frontend/src/as6-command-center-reference-guard.js || FAIL=1
grep -Rqs "as6-ai-copilot-rail-root" frontend/src/as6-command-center-reference-guard.js || FAIL=1
grep -Rqs "as6-command-center-reference-guard-active" frontend/src/as6-command-center-reference-guard.js frontend/src/styles/as6-command-center-reference-guard.css || FAIL=1
if grep -Rqs "as6-command-center-true-reference\|as6-command-center-appshell-reference\|as6-command-center-reference-page" frontend/src/pages/CommandCenterPage.jsx 2>/dev/null; then FAIL=1; fi
if [ "$FAIL" -ne 0 ]; then echo "AS6_COMMAND_CENTER_REFERENCE_GUARD_SAFE=FAIL"; exit 1; fi
echo "AS6_COMMAND_CENTER_REFERENCE_GUARD_SAFE=PASS"
