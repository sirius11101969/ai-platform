#!/usr/bin/env bash
set -euo pipefail

SNAPSHOT_FILE="${1:-}"

if [ -z "$SNAPSHOT_FILE" ]; then
  SNAPSHOT_FILE="$(ls -1t ops/releases/*.json 2>/dev/null | head -n1 || true)"
fi

test -n "$SNAPSHOT_FILE" || { echo "AS6_RELEASE_SNAPSHOT_GATE=FAIL snapshot_missing"; exit 1; }
test -f "$SNAPSHOT_FILE" || { echo "AS6_RELEASE_SNAPSHOT_GATE=FAIL snapshot_file_missing:$SNAPSHOT_FILE"; exit 1; }

node -e '
const fs = require("fs");
const file = process.argv[1];
const data = JSON.parse(fs.readFileSync(file, "utf8"));
const required = ["timestamp","branch","commit","target","node","npm","vite","evidence","evidence_sha256","validate","release_gate","release","readiness"];
for (const key of required) {
  if (!data[key]) {
    console.error(`AS6_RELEASE_SNAPSHOT_GATE=FAIL missing:${key}`);
    process.exit(1);
  }
}
if (data.validate !== "PASS" || data.release_gate !== "PASS" || data.release !== "PASS") {
  console.error("AS6_RELEASE_SNAPSHOT_GATE=FAIL pass_marker_invalid");
  process.exit(1);
}
if (!fs.existsSync(data.evidence)) {
  console.error(`AS6_RELEASE_SNAPSHOT_GATE=FAIL evidence_missing:${data.evidence}`);
  process.exit(1);
}
console.log("AS6_RELEASE_SNAPSHOT_JSON=PASS");
' "$SNAPSHOT_FILE"

echo "AS6_RELEASE_SNAPSHOT_GATE=PASS"
echo "AS6_RELEASE_SNAPSHOT_FILE=$SNAPSHOT_FILE"
