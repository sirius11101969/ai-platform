#!/usr/bin/env bash
set -euo pipefail
test -f docs/epic009/as6-epic009-architecture-review.md
test -f docs/adr/as6-adr-epic009-operating-system-architecture.md
test -f docs/epic009/as6-epic009-compatibility-contracts.md
test -f docs/epic009/as6-epic009-solution-design-input.md
grep -q "ARCHITECTURE_REVIEW=APPROVED" docs/epic009/as6-epic009-architecture-review.md
grep -q "ADR_STATUS=APPROVED" docs/adr/as6-adr-epic009-operating-system-architecture.md
grep -q "COMPATIBILITY_CONTRACTS=APPROVED" docs/epic009/as6-epic009-compatibility-contracts.md
grep -q "SOLUTION_DESIGN_INPUT=READY" docs/epic009/as6-epic009-solution-design-input.md
echo AS6_EPIC009_ARCHITECTURE_REVIEW=PASS
echo AS6_SOLUTION_DESIGN_READY=TRUE
