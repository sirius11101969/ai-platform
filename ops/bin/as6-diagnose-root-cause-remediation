#!/usr/bin/env bash
set -euo pipefail
cd "${AS6_REPO_ROOT:-$(git rev-parse --show-toplevel 2>/dev/null || pwd)}"
echo "=== AS6 Root Cause Remediation Diagnostics ==="
fail=0
catalog="ops/governance/root-cause-catalog.json"
helper="ops/lib/as6-root-cause-remediation-check.py"
if [ -s "$catalog" ]; then echo "AS6_ROOT_CAUSE_REMEDIATION_CATALOG=PASS"; else echo "AS6_ROOT_CAUSE_REMEDIATION_CATALOG=FAIL"; fail=1; fi
if [ -s "$helper" ]; then echo "AS6_ROOT_CAUSE_REMEDIATION_HELPER=PASS:$helper"; else echo "AS6_ROOT_CAUSE_REMEDIATION_HELPER=FAIL:$helper"; fail=1; fi
if [ "$fail" -eq 0 ]; then python3 "$helper" "$catalog" || fail=1; fi
if [ "$fail" -eq 0 ]; then exit 0; fi
echo "AS6_ROOT_CAUSE_REMEDIATION=FAIL"; echo "AS6_ROOT_CAUSE_REMEDIATION_RESULT=FAIL"; exit 1
