grep -q "width: 286px" frontend/src/styles/as6-command-center-sidebar-etalon-v200.css
grep -q "linear-gradient(100deg, #7c2dff" frontend/src/styles/as6-command-center-sidebar-etalon-v200.css
! grep -q "body:has" frontend/src/styles/as6-command-center-sidebar-etalon-v200.css
echo "AS6_COMMAND_CENTER_SIDEBAR_ETALON_V200=PASS"
