#!/usr/bin/env bash
set -euo pipefail
cd "${AS6_REPO_ROOT:-$(git rev-parse --show-toplevel 2>/dev/null || pwd)}"
echo "=== AS6 Autonomous Change Controller Diagnostics ==="
fail=0
DOC="ops/governance/as6-autonomous-change-controller.md"
EVIDENCE_DIR="runtime/change-controller"
mkdir -p "$EVIDENCE_DIR"
git status --short > "$EVIDENCE_DIR/git-status.txt" 2>/dev/null || true
git log --oneline -5 > "$EVIDENCE_DIR/git-log.txt" 2>/dev/null || true
test -f "$DOC" && echo "AS6_AUTONOMOUS_CHANGE_CONTROLLER_DOC=PASS:$DOC" || { echo "AS6_AUTONOMOUS_CHANGE_CONTROLLER_DOC=FAIL:$DOC"; fail=1; }
for signal in AS6_AUTONOMOUS_CHANGE_IMPACT=PASS AS6_AUTONOMOUS_CHANGE_RISK=PASS AS6_AUTONOMOUS_CHANGE_ROLLBACK=PASS AS6_AUTONOMOUS_CHANGE_VALIDATION=PASS AS6_AUTONOMOUS_CHANGE_EVIDENCE=PASS AS6_AUTONOMOUS_CHANGE_REGISTRY=PASS AS6_AUTONOMOUS_CHANGE_DEPLOYMENT_GATE=PASS AEC_AUTONOMOUS_CHANGE_CONTROLLER=PASS; do
  if grep -q "$signal" "$DOC"; then
    echo "AS6_AUTONOMOUS_CHANGE_CONTROLLER_SIGNAL=PASS:$signal"
  else
    echo "AS6_AUTONOMOUS_CHANGE_CONTROLLER_SIGNAL=FAIL:$signal"
    fail=1
  fi
done
for cls in AUTONOMOUS_CHANGE_CONTROLLER_DRIFT CHANGE_EVIDENCE_MISSING DEPLOYMENT_GATE_BYPASS UNVALIDATED_AUTONOMOUS_CHANGE; do
  if grep -q "$cls" ops/governance/root-cause-catalog.json; then
    echo "AS6_AUTONOMOUS_CHANGE_CONTROLLER_ROOT_CAUSE=PASS:$cls"
  else
    echo "AS6_AUTONOMOUS_CHANGE_CONTROLLER_ROOT_CAUSE=FAIL:$cls"
    fail=1
  fi
done
grep -q "autonomous-change-controller" ops/bin/as6-diagnose-all && echo "AS6_AUTONOMOUS_CHANGE_CONTROLLER_DIAGNOSE_ALL=PASS" || { echo "AS6_AUTONOMOUS_CHANGE_CONTROLLER_DIAGNOSE_ALL=FAIL"; fail=1; }
grep -q "ops/bin/as6-diagnose-autonomous-change-controller" ops/status/diagnostic-status-registry.json && echo "AS6_AUTONOMOUS_CHANGE_CONTROLLER_REGISTRY=PASS" || { echo "AS6_AUTONOMOUS_CHANGE_CONTROLLER_REGISTRY=FAIL"; fail=1; }
grep -q "AEC_AUTONOMOUS_CHANGE_CONTROLLER=PASS" docs/AS6_AUTONOMOUS_ENGINEERING_CONSTITUTION.md && echo "AS6_AUTONOMOUS_CHANGE_CONTROLLER_AEC_RULE=PASS" || { echo "AS6_AUTONOMOUS_CHANGE_CONTROLLER_AEC_RULE=FAIL"; fail=1; }
if [ "$fail" -eq 0 ]; then
  echo "AS6_AUTONOMOUS_CHANGE_IMPACT=PASS"
  echo "AS6_AUTONOMOUS_CHANGE_RISK=PASS"
  echo "AS6_AUTONOMOUS_CHANGE_ROLLBACK=PASS"
  echo "AS6_AUTONOMOUS_CHANGE_VALIDATION=PASS"
  echo "AS6_AUTONOMOUS_CHANGE_EVIDENCE=PASS"
  echo "AS6_AUTONOMOUS_CHANGE_REGISTRY=PASS"
  echo "AS6_AUTONOMOUS_CHANGE_DEPLOYMENT_GATE=PASS"
  echo "AS6_AUTONOMOUS_CHANGE_CONTROLLER=PASS"
  echo "AS6_AUTONOMOUS_CHANGE_CONTROLLER_EVIDENCE_DIR=$EVIDENCE_DIR"
  echo "AS6_AUTONOMOUS_CHANGE_CONTROLLER_RESULT=OK"
  exit 0
fi
echo "AS6_AUTONOMOUS_CHANGE_CONTROLLER=FAIL"
echo "AS6_AUTONOMOUS_CHANGE_CONTROLLER_RESULT=FAIL"
exit 1
