#!/usr/bin/env bash
set -euo pipefail

ROOT="${AS6_REPO_ROOT:-$(git rev-parse --show-toplevel 2>/dev/null || pwd)}"
cd "$ROOT"

fail=0

echo "=== AS6 Diagnose All Registry Coverage Diagnostics ==="
echo "HEAVY_DASHBOARD_CHECK_SKIP_POLICY=OK"

test -x ops/bin/as6-diagnostic-registry && echo "DIAGNOSE_ALL_REGISTRY_SOURCE=OK" || { echo "DIAGNOSE_ALL_REGISTRY_SOURCE=FAIL"; fail=1; }
test -x ops/bin/as6-diagnose-all && echo "DIAGNOSE_ALL_SCRIPT=OK" || { echo "DIAGNOSE_ALL_SCRIPT=FAIL"; fail=1; }

if grep -qF "as6-diagnostic-registry" ops/bin/as6-diagnose-all; then
  echo "REGISTRY_DRIVEN_DIAGNOSE_ALL_MODE=OK"
else
  echo "REGISTRY_DRIVEN_DIAGNOSE_ALL_MODE=NO"
fi

registry="$(mktemp)"
status_file="ops/bin/as6-diagnose-all"

./ops/bin/as6-diagnostic-registry \
  | awk -F= '/^DIAGNOSTIC_REGISTRY_ENTRY=OK:/ {print $2}' \
  | sed 's#^OK:##' \
  | sort > "$registry"

while read -r diag; do
  case "$diag" in
    ops/bin/as6-diagnose-all|ops/bin/as6-diagnose-diagnostic-registry|ops/bin/as6-diagnose-diagnostic-coverage|ops/bin/as6-diagnose-diagnostic-flow)
      echo "DIAGNOSE_ALL_REGISTRY_SKIPPED=OK:$diag"
      continue
      ;;
    ops/bin/as6-diagnose-health-dashboard-integration|ops/bin/as6-diagnose-health-timer-dashboard|ops/bin/as6-diagnose-command-center)
      echo "DIAGNOSE_ALL_REGISTRY_SKIPPED=OK:heavy_dashboard_check_prevents_nested_diagnose_all:$diag"
      continue
      ;;
  esac

  if grep -qF "$diag" "$status_file" || grep -qF "${diag#ops/bin/as6-diagnose-}" "$status_file"; then
    echo "DIAGNOSE_ALL_REGISTRY_INCLUDED=OK:$diag"
  elif grep -qF "as6-diagnostic-registry" "$status_file"; then
    echo "DIAGNOSE_ALL_REGISTRY_INCLUDED=OK:registry_driven:$diag"
  else
    echo "DIAGNOSE_ALL_REGISTRY_INCLUDED=FAIL:not_in_diagnose_all:$diag"
    fail=1
  fi
done < "$registry"

rm -f "$registry"

if [ "$fail" -eq 0 ]; then
  echo "DIAGNOSE_ALL_REGISTRY_RESULT=OK"
  exit 0
fi

echo "DIAGNOSE_ALL_REGISTRY_RESULT=FAIL"
exit 1
