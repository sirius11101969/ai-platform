#!/usr/bin/env bash
set -euo pipefail

ROOT="${AS6_REPO_ROOT:-$(git rev-parse --show-toplevel 2>/dev/null || pwd)}"
cd "$ROOT"

PAGE="frontend/src/pages/CommandCenterPage.jsx"
SHELL="frontend/src/components/AppShell.jsx"
THEME="frontend/src/theme/as6Theme.css"
APP="frontend/src/App.jsx"

failures=0

check_file(){ [[ -f "$1" ]] && echo "OK:file:$1" || { echo "FAIL:file:$1"; failures=$((failures+1)); }; }
check_pattern(){ grep -Eq "$2" "$1" && echo "$3=OK" || { echo "$3=FAIL"; failures=$((failures+1)); }; }

check_file "$PAGE"
check_file "$SHELL"
check_file "$THEME"
check_file "$APP"

check_pattern "$APP" 'path="/command-center"' 'COMMAND_CENTER_ROUTE'
check_pattern "$SHELL" 'data-command-sidebar=\{isCommandCenter \? "premium" : undefined\}' 'COMMAND_CENTER_NAV'
check_pattern "$SHELL" 'command-center-active|🚀 Command Center|ИЗБРАННОЕ|AS6 Owner|Открыть AI поддержку' 'COMMAND_CENTER_SIDEBAR'

AI_WORKERS_NAV_COUNT="$( (grep -RIn 'to="/ai-workers"' "$SHELL" 2>/dev/null || true) | wc -l | tr -d '[:space:]')"
echo "AI_WORKERS_NAV_COUNT=$AI_WORKERS_NAV_COUNT"

if [[ "$AI_WORKERS_NAV_COUNT" == "0" ]]; then
  echo "MENU_DUPLICATES_RESULT=OK"
else
  echo "MENU_DUPLICATES_RESULT=FAIL"
  grep -RIn 'to="/ai-workers"' "$SHELL" || true
  failures=$((failures+1))
fi

check_pattern "$SHELL" 'to="/ai-workforce-center".*>AI сотрудники' 'AI_WORKFORCE_NAV'
check_pattern "$SHELL" 'to="/ai-approval-center".*>AI SDR Approval Center' 'AI_APPROVAL_NAV'

check_pattern "$PAGE" 'data-command-center-visual="premium-as6"|command-center-page' 'COMMAND_CENTER_PAGE'
check_pattern "$PAGE" 'command-hero|Ваш AI Command Center|command-top-actions' 'COMMAND_CENTER_HERO'
check_pattern "$PAGE" 'data-command-kpi-row|command-kpis|Выручка сегодня|Новые лиды|AI сотрудники|Конверсия' 'COMMAND_CENTER_KPIS'
check_pattern "$PAGE" 'data-pipeline-funnel|Pipeline Overview|funnelStages|Сумма в процессе|В выигрыше' 'COMMAND_CENTER_FUNNEL'
check_pattern "$PAGE" 'data-copilot-rail|data-copilot-hero|AI Copilot|Спросить AI Copilot|Следующее лучшее действие' 'COMMAND_CENTER_COPILOT'
check_pattern "$PAGE" 'data-ai-recommendations|AI рекомендации|Высокий приоритет|Возможность роста|Оптимизация|Риск' 'COMMAND_CENTER_RECOMMENDATIONS'
check_pattern "$PAGE" 'data-quick-actions|Быстрые действия|Создать лид|Создать сделку|Approval Queue|Настроить AI' 'COMMAND_CENTER_QUICK_ACTIONS'
check_pattern "$THEME" 'command-center-page|command-hero|command-kpis|pipeline-funnel|copilot-hero|quick-actions' 'COMMAND_CENTER_THEME'

if ! docker compose build nginx >/tmp/as6-command-center-build.log 2>&1; then
  echo "FRONTEND_BUILD_RESULT=FAIL"
  tail -50 /tmp/as6-command-center-build.log || true
  failures=$((failures+1))
else
  echo "FRONTEND_BUILD_RESULT=OK"
fi

if [[ "$failures" -eq 0 ]]; then
  echo "COMMAND_CENTER_RESULT=OK"
  exit 0
