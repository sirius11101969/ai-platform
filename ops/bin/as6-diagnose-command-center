#!/usr/bin/env bash
set -euo pipefail
ROOT="${AS6_REPO_ROOT:-$(git rev-parse --show-toplevel 2>/dev/null || pwd)}"
cd "$ROOT"
PAGE="frontend/src/pages/CommandCenterPage.jsx"
SHELL="frontend/src/components/AppShell.jsx"
THEME="frontend/src/theme/as6Theme.css"
APP="frontend/src/App.jsx"
check_file(){ test -f "$1" || { echo "missing:$1"; exit 1; }; }
check_pattern(){ local file="$1" pattern="$2" label="$3"; if rg -q "$pattern" "$file"; then echo "OK:$label"; else echo "FAIL:$label"; exit 1; fi; }
check_file "$PAGE"; check_file "$SHELL"; check_file "$THEME"; check_file "$APP"
check_pattern "$APP" 'path="/command-center"' 'command center route'
check_pattern "$SHELL" 'data-command-sidebar|command-sidebar|as6-sidebar-brand|command-center-active' 'left sidebar command center styling markers'
check_pattern "$PAGE" 'data-command-kpi-row|command-kpis|Выручка сегодня|Новые лиды|Конверсия' 'command KPI row'
check_pattern "$PAGE" 'data-copilot-hero|AI Copilot|Спросить AI Copilot' 'copilot hero'
check_pattern "$PAGE" 'data-pipeline-funnel|Pipeline Overview|funnelStages|Новые лиды|Квалификация|Закрытие' 'pipeline funnel'
check_pattern "$PAGE" 'data-right-action-rail|Следующее лучшее действие|Ожидаемый эффект' 'right action rail'
check_pattern "$PAGE" 'data-ai-recommendations|AI рекомендации|Высокий приоритет|Возможность роста|Оптимизация|Риск' 'AI recommendations'
check_pattern "$PAGE" 'data-quick-actions|Быстрые действия|Создать лид|Настроить AI' 'quick actions'
( cd frontend && npm run build )
echo 'OK:frontend build'
echo 'COMMAND_CENTER_VISUAL_RESULT=OK'
echo 'COMMAND_CENTER_VISUAL_PROGRESS=100'
