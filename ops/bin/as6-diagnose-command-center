#!/usr/bin/env bash
set -euo pipefail

ROOT="${AS6_REPO_ROOT:-$(git rev-parse --show-toplevel 2>/dev/null || pwd)}"
cd "$ROOT"

PAGE="frontend/src/pages/CommandCenterPage.jsx"
SHELL="frontend/src/components/AppShell.jsx"
THEME="frontend/src/theme/as6Theme.css"
APP="frontend/src/App.jsx"

check_file() {
  test -f "$1" || { echo "FAIL:missing:$1"; exit 1; }
}

check_text() {
  local file="$1" text="$2" label="$3"
  if rg -q --fixed-strings "$text" "$file"; then
    echo "OK:$label:$text"
  else
    echo "FAIL:$label:$text"
    exit 1
  fi
}

check_texts() {
  local file="$1" label="$2"
  shift 2
  local text
  for text in "$@"; do
    check_text "$file" "$text" "$label"
  done
  echo "OK:$label"
}

check_file "$PAGE"
check_file "$SHELL"
check_file "$THEME"
check_file "$APP"

check_texts "$APP" 'COMMAND_CENTER_ROUTE' 'path="/command-center"'
check_texts "$SHELL" 'COMMAND_CENTER_PREMIUM_SHELL_TOGGLE' 'isCommandCenter' 'command-shell' 'data-command-sidebar={isCommandCenter ? "premium" : undefined}'
check_texts "$SHELL" 'COMMAND_CENTER_PREMIUM_SIDEBAR' 'AS6' 'AI PLATFORM' 'command-center-active' '🚀 Command Center' 'ИЗБРАННОЕ' 'Pipeline Copilot' 'Approval Queue' 'AS6 Owner' 'Открыть AI поддержку'
check_texts "$PAGE" 'COMMAND_CENTER_PREMIUM_HERO' 'data-command-center-visual="premium-as6"' 'Добро пожаловать' 'Ваш AI Command Center' 'command-top-actions' 'data-badge="12"' 'data-badge="3"'
check_texts "$PAGE" 'COMMAND_CENTER_PREMIUM_KPI_ROW' 'data-command-kpi-row' 'Выручка сегодня' '$1,248,890' 'Новые лиды' '247' 'Сделки в работе' '87' 'AI сотрудники' '28 / 28' 'Конверсия' '24.6%'
check_texts "$PAGE" 'COMMAND_CENTER_PREMIUM_FUNNEL' 'data-pipeline-funnel' 'Pipeline Overview' 'funnelStages' 'Новые лиды' 'Квалификация' 'Презентация' 'Переговоры' 'Закрытие' 'Сумма в процессе' 'В выигрыше'
check_texts "$PAGE" 'COMMAND_CENTER_PREMIUM_CORE_CARDS' 'Главная цель дня' 'Увеличить выручку на $12,400 сегодня' 'Производительность AI сотрудников' 'Динамика выручки' 'Цели на месяц'
check_texts "$PAGE" 'COMMAND_CENTER_PREMIUM_RIGHT_RAIL' 'data-right-action-rail' 'data-copilot-rail' 'data-copilot-hero' 'AI Copilot' 'Спросить AI Copilot' 'Последние события' 'Следующее лучшее действие' 'Ожидаемый эффект' '+$8,900'
check_texts "$PAGE" 'COMMAND_CENTER_PREMIUM_RECOMMENDATIONS' 'data-ai-recommendations' 'AI рекомендации' 'Высокий приоритет' 'Возможность роста' 'Оптимизация' 'Риск'
check_texts "$PAGE" 'COMMAND_CENTER_PREMIUM_QUICK_ACTIONS' 'data-quick-actions' 'Быстрые действия' 'Создать лид' 'Создать сделку' 'Добавить задачу' 'Approval Queue' 'AI аналитика' 'Отчёты' 'Настроить AI'
check_texts "$THEME" 'COMMAND_CENTER_PREMIUM_THEME_TOKENS' '#030712' '#020617' 'command-kpis' 'copilot-hero' 'pipeline-funnel' 'command-right-rail'
check_texts "$THEME" 'COMMAND_CENTER_PREMIUM_FUNNEL_CSS' 'clip-path: polygon(10% 0, 90% 0, 100% 100%, 0 100%)'
check_texts "$THEME" 'COMMAND_CENTER_PREMIUM_QUICK_ACTIONS_STICKY' 'quick-actions { position: sticky; bottom: 8px'

python - <<'PY'
from pathlib import Path
import re
import sys

shell = Path('frontend/src/components/AppShell.jsx').read_text(encoding='utf-8')
try:
    premium_block = shell.split('{isCommandCenter ? (', 1)[1].split('\n        ) : (\n', 1)[0]
except IndexError:
    print('FAIL:MENU_DUPLICATES_PREMIUM_BLOCK')
    sys.exit(1)

labels = []
for line in premium_block.splitlines():
    if '<NavLink' not in line or '</NavLink>' not in line:
        continue
    before_close = line.rsplit('</NavLink>', 1)[0]
    raw = before_close.rsplit('>', 1)[1]
    raw = re.sub(r'<[^>]+>', ' ', raw)
    raw = re.sub(r'\{[^}]+\}', ' ', raw)
    raw = re.sub(r'^[^\wА-Яа-я]+', '', raw.strip())
    label = ' '.join(raw.split())
    if label:
        labels.append(label)

duplicates = sorted({label for label in labels if labels.count(label) > 1})
if duplicates:
    print('FAIL:MENU_DUPLICATES:' + ', '.join(duplicates))
    sys.exit(1)

command_center_labels = [label for label in labels if label == 'Command Center']
if len(command_center_labels) != 1:
    print(f'FAIL:MENU_DUPLICATES_COMMAND_CENTER_COUNT:{len(command_center_labels)}')
    sys.exit(1)

print('OK:MENU_DUPLICATES')
PY

( cd frontend && npm run build )
echo 'OK:frontend build'
echo 'COMMAND_CENTER_RESULT=OK'
echo 'MENU_DUPLICATES_RESULT=OK'
echo 'UI_AUDIT_RESULT=OK'
