#!/usr/bin/env bash
set -euo pipefail
ROOT="${AS6_REPO_ROOT:-$(git rev-parse --show-toplevel 2>/dev/null || pwd)}"
cd "$ROOT"
PAGE="frontend/src/pages/CommandCenterPage.jsx"
SHELL="frontend/src/components/AppShell.jsx"
THEME="frontend/src/theme/as6Theme.css"
APP="frontend/src/App.jsx"
check_file(){ test -f "$1" || { echo "missing:$1"; exit 1; }; }
check_pattern(){ local file="$1" pattern="$2" label="$3"; if rg -q "$pattern" "$file"; then echo "OK:$label"; else echo "FAIL:$label"; exit 1; fi; }
check_file "$PAGE"; check_file "$SHELL"; check_file "$THEME"; check_file "$APP"
check_pattern "$APP" 'path="/command-center"' 'command center route'
check_pattern "$APP" 'path="/ai-workers"' 'legacy ai-workers route'
check_pattern "$APP" 'path="/ai-workforce-center"' 'ai workforce center route'
check_pattern "$APP" 'path="/ai-approval-center"' 'ai approval center route'
check_pattern "$SHELL" 'AS6|AI PLATFORM|command-center-active|🚀 Command Center|ИЗБРАННОЕ|AS6 Owner|Открыть AI поддержку' 'COMMAND_CENTER_VISUAL_SIDEBAR'
check_pattern "$PAGE" 'data-command-kpi-row|Выручка сегодня|\$1,248,890|Новые лиды|247|Сделки в работе|87|AI сотрудники|28 / 28|Конверсия|24.6%' 'COMMAND_CENTER_VISUAL_KPI_ROW'
check_pattern "$PAGE" 'data-pipeline-funnel|Pipeline Overview|funnelStages|Новые лиды|Квалификация|Презентация|Переговоры|Закрытие|Сумма в процессе|В выигрыше' 'COMMAND_CENTER_VISUAL_FUNNEL'
check_pattern "$THEME" 'clip-path: polygon\(10% 0, 90% 0, 100% 100%, 0 100%\)' 'COMMAND_CENTER_VISUAL_FUNNEL_TRAPEZOID_CSS'
check_pattern "$PAGE" 'data-copilot-rail|data-copilot-hero|AI Copilot|Спросить AI Copilot|Последние события|Следующее лучшее действие|Ожидаемый эффект|\+\$8,900' 'COMMAND_CENTER_VISUAL_COPILOT_RAIL'
check_pattern "$PAGE" 'data-ai-recommendations|AI рекомендации|Высокий приоритет|Возможность роста|Оптимизация|Риск' 'COMMAND_CENTER_VISUAL_RECOMMENDATIONS'
check_pattern "$PAGE" 'data-quick-actions|Быстрые действия|Создать лид|Создать сделку|Добавить задачу|Approval Queue|AI аналитика|Отчёты|Настроить AI' 'COMMAND_CENTER_VISUAL_QUICK_ACTIONS'
check_pattern "$THEME" 'position: sticky; bottom: 8px' 'COMMAND_CENTER_VISUAL_QUICK_ACTIONS_STICKY'
check_pattern "$SHELL" 'to="/ai-workforce-center".*>👥 AI сотрудники</NavLink>' 'AI employees command nav route'
check_pattern "$SHELL" 'to="/ai-workforce-center".*>⌘ AI SDR Agents</NavLink>' 'AI SDR Agents nav route'
check_pattern "$SHELL" 'to="/ai-workforce-center".*>AI сотрудники</NavLink>' 'AI employees main nav route'
check_pattern "$SHELL" 'to="/ai-approval-center".*>AI SDR Approval Center</NavLink>' 'AI SDR Approval Center nav route'
check_pattern "$SHELL" 'to="/ai-approval-center".*>▢ Approval Queue' 'Approval Queue nav route'
ai_employees_workforce_count=$(rg 'to="/ai-workforce-center".*>(👥 )?AI сотрудники</NavLink>' "$SHELL" | wc -l | tr -d ' ')
if [ "$ai_employees_workforce_count" -ne 2 ]; then echo "FAIL:AI employees route count=$ai_employees_workforce_count"; exit 1; fi
ai_workers_nav_count=$(( $(rg -o 'path="/ai-workers"|to="/ai-workers"' "$APP" "$SHELL" | wc -l | tr -d ' ') ))
echo "AI_WORKERS_NAV_COUNT=$ai_workers_nav_count"
if [ "$ai_workers_nav_count" -ne 1 ]; then
  echo 'MENU_DUPLICATES_RESULT=FAIL'
  echo 'COMMAND_CENTER_RESULT=FAIL'
  exit 1
fi
if rg -q 'to="/ai-workers".*>(👥 AI сотрудники|⌘ AI SDR Agents|AI сотрудники|AI SDR Approval Center)' "$SHELL"; then
  echo 'MENU_DUPLICATES_RESULT=FAIL'
  echo 'COMMAND_CENTER_RESULT=FAIL'
  exit 1
fi
( cd frontend && npm run build )
echo 'OK:frontend build'
echo 'MENU_DUPLICATES_RESULT=OK'
echo 'COMMAND_CENTER_VISUAL_SIDEBAR=OK'
echo 'COMMAND_CENTER_VISUAL_KPI_ROW=OK'
echo 'COMMAND_CENTER_VISUAL_FUNNEL=OK'
echo 'COMMAND_CENTER_VISUAL_COPILOT_RAIL=OK'
echo 'COMMAND_CENTER_VISUAL_RECOMMENDATIONS=OK'
echo 'COMMAND_CENTER_VISUAL_QUICK_ACTIONS=OK'
echo 'COMMAND_CENTER_VISUAL_RESULT=OK'
echo 'COMMAND_CENTER_RESULT=OK'
echo 'COMMAND_CENTER_VISUAL_PROGRESS=100'
