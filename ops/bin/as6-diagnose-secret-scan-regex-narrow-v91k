#!/usr/bin/env bash
set -euo pipefail

SCAN_SOURCE=""
if [ -x .git/hooks/pre-commit ]; then
  SCAN_SOURCE=".git/hooks/pre-commit"
elif [ -x ops/bin/as6-pre-commit-secret-scan ]; then
  SCAN_SOURCE="ops/bin/as6-pre-commit-secret-scan"
else
  echo "AS6_SECRET_SCAN_REGEX_NARROW_V91K=FAIL scanner_missing"
  exit 1
fi

if ! grep -q "SECRET_PATTERN=" "$SCAN_SOURCE" && ! grep -Fq "api[_-]?key" "$SCAN_SOURCE"; then
  echo "AS6_SECRET_SCAN_REGEX_NARROW_V91K=FAIL narrow_pattern_missing"
  exit 1
fi

! grep -q "grep -Eiq '(password|passwd|api" "$SCAN_SOURCE" || { echo "AS6_SECRET_SCAN_REGEX_NARROW_V91K=FAIL old_broad_pattern_present"; exit 1; }

echo "AS6_SECRET_SCAN_REGEX_NARROW_V91K=PASS"
