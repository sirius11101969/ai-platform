#!/usr/bin/env bash
set -euo pipefail

test -x .git/hooks/pre-commit || { echo "AS6_SECRET_SCAN_REGEX_NARROW_V91K=FAIL hook_missing"; exit 1; }
grep -q "SECRET_PATTERN=" .git/hooks/pre-commit || { echo "AS6_SECRET_SCAN_REGEX_NARROW_V91K=FAIL narrow_pattern_missing"; exit 1; }
! grep -q "grep -Eiq '(password|passwd|api" .git/hooks/pre-commit || { echo "AS6_SECRET_SCAN_REGEX_NARROW_V91K=FAIL old_broad_pattern_present"; exit 1; }

echo "AS6_SECRET_SCAN_REGEX_NARROW_V91K=PASS"
