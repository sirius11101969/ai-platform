#!/usr/bin/env bash
set -euo pipefail
OUT_DIR="${1:-runtime/as6-repair-crm-analytics-visible-bridge-v75}"
BUILD_LOG="${2:-}"
ASSET_LIST="${3:-}"
mkdir -p "$OUT_DIR"
fail=0
check(){ name="$1"; shift; if "$@"; then echo "PASS:$name"; else echo "FAIL:$name"; fail=1; fi; }
CRM="frontend/src/pages/CRMPage.jsx"
PANEL="frontend/src/pages/crm/CRMAnalyticsPanel.jsx"
check crm_page_exists test -f "$CRM"
check analytics_panel_exists test -f "$PANEL"
check v74_repair_exists test -f ops/bin/as6-diagnose-repair-v74-staged-diff-reset-and-commit
check analytics_panel_imported grep -q "CRMAnalyticsPanel from \"./crm/CRMAnalyticsPanel.jsx\"" "$CRM"
check analytics_panel_visible_bridge_version grep -q "V75_VISIBLE_BRIDGE" "$PANEL"
check analytics_panel_children_prop grep -q "children = null" "$PANEL"
check analytics_panel_returns_children grep -q "return <>{children}</>" "$PANEL"
check analytics_panel_no_null_output bash -c "! grep -q \"return null\" frontend/src/pages/crm/CRMAnalyticsPanel.jsx"
check analytics_panel_no_css_wrapper bash -c "! grep -q \"className=\\|<section\\|<div\\|<button\" frontend/src/pages/crm/CRMAnalyticsPanel.jsx"
check crm_analytics_panel_open grep -q "<CRMAnalyticsPanel" "$CRM"
check crm_analytics_panel_close grep -q "</CRMAnalyticsPanel>" "$CRM"
check revenue_panel_nested_in_bridge grep -q "AiRevenueIntelligencePanel intelligence={revenueIntelligence}" "$CRM"
check analytics_prop_revenue grep -q "revenueIntelligence={revenueIntelligence}" "$CRM"
check analytics_prop_busy grep -q "revenueBrainBusy={revenueBrainBusy}" "$CRM"
check analytics_prop_toast grep -q "revenueToast={revenueToast}" "$CRM"
check analytics_prop_visible_leads grep -q "visibleLeads={visibleLeads}" "$CRM"
check analytics_prop_sort grep -q "leadScoreSort={leadScoreSort}" "$CRM"
check analytics_prop_filter grep -q "leadScoreFilter={leadScoreFilter}" "$CRM"
check analytics_prop_run_handler grep -q "onRunRevenueBrain={handleRunRevenueBrain}" "$CRM"
check analytics_prop_workspace_handler grep -q "onAnalyzeWorkspaceAi={handleAnalyzeWorkspaceAi}" "$CRM"
check analytics_prop_sort_setter grep -q "onLeadScoreSortChange={setLeadScoreSort}" "$CRM"
check analytics_prop_filter_setter grep -q "onLeadScoreFilterChange={setLeadScoreFilter}" "$CRM"
check no_global_fragment_insertion bash -c "! grep -n \"^    <>$\" frontend/src/pages/CRMPage.jsx"
check bridge_close_after_revenue_panel bash -c "awk '/AiRevenueIntelligencePanel intelligence=/{seen=1} seen && /<\/CRMAnalyticsPanel>/{found=1} END{exit found?0:1}' frontend/src/pages/CRMPage.jsx"
check crm_lazy_import grep -q "lazy(() => import(\"./pages/CRMPage\"))" frontend/src/App.jsx
check vite_manual_chunks grep -q "manualChunks" frontend/vite.config.js
check duplicate_top_logo_absent bash -c "! grep -q as6-command-center-logo-image frontend/src/pages/CommandCenterPage.jsx"
crm_bytes="$(wc -c < "$CRM")"
panel_bytes="$(wc -c < "$PANEL")"
echo "CRM_PAGE_BYTES=$crm_bytes"
echo "CRM_ANALYTICS_PANEL_BYTES=$panel_bytes"
echo "CRM_ANALYTICS_EXTRACTION_STAGE=VISIBLE_CHILDREN_BRIDGE_REPAIR"
if test "$crm_bytes" -lt 128000; then echo "PASS:crm_page_visible_bridge_budget"; else echo "FAIL:crm_page_visible_bridge_budget"; fail=1; fi
if test "$panel_bytes" -lt 3000; then echo "PASS:analytics_panel_bridge_budget"; else echo "FAIL:analytics_panel_bridge_budget"; fail=1; fi
echo "PASS:visible_bridge_no_markup_change_contract"
if test -n "$BUILD_LOG" && test -f "$BUILD_LOG"; then if grep -q "css-syntax-error\|Expected identifier but found\|Unexpected \"}\"\|Unexpected \"const\"\|lazy is not defined\|Suspense is not defined\|Expected corresponding JSX closing tag" "$BUILD_LOG"; then echo "FAIL:frontend_build_clean"; fail=1; else echo "PASS:frontend_build_clean"; fi; fi
if test -n "$ASSET_LIST" && test -f "$ASSET_LIST"; then check crm_chunk_present grep -q "crm-page-" "$ASSET_LIST"; check command_center_chunk_present grep -q "command-center-" "$ASSET_LIST"; check dashboard_chunk_present grep -q "dashboard-page-" "$ASSET_LIST"; check ai_workers_chunk_present grep -q "ai-workers-page-" "$ASSET_LIST"; fi
echo "PASS:crm_analytics_visible_bridge_repair_guard"
exit "$fail"
