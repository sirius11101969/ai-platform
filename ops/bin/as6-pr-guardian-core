#!/usr/bin/env bash
set -euo pipefail

ROOT="${AS6_REPO_ROOT:-$(git rev-parse --show-toplevel 2>/dev/null || pwd)}"
cd "$ROOT"

mkdir -p var/cache
REPORT="var/cache/as6-pr-guardian.json"
LOG="var/cache/as6-pr-guardian.log"

failures=0
passed=0

run_check() {
  local name="$1"
  local required_marker="${2:-}"
  shift 2

  echo "=== $name ===" | tee -a "$LOG"
  local tmp
  tmp="$(mktemp)"

  if "$@" >"$tmp" 2>&1; then
    cat "$tmp" | tee -a "$LOG"

    if [ -n "$required_marker" ] && ! grep -q "$required_marker" "$tmp"; then
      echo "FAIL: $name missing marker: $required_marker" | tee -a "$LOG"
      failures=$((failures + 1))
    elif grep -Eq 'RESULT=(WARN|FAIL|BLOCK)|MERGE_BLOCKED|COMMAND_CENTER_RESULT=WARN|UI_AUDIT_RESULT=WARN|MENU_DUPLICATES_RESULT=WARN' "$tmp"; then
      echo "FAIL: $name returned WARN/BLOCK/FAIL marker" | tee -a "$LOG"
      failures=$((failures + 1))
    else
      echo "PASS: $name" | tee -a "$LOG"
      passed=$((passed + 1))
    fi
  else
    cat "$tmp" | tee -a "$LOG"
    echo "FAIL: $name command exited non-zero" | tee -a "$LOG"
    failures=$((failures + 1))
  fi

  rm -f "$tmp"
}

: > "$LOG"

echo "==================================================" | tee -a "$LOG"
echo "AS6 ARCHITECTURE GUARDIAN v3.3" | tee -a "$LOG"
echo "==================================================" | tee -a "$LOG"

run_check "toolchain" "TOOLCHAIN_RESULT=OK" ./ops/bin/as6-toolchain-check
run_check "git diff check" "" git diff --check
run_check "secret scan" "SECRET_SCAN_RESULT=OK" ./ops/bin/as6-pre-commit-secret-scan
run_check "master screen diagnostic" "AS6_MASTER_SCREEN_V1_DIAGNOSTIC=PASS" bash ops/bin/as6-diagnose-master-screen-v1
run_check "master screen control" "AS6_CONTROL_MASTER_SCREEN_V1=PASS" bash ops/bin/as6-control-master-screen-v1
run_check "frontend production build" "" bash -lc 'cd frontend && NPM_CONFIG_CACHE="${AS6_NPM_CACHE:-/tmp/as6-npm-cache}" npm install --package-lock=false --ignore-scripts --no-audit --no-fund && npm run build'

if [ "$failures" -eq 0 ]; then
  verdict="SAFE_TO_MERGE"
else
  verdict="MERGE_BLOCKED"
fi

cat > "$REPORT" <<JSON
{
  "guardian": "AS6 Architecture Guardian",
  "version": "3.3",
  "verdict": "$verdict",
  "passed": $passed,
  "failures": $failures,
  "report": "$REPORT",
  "log": "$LOG",
  "source": "as6-pr-guardian"
}
JSON

echo | tee -a "$LOG"
echo "==================================================" | tee -a "$LOG"
echo "AS6_GUARDIAN_VERDICT=$verdict" | tee -a "$LOG"
echo "AS6_GUARDIAN_PASSED=$passed" | tee -a "$LOG"
echo "AS6_GUARDIAN_FAILURES=$failures" | tee -a "$LOG"
echo "REPORT=$REPORT" | tee -a "$LOG"
echo "LOG=$LOG" | tee -a "$LOG"
echo "==================================================" | tee -a "$LOG"

if [ "$failures" -ne 0 ]; then
  exit 1
fi
