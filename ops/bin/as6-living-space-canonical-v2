  '- AS6_PROCESS_PATH_REQUIRED_RULE' \
  '- AS6_INTENT_ENTRY_REQUIRED_RULE' \
  '- AS6_FALSE_METRICS_FORBIDDEN_RULE' \
  '- AS6_EMPTY_STATE_MUST_REMAIN_CANONICAL_RULE' \
  > "$AEC"

echo "=== 10. REGISTRY + COVERAGE + GOVERNANCE + STATE ==="
if ! grep -Fq '## AS6 Living Space Canonical v2' "$REGISTRY"; then printf '%s\n' '' '## AS6 Living Space Canonical v2' '- diagnostic: canonical Master Screen inheritance restored across Living Space Engine and Documents real-data space' '- artifacts: frontend/src/living/product-v2/LivingSpaceEngine.jsx, frontend/src/living/product-v2/LivingSpaceEngine.css, frontend/src/living/product-v2/LivingDocumentsSpace.jsx' '- control: ops/bin/as6-control-living-space-canonical-v2' '- result: AS6_LIVING_SPACE_CANONICAL_V2=REGISTERED' >> "$REGISTRY"; fi
if ! grep -Fq '## AS6 Living Space Canonical v2 Coverage' "$COVERAGE"; then printf '%s\n' '' '## AS6 Living Space Canonical v2 Coverage' '- AS6_MASTER_SCREEN_INHERITANCE_COVERAGE=REGISTERED' '- AS6_CANONICAL_CONTEXT_RAILS_COVERAGE=REGISTERED' '- AS6_CANONICAL_GRAPH_COVERAGE=REGISTERED' '- AS6_CANONICAL_PROCESS_PATH_COVERAGE=REGISTERED' '- AS6_CANONICAL_INTENT_ENTRY_COVERAGE=REGISTERED' '- AS6_DOCUMENTS_CANONICAL_REAL_DATA_COVERAGE=REGISTERED' >> "$COVERAGE"; fi
if ! grep -Fq 'AS6_LIVING_SPACE_CANONICAL_V2' "$STATE"; then printf '%s\n' '' '## AS6 Living Space Canonical v2' '- AS6_LIVING_SPACE_CANONICAL_V2=PASS' '- AS6_MASTER_SCREEN_INHERITANCE=PASS' '- AS6_DOCUMENTS_CANONICAL_REAL_DATA=PASS' '- AS6_LIVING_PRODUCT_DATA_READINESS=91%' >> "$STATE"; fi
if ! grep -Fq 'AS6_CANONICAL_LIVING_SPACE_REFERENCE_DRIFT' "$ERRORS"; then printf '%s\n' '' '## AS6 Living Space Canonical v2' '- AS6_CANONICAL_LIVING_SPACE_REFERENCE_DRIFT=FIXED' '- AS6_REAL_DATA_REPLACED_SPATIAL_LANGUAGE=FIXED' '- AS6_DOCUMENTS_NON_CANONICAL_LAYOUT=FIXED' '- AS6_SPACE_ENGINE_LEFT_RIGHT_CONTEXT_GAP=FIXED' '- AS6_SPACE_ENGINE_PROCESS_PATH_GAP=FIXED' '- AS6_SPACE_ENGINE_INTENT_ENTRY_GAP=FIXED' '- AS6_MASTER_SCREEN_INHERITANCE_GAP=FIXED' >> "$ERRORS"; fi
echo "AS6_DIAGNOSTIC_REGISTRY=UPDATED"
echo "AS6_COVERAGE_REGISTRY=UPDATED"
echo "AS6_GOVERNANCE_AEC=UPDATED"
echo "AS6_PROJECT_STATE=UPDATED"
echo "AS6_DETECTED_ERRORS=UPDATED"

echo "=== 11. VALIDATION ==="
npm --prefix frontend run build
npm --prefix backend run test:ai-execution-runner-auth
"$CONTROL"
ops/bin/as6-control-living-documents-real-data-v1
ops/bin/as6-control-living-space-engine-v1
ops/bin/as6-control-living-workspace-v1
ops/bin/as6-control-living-auth-boundary-v1
ops/bin/as6-control-api-upstream-health-v1
