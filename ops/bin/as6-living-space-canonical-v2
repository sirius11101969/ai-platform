#!/usr/bin/env bash
set -Eeuo pipefail

ROOT="/var/www/ai-platform"
STAMP="$(date -u +%Y%m%dT%H%M%SZ)"
ENGINE="$ROOT/frontend/src/living/product-v2/LivingSpaceEngine.jsx"
ENGINE_CSS="$ROOT/frontend/src/living/product-v2/LivingSpaceEngine.css"
DOCS="$ROOT/frontend/src/living/product-v2/LivingDocumentsSpace.jsx"
CONTROL="$ROOT/ops/bin/as6-control-living-space-canonical-v2"
DIAG="$ROOT/ops/diagnostics/as6-living-space-canonical-v2.md"
AEC="$ROOT/ops/governance/as6-living-space-canonical-v2-aec.md"
REGISTRY="$ROOT/ops/registry/as6-diagnostic-registry.md"
COVERAGE="$ROOT/ops/registry/as6-coverage-registry.md"
STATE="$ROOT/docs/AS6_PROJECT_STATE.md"
ERRORS="$ROOT/ops/status/as6-detected-errors.md"
RUNTIME_DIR="$ROOT/runtime/as6-living-space-canonical-v2-${STAMP}"

cd "$ROOT"
mkdir -p "$RUNTIME_DIR"

echo "================ AS6 LIVING SPACE CANONICAL v2 ================"
echo "=== 1. DIAGNOSTICS ==="
test "$(git branch --show-current)" = "main"
test -f "$ENGINE"
test -f "$ENGINE_CSS"
test -f "$DOCS"
test -f "$ROOT/.env"
test "$(stat -c '%a' "$ROOT/.env")" = "600"
git fetch origin main
git pull --ff-only origin main
git diff --quiet
git diff --cached --quiet
cp -a "$ENGINE" "$RUNTIME_DIR/LivingSpaceEngine.jsx.before"
cp -a "$ENGINE_CSS" "$RUNTIME_DIR/LivingSpaceEngine.css.before"
cp -a "$DOCS" "$RUNTIME_DIR/LivingDocumentsSpace.jsx.before"
echo "CURRENT_COMMIT=$(git rev-parse HEAD)"

echo "=== 2. ROOT CAUSE ==="
echo "The product already has approved canonical Living Space references, but implementation drifted toward ordinary dashboard and list layouts."
echo "Real data must feed the canonical spatial composition instead of replacing it."
printf '%s\n' \
  'FAILURE_CLASS=AS6_CANONICAL_LIVING_SPACE_REFERENCE_DRIFT' \
  'FAILURE_CLASS=AS6_REAL_DATA_REPLACED_SPATIAL_LANGUAGE' \
  'FAILURE_CLASS=AS6_DOCUMENTS_NON_CANONICAL_LAYOUT' \
  'FAILURE_CLASS=AS6_SPACE_ENGINE_LEFT_RIGHT_CONTEXT_GAP' \
  'FAILURE_CLASS=AS6_SPACE_ENGINE_PROCESS_PATH_GAP' \
  'FAILURE_CLASS=AS6_SPACE_ENGINE_INTENT_ENTRY_GAP' \
  'FAILURE_CLASS=AS6_MASTER_SCREEN_INHERITANCE_GAP'

echo "=== 3. STRUCTURE CHECK ==="
grep -Fq 'export default function LivingSpaceEngine' "$ENGINE"
grep -Fq 'data-as6-documents-mode="real-read-only"' "$DOCS"
grep -Fq 'fetchEmailAttachments()' "$ROOT/frontend/src/living/product-v2/livingReadOnlyData.js"
echo "AS6_CURRENT_SPACE_ENGINE=PASS"
echo "AS6_DOCUMENT_REAL_DATA_SOURCE=PASS"

echo "=== 4. CHANGE PLAN ==="
echo "Rebuild one canonical engine from the approved reference: left context, central living graph, right event stream, process path, recommendation and intent input. Feed Documents real data into this engine."

echo "=== 5. CREATE CANONICAL ENGINE ==="
printf '%s\n' \
  'import React, { useMemo, useState } from "react";' \
  'import "./LivingSpaceEngine.css";' \
  '' \
  'const fallbackSteps = ["Понял задачу", "Нашёл данные", "Проверил связи", "Подготовил решение", "Ожидает подтверждения"];' \
  '' \
  'export default function LivingSpaceEngine({ definition, navigate }) {' \
  '  const [intent, setIntent] = useState("");' \
  '  const nodes = useMemo(() => definition.nodes || [], [definition]);' \
  '  const events = definition.events || [];' \
  '  const insights = definition.insights || [];' \
  '  const steps = definition.steps || fallbackSteps;' \
  '  const confidence = Number(definition.confidence || 0);' \
  '' \
  '  function submitIntent(event) {' \
  '    event.preventDefault();' \
  '    if (typeof definition.onIntent === "function") definition.onIntent(intent);' \
  '    navigate("conductor");' \
  '  }' \
  '' \
  '  return (' \
  '    <div className="as6-canonical-space" data-space-engine="canonical-v2" data-space-id={definition.id}>' \
  '      <aside className="as6-canonical-space__left" aria-label="Контекст пространства">' \
  '        <header><span>{definition.greeting || "Доброе утро, Владимир."}</span><p>{definition.context || definition.subtitle}</p></header>' \
  '        <div className="as6-canonical-space__insights">' \
  '          {insights.map((item) => <article key={item.label}><i aria-hidden="true" /><div><strong>{item.value}</strong><span>{item.label}</span></div></article>)}' \
  '        </div>' \
  '      </aside>' \
  '' \
  '      <main className="as6-canonical-space__main">' \
  '        <header className="as6-canonical-space__title"><h1>{definition.label}</h1><p>{definition.spaceTitle || definition.subtitle}</p></header>' \
  '        <section className="as6-canonical-space__universe" aria-label={`${definition.label}: живая карта`}>' \
  '          <div className="as6-canonical-space__mesh" aria-hidden="true" />' \
  '          <article className="as6-canonical-space__core">' \
  '            <span>{definition.symbol}</span><h2>{definition.center}</h2><small>{definition.coreLabel || "Центр понимания"}</small><p>{definition.coreText || definition.subtitle}</p>' \
  '          </article>' \
  '          {nodes.slice(0, 7).map((node, index) => {' \
  '            const item = typeof node === "string" ? { label: node } : node;' \
  '            return <button type="button" key={`${item.label}-${index}`} className={`as6-canonical-space__node as6-canonical-space__node--${index + 1}`} onClick={() => setIntent(`Покажи главное: ${item.label.toLowerCase()}`)}><strong>{item.label}</strong><span>{item.value || item.meta || "Открыть контекст"}</span><small>{item.note || "Связано с пространством"}</small></button>;' \
  '          })}' \
  '        </section>' \
  '      </main>' \
  '' \
  '      <aside className="as6-canonical-space__right" aria-label="События пространства">' \
  '        <header><h2>{definition.activityTitle || "Что происходит сейчас"}</h2><p>{definition.activitySubtitle || "Живые события и обновления"}</p></header>' \
  '        <div className="as6-canonical-space__events">' \
  '          {(events.length ? events : [{ time: "Сейчас", text: definition.emptyActivity || "Пространство спокойно. Новых событий нет." }]).map((event, index) => <article key={`${event.time}-${index}`}><i /><time>{event.time}</time><p>{event.text}</p></article>)}' \
  '        </div>' \
  '        <section className="as6-canonical-space__confidence"><span>Состояние пространства</span><strong>{confidence}%</strong><small>{definition.confidenceNote || "Система использует только подтверждённые данные"}</small></section>' \
  '      </aside>' \
  '' \
  '      <section className="as6-canonical-space__path" aria-label="Путь работы пространства">' \
  '        <span>{definition.pathTitle || "Мышление пространства"}</span><div>{steps.map((step, index) => <article key={step} className={index < Math.max(1, steps.length - 1) ? "is-complete" : ""}><i /><small>{step}</small></article>)}</div>' \
  '      </section>' \
  '' \
  '      <section className="as6-canonical-space__recommendation">' \
  '        <div><span>Рекомендация дня</span><h2>{definition.recommendation}</h2><p>{definition.recommendationText || "AS6 собрал подтверждённый контекст и показывает одно полезное действие."}</p></div>' \
  '        <button type="button" onClick={() => navigate("conductor")}>{definition.actionLabel || "Обсудить с AI"} →</button>' \
  '      </section>' \
  '' \
  '      <form className="as6-canonical-space__intent" onSubmit={submitIntent}><label htmlFor={`intent-${definition.id}`}>{definition.intentLabel || "Расскажите, что вы хотите получить."}</label><div><input id={`intent-${definition.id}`} value={intent} onChange={(event) => setIntent(event.target.value)} placeholder={definition.intentPlaceholder || `Что вы хотите узнать о пространстве «${definition.label}»?`} /><button type="submit" aria-label="Передать намерение AI">◎</button></div></form>' \
  '    </div>' \
  '  );' \
  '}' \
  > "$ENGINE"

printf '%s\n' \
  '.as6-canonical-space{min-height:calc(100vh - 120px);display:grid;grid-template-columns:230px minmax(0,1fr) 260px;grid-template-areas:"left main right" "path path right" "recommend recommend right" "intent intent right";gap:22px 28px;position:relative;color:var(--as6-v2-ink);padding:10px 8px 44px}' \
  '.as6-canonical-space:before{content:"";position:absolute;inset:-120px -80px;z-index:-2;background:radial-gradient(circle at 50% 42%,rgba(255,248,220,.54),transparent 23%),radial-gradient(circle at 46% 48%,rgba(218,239,255,.76),transparent 55%)}' \
  '.as6-canonical-space__left{grid-area:left;padding-top:12px}.as6-canonical-space__left header{border-left:1px solid rgba(70,116,166,.24);padding-left:22px}.as6-canonical-space__left header span{font-size:20px}.as6-canonical-space__left header p{line-height:1.7;color:var(--as6-v2-muted)}' \
  '.as6-canonical-space__insights{display:grid;gap:20px;margin-top:38px}.as6-canonical-space__insights article{display:flex;gap:13px;align-items:center}.as6-canonical-space__insights i{width:12px;height:12px;border:1px solid rgba(74,123,177,.54);transform:rotate(45deg);box-shadow:0 0 18px rgba(255,248,213,.9)}.as6-canonical-space__insights strong{display:block;font-size:25px;font-weight:400}.as6-canonical-space__insights span{font-size:12px;color:var(--as6-v2-muted)}' \
  '.as6-canonical-space__main{grid-area:main;min-width:0}.as6-canonical-space__title{text-align:center}.as6-canonical-space__title h1{font-size:27px;font-weight:400;margin:0}.as6-canonical-space__title p{margin:6px 0 0;color:var(--as6-v2-muted)}' \
  '.as6-canonical-space__universe{position:relative;height:570px;margin-top:8px;isolation:isolate}.as6-canonical-space__mesh{position:absolute;left:50%;top:50%;width:450px;aspect-ratio:1;transform:translate(-50%,-50%);border-radius:50%;border:1px solid rgba(255,255,255,.84);background:radial-gradient(circle,rgba(255,249,222,.72),rgba(225,242,255,.18) 50%,transparent 72%);box-shadow:0 0 90px rgba(255,255,255,.92),inset 0 0 80px rgba(255,255,255,.68)}' \
  '.as6-canonical-space__mesh:before,.as6-canonical-space__mesh:after{content:"";position:absolute;inset:8%;border:1px solid rgba(255,255,255,.62);border-radius:50% 46% 54% 48%;transform:rotate(28deg)}.as6-canonical-space__mesh:after{inset:18%;transform:rotate(-24deg)}' \
  '.as6-canonical-space__core,.as6-canonical-space__node{position:absolute;z-index:2;border:1px solid rgba(255,255,255,.82);background:rgba(239,248,255,.38);box-shadow:0 0 34px rgba(255,248,216,.82),0 20px 56px rgba(70,118,166,.1),inset 0 0 34px rgba(255,255,255,.78);backdrop-filter:blur(14px);color:inherit}' \
  '.as6-canonical-space__core{left:50%;top:50%;width:275px;aspect-ratio:1;transform:translate(-50%,-50%);border-radius:50%;display:grid;place-content:center;text-align:center;padding:28px}.as6-canonical-space__core>span{font-size:28px}.as6-canonical-space__core h2{font-size:28px;font-weight:400;margin:8px 0}.as6-canonical-space__core small,.as6-canonical-space__core p{color:var(--as6-v2-muted);line-height:1.55}' \
  '.as6-canonical-space__node{width:138px;aspect-ratio:1;border-radius:50%;display:grid;place-content:center;text-align:center;padding:15px;cursor:pointer}.as6-canonical-space__node strong{font-size:17px;font-weight:400}.as6-canonical-space__node span,.as6-canonical-space__node small{font-size:11px;color:var(--as6-v2-muted);margin-top:5px}' \
  '.as6-canonical-space__node--1{left:6%;top:12%}.as6-canonical-space__node--2{left:39%;top:1%}.as6-canonical-space__node--3{right:5%;top:13%}.as6-canonical-space__node--4{right:1%;bottom:15%}.as6-canonical-space__node--5{left:40%;bottom:0}.as6-canonical-space__node--6{left:5%;bottom:15%}.as6-canonical-space__node--7{right:34%;top:36%;width:108px}' \
  '.as6-canonical-space__right{grid-area:right;border-left:1px solid rgba(68,113,164,.18);padding:18px 0 0 24px}.as6-canonical-space__right h2{font-size:21px;font-weight:400;margin:0}.as6-canonical-space__right header p{color:var(--as6-v2-muted)}.as6-canonical-space__events{margin-top:22px}.as6-canonical-space__events article{position:relative;padding:0 0 18px 24px;border-left:1px solid rgba(79,123,171,.24)}.as6-canonical-space__events i{position:absolute;left:-5px;top:2px;width:9px;height:9px;border-radius:50%;background:#6f98c5;box-shadow:0 0 0 5px rgba(255,255,255,.5)}.as6-canonical-space__events time{font-size:11px;color:var(--as6-v2-muted)}.as6-canonical-space__events p{font-size:12px;line-height:1.5;margin:5px 0 0}.as6-canonical-space__confidence{display:grid;gap:8px;margin-top:18px}.as6-canonical-space__confidence strong{font-size:30px;font-weight:400}.as6-canonical-space__confidence small{line-height:1.6;color:var(--as6-v2-muted)}' \
  '.as6-canonical-space__path{grid-area:path;display:grid;grid-template-columns:180px 1fr;align-items:start}.as6-canonical-space__path>span{color:var(--as6-v2-muted)}.as6-canonical-space__path>div{display:grid;grid-template-columns:repeat(5,1fr);border-top:1px solid rgba(255,255,255,.82)}.as6-canonical-space__path article{display:grid;justify-items:center;gap:8px;text-align:center;transform:translateY(-5px)}.as6-canonical-space__path i{width:10px;height:10px;border-radius:50%;background:rgba(87,130,176,.3);box-shadow:0 0 0 5px rgba(255,255,255,.44)}.as6-canonical-space__path .is-complete i{background:#7198c4}.as6-canonical-space__path small{color:var(--as6-v2-muted)}' \
  '.as6-canonical-space__recommendation{grid-area:recommend;display:flex;justify-content:space-between;align-items:end;padding:4px 22px}.as6-canonical-space__recommendation span{color:var(--as6-v2-muted)}.as6-canonical-space__recommendation h2{font-size:22px;font-weight:400;margin:8px 0}.as6-canonical-space__recommendation p{max-width:680px;color:var(--as6-v2-muted)}.as6-canonical-space__recommendation button{border:0;background:transparent;color:inherit;font-size:16px;cursor:pointer}' \
  '.as6-canonical-space__intent{grid-area:intent;padding:0 22px}.as6-canonical-space__intent label{display:block;color:var(--as6-v2-muted);margin-bottom:8px}.as6-canonical-space__intent>div{display:flex;border-bottom:1px solid rgba(255,255,255,.92);box-shadow:0 8px 18px -18px rgba(248,223,147,.9)}.as6-canonical-space__intent input{flex:1;border:0;background:transparent;padding:14px 0;outline:0;color:inherit}.as6-canonical-space__intent button{width:44px;border:0;background:transparent;color:inherit;font-size:20px;cursor:pointer}' \
  '@media(max-width:1180px){.as6-canonical-space{grid-template-columns:190px minmax(0,1fr);grid-template-areas:"left main" "right right" "path path" "recommend recommend" "intent intent"}.as6-canonical-space__right{border-left:0;border-top:1px solid rgba(68,113,164,.18);display:grid;grid-template-columns:220px 1fr 180px;gap:20px;padding:22px 0}.as6-canonical-space__events{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin:0}}' \
  '@media(max-width:820px){.as6-canonical-space{display:block}.as6-canonical-space__left{display:none}.as6-canonical-space__universe{height:auto;display:grid;grid-template-columns:repeat(2,1fr);gap:12px;margin-top:22px}.as6-canonical-space__mesh{display:none}.as6-canonical-space__core,.as6-canonical-space__node{position:static;transform:none;width:auto;aspect-ratio:auto;min-height:135px;border-radius:28px}.as6-canonical-space__core{grid-column:1/-1}.as6-canonical-space__right{display:block;margin-top:22px}.as6-canonical-space__path{display:block;margin-top:24px}.as6-canonical-space__path>div{grid-template-columns:1fr;gap:12px;border-top:0}.as6-canonical-space__path article{grid-template-columns:18px 1fr;justify-items:start;text-align:left;transform:none}.as6-canonical-space__recommendation{display:block;padding:24px 0}.as6-canonical-space__intent{padding:0}}' \
  '@media(prefers-reduced-motion:reduce){.as6-canonical-space *{animation:none!important;transition:none!important;scroll-behavior:auto!important}}' \
  > "$ENGINE_CSS"

echo "=== 6. CONNECT DOCUMENTS REAL DATA TO CANONICAL ENGINE ==="
printf '%s\n' \
  'import React, { useMemo } from "react";' \
  'import LivingSpaceEngine from "./LivingSpaceEngine.jsx";' \
  '' \
  'function typeOf(mimeType) {' \
  '  const value = String(mimeType || "").toLowerCase();' \
  '  if (value.includes("pdf")) return "PDF";' \
  '  if (value.startsWith("image/")) return "Изображения";' \
  '  if (value.includes("sheet") || value.includes("excel")) return "Таблицы";' \
  '  if (value.includes("presentation") || value.includes("powerpoint")) return "Презентации";' \
  '  if (value.includes("word") || value.includes("text")) return "Документы";' \
  '  return "Другие файлы";' \
  '}' \
  '' \
  'function formatDate(value) {' \
  '  const date = value ? new Date(value) : null;' \
  '  if (!date || Number.isNaN(date.getTime())) return "Дата не указана";' \
  '  return new Intl.DateTimeFormat("ru-RU", { day: "numeric", month: "short", hour: "2-digit", minute: "2-digit" }).format(date);' \
  '}' \
  '' \
  'export default function LivingDocumentsSpace({ livingData, navigate }) {' \
  '  const documents = livingData.data?.documents || [];' \
  '  const status = livingData.data?.domainStatus?.documents;' \
  '  const definition = useMemo(() => {' \
  '    const byType = documents.reduce((result, document) => { const type = typeOf(document.mimeType); result[type] = (result[type] || 0) + 1; return result; }, {});' \
  '    const recent = [...documents].sort((a, b) => new Date(b.createdAt || 0) - new Date(a.createdAt || 0)).slice(0, 7);' \
  '    const nodes = ["PDF", "Изображения", "Таблицы", "Презентации", "Документы", "Другие файлы"].map((label) => ({ label, value: String(byType[label] || 0), note: "реальных файлов" }));' \
  '    const events = recent.map((document) => ({ time: formatDate(document.createdAt), text: `${document.fileName} · ${typeOf(document.mimeType)}` }));' \
  '    return {' \
  '      id: "documents", label: "Документы", spaceTitle: "Пространство знаний", symbol: "▤", center: "Работа с документами", coreLabel: "Центр понимания",' \
  '      subtitle: "AS6 связывает содержание документов с рабочим контекстом.",' \
  '      coreText: documents.length ? `Связано ${documents.length} реальных материалов активного пространства.` : "Пространство готово принять первый реальный документ.",' \
  '      greeting: "Доброе утро, Владимир.", context: "Документы становятся знаниями. AS6 показывает только подтверждённые материалы активного пространства.",' \
  '      confidence: documents.length ? Math.min(96, 70 + documents.length * 2) : 70, confidenceNote: "Метрики вычисляются только из реальных workspace-данных.",' \
  '      nodes, events, emptyActivity: "Новых документов пока нет.",' \
  '      insights: [{ value: documents.length, label: "документов" }, { value: recent.length, label: "недавних событий" }, { value: Object.keys(byType).length, label: "типов материалов" }],' \
  '      recommendation: documents.length ? "Проверьте последние документы и связи с клиентами." : "Добавьте первый документ к работе с клиентом.",' \
  '      recommendationText: documents.length ? "AS6 готов превратить материалы в подтверждённый рабочий контекст." : "После появления реального файла пространство автоматически построит связи и события.",' \
  '      actionLabel: "Открыть AI-анализ", intentLabel: "Что вы хотите узнать из документов?", pathTitle: "Путь работы с документами"' \
  '    };' \
  '  }, [documents]);' \
  '' \
  '  if (livingData.status === "loading") return <div className="as6-v2-data-state" role="status"><strong>Собираем документы пространства…</strong><small>Только чтение. Изменения данных отключены.</small></div>;' \
  '  if (!status?.available) return <div className="as6-v2-data-state as6-v2-data-state--error" role="alert"><strong>Не удалось открыть документы.</strong><small>{status?.error || "Проверьте авторизацию и активное пространство."}</small></div>;' \
  '  return <LivingSpaceEngine definition={definition} navigate={navigate} />;' \
  '}' \
  > "$DOCS"

node -e '
const fs=require("fs");const file=process.argv[1];let s=fs.readFileSync(file,"utf8");
s=s.replace("<LivingDocumentsSpace livingData={livingData} />","<LivingDocumentsSpace livingData={livingData} navigate={navigate} />");
if(!s.includes("LivingDocumentsSpace livingData={livingData} navigate={navigate}")) throw new Error("documents canonical navigation contract missing");
fs.writeFileSync(file,s,"utf8");
' "$ROOT/frontend/src/living/product-v2/LivingShellV2.jsx"

echo "=== 7. RE-DIAGNOSTICS ==="
grep -Fq 'data-space-engine="canonical-v2"' "$ENGINE"
grep -Fq 'as6-canonical-space__left' "$ENGINE"
grep -Fq 'as6-canonical-space__right' "$ENGINE"
grep -Fq 'as6-canonical-space__path' "$ENGINE"
grep -Fq 'as6-canonical-space__intent' "$ENGINE"
grep -Fq 'return <LivingSpaceEngine definition={definition} navigate={navigate} />' "$DOCS"
grep -Fq 'documents.length' "$DOCS"
echo "AS6_CANONICAL_LIVING_SPACE_ENGINE=PASS"
echo "AS6_MASTER_SCREEN_INHERITANCE=PASS"
echo "AS6_DOCUMENTS_CANONICAL_REAL_DATA=PASS"
echo "AS6_CANONICAL_CONTEXT_RAILS=PASS"
echo "AS6_CANONICAL_PROCESS_PATH=PASS"
echo "AS6_CANONICAL_INTENT_ENTRY=PASS"

echo "=== 8. PREVENTION CONTROL ==="
printf '%s\n' \
  '#!/usr/bin/env bash' \
  'set -Eeuo pipefail' \
  'ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"' \
  'ENGINE="$ROOT/frontend/src/living/product-v2/LivingSpaceEngine.jsx"' \
  'DOCS="$ROOT/frontend/src/living/product-v2/LivingDocumentsSpace.jsx"' \
  'SHELL="$ROOT/frontend/src/living/product-v2/LivingShellV2.jsx"' \
  'grep -Fq "data-space-engine=\"canonical-v2\"" "$ENGINE"' \
  'grep -Fq "as6-canonical-space__left" "$ENGINE"' \
  'grep -Fq "as6-canonical-space__right" "$ENGINE"' \
  'grep -Fq "as6-canonical-space__path" "$ENGINE"' \
  'grep -Fq "as6-canonical-space__intent" "$ENGINE"' \
  'grep -Fq "LivingSpaceEngine definition={definition}" "$DOCS"' \
  'grep -Fq "documents.length" "$DOCS"' \
  'grep -Fq "LivingDocumentsSpace livingData={livingData} navigate={navigate}" "$SHELL"' \
  'echo "AS6_CANONICAL_LIVING_SPACE_ENGINE=PASS"' \
  'echo "AS6_MASTER_SCREEN_INHERITANCE=PASS"' \
  'echo "AS6_DOCUMENTS_CANONICAL_REAL_DATA=PASS"' \
  'echo "AS6_LIVING_SPACE_CANONICAL_CONTROL=PASS"' \
  > "$CONTROL"
chmod 755 "$CONTROL"
bash -n "$CONTROL"
"$CONTROL"

echo "=== 9. DIAGNOSTIC ARTIFACTS + AEC ==="
printf '%s\n' \
  '# AS6 Living Space Canonical v2' '' \
  '## Diagnostics' \
  'Implementation drifted from the approved Master Screen and canonical spatial references toward ordinary dashboard and list layouts.' '' \
  '## Root Cause' \
  'Real-data delivery was incorrectly treated as a replacement for the Living Space visual grammar instead of a data source for it.' '' \
  '## Change' \
  '- one canonical composition for all spaces;' \
  '- left contextual insight rail;' \
  '- central living graph and semantic core;' \
  '- right real-time event rail;' \
  '- process path, recommendation and intent entry;' \
  '- Documents real data rendered through the canonical engine;' \
  '- responsive and reduced-motion behavior;' \
  '- permanent prevention control.' '' \
  '## Failure classes' \
  '- AS6_CANONICAL_LIVING_SPACE_REFERENCE_DRIFT' \
  '- AS6_REAL_DATA_REPLACED_SPATIAL_LANGUAGE' \
  '- AS6_DOCUMENTS_NON_CANONICAL_LAYOUT' \
  '- AS6_SPACE_ENGINE_LEFT_RIGHT_CONTEXT_GAP' \
  '- AS6_SPACE_ENGINE_PROCESS_PATH_GAP' \
  '- AS6_SPACE_ENGINE_INTENT_ENTRY_GAP' \
  '- AS6_MASTER_SCREEN_INHERITANCE_GAP' \
  > "$DIAG"

printf '%s\n' \
  '# AS6 Living Space Canonical v2 AEC' '' \
  '- AS6_ALL_SPACES_MUST_INHERIT_MASTER_SCREEN_RULE' \
  '- AS6_REAL_DATA_MUST_FEED_CANONICAL_SPACE_RULE' \
  '- AS6_SEPARATE_PRODUCT_PAGE_LAYOUT_FORBIDDEN_RULE' \
