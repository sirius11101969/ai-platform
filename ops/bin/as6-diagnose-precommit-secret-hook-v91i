#!/usr/bin/env bash
set -euo pipefail

test -f .git/hooks/pre-commit || { echo "AS6_PRECOMMIT_SECRET_HOOK_V91I=FAIL hook_missing"; exit 1; }

grep -q "git diff --cached -U0" .git/hooks/pre-commit ops/bin/as6-pre-commit-push-enforcement 2>/dev/null || {
  echo "AS6_PRECOMMIT_SECRET_HOOK_V91I=FAIL zero_context_diff_missing"
  exit 1
}

echo "AS6_PRECOMMIT_SECRET_HOOK_REPAIR_V91I=PASS"
