#!/usr/bin/env bash
set -euo pipefail
cd "${AS6_REPO_ROOT:-$(git rev-parse --show-toplevel 2>/dev/null || pwd)}"
echo "=== AS6 Generated Python Runtime Contract Diagnostics ==="
helper="ops/lib/as6-generated-python-runtime-contract-check.py"
if [ -s "$helper" ]; then echo "AS6_GENERATED_PYTHON_RUNTIME_CONTRACT_HELPER=PASS:$helper"; else echo "AS6_GENERATED_PYTHON_RUNTIME_CONTRACT_HELPER=FAIL:$helper"; exit 1; fi
python3 "$helper"
