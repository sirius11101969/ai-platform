#!/usr/bin/env bash
set -euo pipefail
ROOT="${AS6_REPO_ROOT:-$(git rev-parse --show-toplevel 2>/dev/null || pwd)}"
cd "$ROOT"
files=(frontend/src/pages/CommandCenterPage.jsx frontend/src/components/AppShell.jsx frontend/src/theme/as6Theme.css frontend/src/App.jsx ops/bin/as6-diagnose-command-center)
pattern='(OPENAI_API_KEY|SECRET_KEY|BEGIN RSA PRIVATE KEY|BEGIN OPENSSH PRIVATE KEY|AKIA[0-9A-Z]{16})'
if rg -n "$pattern" "${files[@]}"; then
  echo 'AS6_SECRET_SCAN_RESULT=FAIL'
  exit 1
fi
echo 'AS6_SECRET_SCAN_RESULT=OK'
