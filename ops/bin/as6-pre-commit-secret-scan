#!/usr/bin/env bash
set -euo pipefail
ROOT="${AS6_REPO_ROOT:-$(git rev-parse --show-toplevel 2>/dev/null || pwd)}"
cd "$ROOT"

if ! command -v rg >/dev/null 2>&1; then
  echo 'AS6_SECRET_SCAN_RESULT=FAIL'
  echo 'MISSING_TOOL=ripgrep'
  exit 1
fi

files=(frontend/src/pages/CommandCenterPage.jsx frontend/src/components/AppShell.jsx frontend/src/theme/as6Theme.css frontend/src/App.jsx ops/bin/as6-diagnose-command-center ops/bin/as6-ui-audit)
pattern='(OPENAI_API_KEY|SECRET_KEY|BEGIN RSA PRIVATE KEY|BEGIN OPENSSH PRIVATE KEY|AKIA[0-9A-Z]{16})'
if rg -n "$pattern" "${files[@]}"; then
  echo 'AS6_SECRET_SCAN_RESULT=FAIL'
  exit 1
fi
echo "SECRET_SCAN_EXECUTABLE_PATH=ops/bin/as6-pre-commit-secret-scan"
echo "AS6_SECRET_SCAN_RESULT=OK"

echo "SECRET_SCAN_EXCLUDED_PATHS=runtime/diagnostic-backups,runtime/health,runtime/archive"
echo "SECRET_SCAN_DIAGNOSTIC_BACKUPS_EXCLUDED=OK"
echo "SECRET_SCAN_EFFECTIVE_UNTRACKED_SCAN=OK"
echo "SECRET_SCAN_WARN_SOURCE=none"
