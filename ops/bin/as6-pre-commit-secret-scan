#!/usr/bin/env bash
set -euo pipefail
cd "${AS6_REPO_ROOT:-$(git rev-parse --show-toplevel 2>/dev/null || pwd)}"
echo "=== AS6 PRE-COMMIT SECRET SCAN ==="
warn=0
echo "--- checking .env protection ---"
env_status="$(git diff --cached --name-status -- .env 2>/dev/null || true)"
if printf "%s\n" "$env_status" | grep -qE "^(A|M|R|C)[[:space:]]"; then
  echo "BLOCK: .env content is staged. Values are hidden."
  warn=1
elif printf "%s\n" "$env_status" | grep -qE "^D[[:space:]]"; then
  echo "AS6_ENV_STAGED_DELETION_ALLOWED=PASS:.env"
else
  echo "PASS: .env is not staged"
fi
echo "--- checking tracked/staged additions safely ---"
files="$(git diff --cached --name-only --diff-filter=ACMR | grep -Ev "^\.env$|^runtime/|^docs/|^ops/governance/|^ops/status/|^ops/bin/as6-pre-commit-secret-scan$|^ops/bin/as6-diagnose-env-contract$|^ops/bin/as6-diagnose-constitution$|^ops/bin/as6-diagnose-all$" || true)"
if [ -n "$files" ]; then
  hit=0
  while IFS= read -r f; do
    [ -n "$f" ] || continue
    git diff --cached -- "$f" 2>/dev/null | grep -Eai "^\+.*(secret|password|token|api[_-]?key|private[_-]?key)[^[:space:]]*[=:][^[:space:]]{8,}" >/dev/null 2>&1 && hit=1
  done <<EOF
$files
EOF
  if [ "$hit" -eq 1 ]; then
    echo "BLOCK: possible secret values found in staged additions. Values are hidden."
    warn=1
  else
    echo "PASS: no obvious secret values in staged additions"
  fi
else
  echo "PASS: no staged added/modified files to scan"
fi
echo "--- checking untracked files safely ---"
tmp="/tmp/as6-secret-scan-untracked.$$"
git ls-files --others --exclude-standard > "$tmp" || true
hit=0
while IFS= read -r f; do
  [ -f "$f" ] || continue
  case "$f" in runtime/*|node_modules/*|coverage/*|dist/*|build/*) continue ;; esac
  grep -Eai "(secret|password|token|api[_-]?key|private[_-]?key)[^[:space:]]*[=:][^[:space:]]{8,}" "$f" >/dev/null 2>&1 && hit=1
done < "$tmp"
rm -f "$tmp" 2>/dev/null || true
if [ "$hit" -eq 1 ]; then
  echo "BLOCK: possible secret values found in untracked files. Values are hidden."
  warn=1
else
  echo "PASS: no obvious secret values in untracked files"
fi
if [ "$warn" -eq 0 ]; then
  echo
  echo "SECRET_SCAN_RESULT=OK"
  echo "AS6_SECRET_SCAN_RESULT=OK"
  echo "SECRET_SCAN_WARN_SOURCE=none"
  exit 0
fi
echo
echo "SECRET_SCAN_RESULT=BLOCK"
echo "AS6_SECRET_SCAN_RESULT=BLOCK"
exit 1
