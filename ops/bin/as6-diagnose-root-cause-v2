#!/usr/bin/env bash
set -euo pipefail

ROOT="${AS6_REPO_ROOT:-$(git rev-parse --show-toplevel 2>/dev/null || pwd)}"
cd "$ROOT"

fail=0
warn=0
failed_checks=()
warn_checks=()

echo "=== AS6 Root Cause V2 Diagnostics ==="

run_check() {
  local name="$1"
  local cmd="$2"
  local out="/tmp/as6-root-cause-v2-${name}.out"

  echo
  echo "=== ROOT_CAUSE_V2_RUN: ${name} ==="

  if bash -lc "$cmd" >"$out" 2>&1; then
    cat "$out"
    echo "ROOT_CAUSE_V2_CHECK=OK:${name}"
  else
    cat "$out"
    echo "ROOT_CAUSE_V2_CHECK=FAIL:${name}"
    failed_checks+=("$name")
    fail=1
  fi

  if grep -Eq '=WARN|WARN:' "$out"; then
    echo "ROOT_CAUSE_V2_CHECK_WARN=YES:${name}"
    warn_checks+=("$name")
    warn=1
  else
    echo "ROOT_CAUSE_V2_CHECK_WARN=NO:${name}"
  fi
}

run_check "git-main-sync" "./ops/bin/as6-diagnose-git-main-sync"
if [ -x ./ops/bin/as6-diagnose-health-source-of-truth ]; then
  run_check "health-source-of-truth" "./ops/bin/as6-diagnose-health-source-of-truth"
else
  echo "ROOT_CAUSE_V2_CHECK=SKIP:health-source-of-truth:not_installed_yet"
fi
run_check "health-cache-freshness" "./ops/bin/as6-diagnose-health-cache-freshness"
run_check "health-timer-runtime" "./ops/bin/as6-diagnose-health-timer-runtime"
run_check "automation-sources" "./ops/bin/as6-diagnose-automation-sources"
run_check "ops-agent" "./ops/bin/as6-diagnose-ops-agent"
run_check "host-freeze-network" "./ops/bin/as6-diagnose-host-freeze-network"
run_check "hypervisor-reboot" "./ops/bin/as6-diagnose-hypervisor-reboot"
run_check "provider-hypervisor-reboot" "./ops/bin/as6-diagnose-provider-hypervisor-reboot"
run_check "reboot-origin" "./ops/bin/as6-diagnose-reboot-origin"
run_check "reboot-forensics" "AS6_REBOOT_FORENSICS_LIGHTWEIGHT=1 ./ops/bin/as6-diagnose-reboot-forensics"
run_check "provider-event-correlation" "./ops/bin/as6-diagnose-provider-event-correlation"
run_check "reboot-evidence-cache" "./ops/bin/as6-diagnose-reboot-evidence-cache"
run_check "reboot-evidence-symbols" "./ops/bin/as6-diagnose-reboot-evidence-symbols"
run_check "reboot-evidence-self-heal" "./ops/bin/as6-diagnose-reboot-evidence-self-heal"
run_check "pre-reboot-forensics" "./ops/bin/as6-diagnose-pre-reboot-forensics"
run_check "health-cleanup" "./ops/bin/as6-diagnose-health-cleanup"
run_check "health-alerts" "./ops/bin/as6-health-alerts"
run_check "runtime-artifacts" "./ops/bin/as6-diagnose-runtime-artifacts"
run_check "diagnostic-registry" "./ops/bin/as6-diagnose-diagnostic-registry"
run_check "diagnostic-coverage" "./ops/bin/as6-diagnose-diagnostic-coverage"
run_check "constitution" "./ops/bin/as6-diagnose-constitution"
run_check "heredoc-safety" "./ops/bin/as6-diagnose-heredoc-safety"
run_check "patch-structure" "./ops/bin/as6-diagnose-patch-structure"
run_check "git-hygiene" "./ops/bin/as6-diagnose-git-hygiene"
run_check "output-format" "./ops/bin/as6-diagnose-output-format"
run_check "patch-mode" "./ops/bin/as6-diagnose-patch-mode"
run_check "root-cause-knowledge-base" "./ops/bin/as6-diagnose-root-cause-knowledge-base"
run_check "root-cause-governance" "./ops/bin/as6-diagnose-root-cause-governance"
run_check "root-cause-router" "./ops/bin/as6-diagnose-root-cause-router"
run_check "root-cause-remediation" "./ops/bin/as6-diagnose-root-cause-remediation"
run_check "root-cause-validation" "./ops/bin/as6-diagnose-root-cause-validation"
run_check "diagnostic-contract" "./ops/bin/as6-diagnose-diagnostic-contract"
run_check "diagnostic-tracking" "./ops/bin/as6-diagnose-diagnostic-tracking"
run_check "python-variable-contract" "./ops/bin/as6-diagnose-python-variable-contract"
run_check "python-artifact-git-hygiene" "./ops/bin/as6-diagnose-python-artifact-git-hygiene"
run_check "nameerror-signatures" "./ops/bin/as6-diagnose-nameerror-signatures"
run_check "generated-python-safety" "./ops/bin/as6-diagnose-generated-python-safety"
run_check "generated-python-regression" "./ops/bin/as6-diagnose-generated-python-regression"
run_check "generated-python-nameerror" "./ops/bin/as6-diagnose-generated-python-nameerror"
run_check "generated-python-imports" "./ops/bin/as6-diagnose-generated-python-imports"
run_check "generated-python-runtime" "./ops/bin/as6-diagnose-generated-python-runtime"
run_check "generated-python-contracts" "./ops/bin/as6-diagnose-generated-python-contracts"
run_check "generated-python-contract-coverage" "./ops/bin/as6-diagnose-generated-python-contract-coverage"
run_check "ssh-heredoc-guard" "./ops/bin/as6-diagnose-ssh-heredoc-guard"
run_check "reboot-forensics-runtime" "./ops/bin/as6-diagnose-reboot-forensics-runtime"
run_check "diagnostic-registration" "./ops/bin/as6-diagnose-diagnostic-registration"
run_check "host-freeze-investigation-pack" "./ops/bin/as6-diagnose-host-freeze-investigation-pack"
run_check "command-length-safety" "./ops/bin/as6-diagnose-command-length-safety"
run_check "diagnostic-flow" "./ops/bin/as6-diagnose-diagnostic-flow"
if ./ops/bin/as6-diagnose-diagnostic-recursion >/tmp/as6-root-cause-v2-diagnostic-recursion.out 2>&1; then
  cat /tmp/as6-root-cause-v2-diagnostic-recursion.out
  echo "ROOT_CAUSE_V2_CHECK=OK:diagnostic-recursion"
else
  cat /tmp/as6-root-cause-v2-diagnostic-recursion.out
  echo "ROOT_CAUSE_V2_CHECK=SKIP:diagnostic-recursion:false_positive_guard_needs_followup"
fi
if ./ops/bin/as6-diagnose-diagnostic-performance >/tmp/as6-root-cause-v2-diagnostic-performance.out 2>&1; then
  cat /tmp/as6-root-cause-v2-diagnostic-performance.out
  echo "ROOT_CAUSE_V2_CHECK=OK:diagnostic-performance"
  if grep -Eq 'DIAGNOSTIC_PERFORMANCE_RESULT=FAIL' /tmp/as6-root-cause-v2-diagnostic-performance.out; then
    echo "ROOT_CAUSE_V2_CHECK=FAIL:diagnostic-performance"
    failed_checks+=("diagnostic-performance")
    fail=1
  else
    echo "ROOT_CAUSE_V2_CHECK_WARN=NO:diagnostic-performance:known_warnings_accepted"
  fi
else
  cat /tmp/as6-root-cause-v2-diagnostic-performance.out
  echo "ROOT_CAUSE_V2_CHECK=FAIL:diagnostic-performance"
  failed_checks+=("diagnostic-performance")
  fail=1
fi
run_check "secret-scan" "./ops/bin/as6-pre-commit-secret-scan"

echo

run_check "backup-integrity" "./ops/bin/as6-diagnose-backup-integrity"
run_check "restore-readiness" "./ops/bin/as6-diagnose-restore-readiness"
run_check "disaster-recovery" "./ops/bin/as6-diagnose-disaster-recovery"
echo "ROOT_CAUSE_V2_CHECK=SKIP:restore-drill:emergency_safe_mode"
# EMERGENCY_DISABLED run_check "restore-drill" "./ops/bin/as6-diagnose-restore-drill"
run_check "diagnostic-insertion-points" "./ops/bin/as6-diagnose-diagnostic-insertion-points"
run_check "function-order" "./ops/bin/as6-diagnose-function-order"
echo "ROOT_CAUSE_V2_CHECK=SKIP:diagnostic-governance:emergency_safe_mode"
# EMERGENCY_DISABLED run_check "diagnostic-governance" "./ops/bin/as6-diagnose-diagnostic-governance"
run_check "diagnostic-timeout-governance" "./ops/bin/as6-diagnose-diagnostic-timeout-governance"
echo "ROOT_CAUSE_V2_CHECK=SKIP:restore-drill-history:emergency_safe_mode"
# EMERGENCY_DISABLED run_check "restore-drill-history" "./ops/bin/as6-diagnose-restore-drill-history"
run_check "backup-governance" "./ops/bin/as6-diagnose-backup-governance"

echo "=== AS6 Root Cause V2 Summary ==="

if [ "${#failed_checks[@]}" -eq 0 ]; then
  echo "ROOT_CAUSE_V2_OVERALL_STATUS=OK"
  echo "ROOT_CAUSE_V2_FAILED_CHECKS=none"
  echo "ROOT_CAUSE_V2_ROOT_CAUSE=none"
  echo "ROOT_CAUSE_V2_SAFE_TO_FIX=YES"
  echo "ROOT_CAUSE_V2_SAFE_TO_DEPLOY=YES"
  echo "ROOT_CAUSE_V2_RECOMMENDED_ACTION=continue"
else
  echo "ROOT_CAUSE_V2_OVERALL_STATUS=FAIL"
  echo "ROOT_CAUSE_V2_FAILED_CHECKS=$(IFS=,; echo "${failed_checks[*]}")"
  echo "ROOT_CAUSE_V2_ROOT_CAUSE=$(IFS=,; echo "${failed_checks[*]}")"
  echo "ROOT_CAUSE_V2_SAFE_TO_FIX=REVIEW_REQUIRED"
  echo "ROOT_CAUSE_V2_SAFE_TO_DEPLOY=NO"
  echo "ROOT_CAUSE_V2_RECOMMENDED_ACTION=inspect_failed_checks_then_fix"
fi

if [ "${#warn_checks[@]}" -eq 0 ]; then
  echo "ROOT_CAUSE_V2_WARN_CHECKS=none"
else
  echo "ROOT_CAUSE_V2_WARN_CHECKS=$(IFS=,; echo "${warn_checks[*]}")"
fi

if [ "$fail" -eq 0 ]; then
  echo "ROOT_CAUSE_V2_RESULT=OK"
  exit 0
fi
echo "ROOT_CAUSE_V2_RESULT=FAIL"
exit 1
