#!/usr/bin/env bash
set -euo pipefail

test -f docs/portfolio/as6-portfolio-registry.md
test -f docs/portfolio/as6-next-major-epic-selection.md
test -f docs/epic010/as6-epic010-workspace-experience-planning-entry.md

grep -q "EPIC_ID=AS6_EPIC010_WORKSPACE_EXPERIENCE" docs/portfolio/as6-portfolio-registry.md
grep -q "OWNING_BASELINE=AS6_OPERATING_SYSTEM_V1" docs/portfolio/as6-portfolio-registry.md
grep -q "AFFECTED_COMPONENTS=" docs/portfolio/as6-portfolio-registry.md
grep -q "IMPLEMENTATION_STATUS=NOT_AUTHORIZED" docs/portfolio/as6-portfolio-registry.md
grep -q "IMPLEMENTATION_AUTHORIZED=FALSE" docs/portfolio/as6-next-major-epic-selection.md
grep -q "NEXT_STAGE=AS6_EPIC010_WORKSPACE_EXPERIENCE_PLANNING" docs/portfolio/as6-next-major-epic-selection.md

echo AS6_NEXT_MAJOR_EPIC_SELECTION_DIAGNOSTIC=PASS
