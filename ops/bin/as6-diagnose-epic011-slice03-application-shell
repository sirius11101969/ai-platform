#!/usr/bin/env bash
set -euo pipefail

test -f frontend/src/as6os/applicationShell/applicationShellContract.js
test -f frontend/src/as6os/applicationShell/applicationShellRegistry.js
test -f frontend/src/as6os/applicationShell/applicationShellResolver.js
