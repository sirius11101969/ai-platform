#!/usr/bin/env bash
set -euo pipefail
cd /var/www/ai-platform
fail=0
warn=0
dir="runtime/root-cause-deduplication"
mkdir -p "$dir"
out="$dir/latest.out"
map="$dir/root-cause-map.tsv"
aliases="$dir/root-cause-aliases.tsv"
dups="$dir/root-cause-duplicates.tsv"
orphans="$dir/root-cause-orphans.tsv"
summary="$dir/root-cause-summary.env"
: > "$out"
: > "$map"
: > "$aliases"
: > "$dups"
: > "$orphans"
: > "$summary"
say(){ echo "$1" | tee -a "$out"; }
ok(){ say "PASS: $1"; }
soft(){ say "WARN: $1"; warn=1; }
bad(){ say "FAIL: $1"; fail=1; }

say "=== AS6 AUTONOMOUS ROOT CAUSE DEDUPLICATION CONTROLLER ==="

say "--- catalog discovery ---"
catalog=""
for f in ops/governance/as6-root-cause-catalog.md docs/governance/as6-root-cause-catalog.md docs/AS6_PROJECT_STATE.md; do
  if [ -f "$f" ]; then catalog="$catalog $f"; fi
done
if [ -n "$catalog" ]; then ok "root cause source files discovered:$catalog"; else bad "no root cause source file discovered"; fi

say "--- root cause class extraction ---"
printf "%s\t%s\t%s\n" "class" "normalized" "source" > "$map"
for f in $catalog ops/registry/*.md docs/governance/*.md docs/diagnostics/*.md docs/coverage/*.md; do
  [ -f "$f" ] || continue
  grep -Eo "[A-Z][A-Z0-9_]{5,}" "$f" | while read -r cls; do
    case "$cls" in AS6|PASS|FAIL|WARN|OK|YES|NO|UTC|LTS|VPS|API|AEC) continue ;; esac
    norm="$(printf "%s" "$cls" | sed -E "s/^(AS6_|AEC_)//; s/_(MISSING|DRIFT|FAILED|FAIL|GAP|VIOLATION|REQUIRED|FORBIDDEN|NONE|OK|PASS)$//")"
    printf "%s\t%s\t%s\n" "$cls" "$norm" "$f"
  done
done | sort -u >> "$map"
count="$(tail -n +2 "$map" | wc -l | tr -d " ")"
say "ROOT_CAUSE_DEDUP_CLASS_REFERENCE_COUNT=$count"
if [ "$count" -gt 0 ]; then ok "root cause references extracted"; else bad "no root cause references extracted"; fi

say "--- duplicate detection ---"
printf "%s\t%s\n" "class" "count" > "$dups"
tail -n +2 "$map" | cut -f1 | sort | uniq -c | awk "$1 > 1 {print $2 \"\t\" $1}" >> "$dups" || true
dup_count="$(tail -n +2 "$dups" | wc -l | tr -d " ")"
say "ROOT_CAUSE_DUPLICATE_REFERENCE_COUNT=$dup_count"
ok "duplicate reference scan completed"

say "--- alias and overlap detection ---"
printf "%s\t%s\t%s\n" "normalized" "count" "classes" > "$aliases"
tail -n +2 "$map" | awk -F "\t" "{a[\$2]=a[\$2]\",\"$1; c[\$2]++} END {for (k in c) if (c[k] > 1) print k \"\t\" c[k] \"\t\" a[k]}" | sort >> "$aliases" || true
alias_count="$(tail -n +2 "$aliases" | wc -l | tr -d " ")"
say "ROOT_CAUSE_ALIAS_GROUP_COUNT=$alias_count"
if [ "$alias_count" -gt 0 ]; then soft "alias/overlap groups detected for review"; else ok "no alias/overlap groups detected"; fi

say "--- orphan class detection ---"
printf "%s\t%s\n" "class" "reason" > "$orphans"
tail -n +2 "$map" | cut -f1 | sort -u | while read -r cls; do
  if grep -Rqs "$cls" ops/registry docs/diagnostics docs/coverage docs/governance docs/AS6_PROJECT_STATE.md 2>/dev/null; then
    true
  else
    printf "%s\t%s\n" "$cls" "not linked in registry/docs" >> "$orphans"
  fi
done
orphan_count="$(tail -n +2 "$orphans" | wc -l | tr -d " ")"
say "ROOT_CAUSE_ORPHAN_COUNT=$orphan_count"
if [ "$orphan_count" -eq 0 ]; then ok "no orphan root cause classes detected"; else soft "orphan candidates detected for review"; fi

say "--- governance consistency gates ---"
if [ -x ops/bin/as6-diagnose-root-cause-knowledge-base ]; then if ops/bin/as6-diagnose-root-cause-knowledge-base >> "$out" 2>&1; then ok "root cause knowledge base gate"; else bad "root cause knowledge base gate failed"; fi; else soft "knowledge base diagnostic missing"; fi
if [ -x ops/bin/as6-diagnose-root-cause-governance ]; then if ops/bin/as6-diagnose-root-cause-governance >> "$out" 2>&1; then ok "root cause governance gate"; else bad "root cause governance gate failed"; fi; else soft "governance diagnostic missing"; fi

say "--- secret safety ---"
if git ls-files .env 2>/dev/null | grep -Fxq ".env"; then bad ".env is tracked by git"; else ok ".env is not tracked by git"; fi
if [ -x ops/bin/as6-pre-commit-secret-scan ]; then if ops/bin/as6-pre-commit-secret-scan >> "$out" 2>&1; then ok "secret scan"; else bad "secret scan failed"; fi; else soft "secret scan missing"; fi

printf "%s\n" "AS6_ROOT_CAUSE_DEDUP_REFERENCE_COUNT=$count" "AS6_ROOT_CAUSE_DEDUP_DUPLICATE_REFERENCE_COUNT=$dup_count" "AS6_ROOT_CAUSE_DEDUP_ALIAS_GROUP_COUNT=$alias_count" "AS6_ROOT_CAUSE_DEDUP_ORPHAN_COUNT=$orphan_count" "AS6_ROOT_CAUSE_DEDUP_MAP=$map" "AS6_ROOT_CAUSE_DEDUP_ALIASES=$aliases" "AS6_ROOT_CAUSE_DEDUP_DUPLICATES=$dups" "AS6_ROOT_CAUSE_DEDUP_ORPHANS=$orphans" "AS6_ROOT_CAUSE_DEDUP_EVIDENCE=$out" > "$summary"
ok "summary generated: $summary"

say "--- result ---"
if [ "$fail" -eq 0 ]; then
  say "AS6_ROOT_CAUSE_DEDUPLICATION=PASS"
  [ "$warn" -eq 1 ] && say "AS6_ROOT_CAUSE_DEDUPLICATION_WARNINGS=PRESENT" || say "AS6_ROOT_CAUSE_DEDUPLICATION_WARNINGS=NONE"
  say "AS6_ROOT_CAUSE_DEDUPLICATION_RESULT=OK"
else
  say "AS6_ROOT_CAUSE_DEDUPLICATION=FAIL"
  say "AS6_ROOT_CAUSE_DEDUPLICATION_RESULT=FAIL"
fi
say "AS6_ROOT_CAUSE_DEDUPLICATION_EVIDENCE=$out"
exit "$fail"
