#!/usr/bin/env bash
set -euo pipefail
cd "${AS6_REPO_ROOT:-$(git rev-parse --show-toplevel 2>/dev/null || pwd)}"
echo "=== AS6 Host Freeze Investigation Pack Diagnostics ==="
fail=0
required_files="ops/bin/as6-diagnose-host-freeze-network ops/bin/as6-diagnose-provider-event-correlation ops/bin/as6-diagnose-provider-hypervisor-reboot ops/bin/as6-diagnose-pre-reboot-forensics ops/bin/as6-diagnose-reboot-evidence-cache ops/bin/as6-reboot-evidence-cache ops/bin/as6-reboot-forensics-snapshot"
for f in $required_files; do if [ -s "$f" ]; then echo "AS6_HOST_FREEZE_ARTIFACT=PASS:$f"; else echo "AS6_HOST_FREEZE_ARTIFACT=FAIL:$f"; fail=1; fi; done
if [ -d runtime/pre-reboot-forensics ] || systemctl list-timers --all 2>/dev/null | grep -q "as6-pre-reboot-forensics"; then echo "AS6_PRE_REBOOT_CAPTURE=PASS"; else echo "AS6_PRE_REBOOT_CAPTURE=WARN:not_installed_or_no_runtime_dir"; fi
if [ -d runtime/reboot-forensics ] || [ -s runtime/reboot-forensics/provider-correlation.json ]; then echo "AS6_REBOOT_EVIDENCE_CACHE=PASS"; else echo "AS6_REBOOT_EVIDENCE_CACHE=WARN:not_created_yet"; fi
echo "AS6_HOST_FREEZE_ROOT_CAUSE_CLASSES=HOST_FREEZE_SSH_DROP,PROVIDER_HYPERVISOR_REBOOT,NETWORK_BLACKHOLE,PRE_REBOOT_EVIDENCE_MISSING,OVERSIZED_SINGLE_LINE_PATCH"
echo "AS6_HOST_FREEZE_CONTROLS=pre_reboot_capture,reboot_evidence_cache,provider_event_correlation,ssh_stability_probe,max_command_length"
if [ "$fail" -eq 0 ]; then echo "AS6_HOST_FREEZE_INVESTIGATION_PACK=PASS"; echo "AS6_HOST_FREEZE_INVESTIGATION_RESULT=OK"; exit 0; fi
echo "AS6_HOST_FREEZE_INVESTIGATION_PACK=FAIL"; echo "AS6_HOST_FREEZE_INVESTIGATION_RESULT=FAIL"; exit 1
