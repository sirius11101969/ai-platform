#!/usr/bin/env bash
set -euo pipefail

ROOT="${AS6_REPO_ROOT:-$(git rev-parse --show-toplevel 2>/dev/null || pwd)}"
cd "$ROOT"

fail=0

echo "=== AS6 Diagnostic Recursion Guard ==="

if grep -q 'as6-post-merge-validation' ops/bin/as6-diagnose-all 2>/dev/null; then
  echo "DIAGNOSTIC_RECURSION_AGGREGATOR_POST_MERGE=FAIL:diagnose_all_calls_post_merge_validation"
  fail=1
else
  echo "DIAGNOSTIC_RECURSION_AGGREGATOR_POST_MERGE=OK"
fi

if grep -q 'as6-platform-command-center' ops/bin/as6-health-cache 2>/dev/null; then
  echo "DIAGNOSTIC_RECURSION_HEALTH_CACHE_NO_COMMAND_CENTER=FAIL:ops/bin/as6-health-cache"
  fail=1
else
  echo "DIAGNOSTIC_RECURSION_HEALTH_CACHE_NO_COMMAND_CENTER=OK"
fi

if grep -q "as6-health-cache')" ops/bin/as6-health-status 2>/dev/null; then
  echo "DIAGNOSTIC_RECURSION_STATUS_NO_CACHE_REFRESH=FAIL:ops/bin/as6-health-status"
  fail=1
else
  echo "DIAGNOSTIC_RECURSION_STATUS_NO_CACHE_REFRESH=OK"
fi

if grep -RIn 'run_check "post-merge-validation"' ops/bin/as6-diagnose-all 2>/dev/null; then
  echo "DIAGNOSTIC_RECURSION_DIAGNOSE_ALL_NESTED=FAIL"
  fail=1
else
  echo "DIAGNOSTIC_RECURSION_DIAGNOSE_ALL_NESTED=OK"
fi

if [ "$fail" -eq 0 ]; then
  echo "DIAGNOSTIC_RECURSION_RESULT=OK"
  exit 0
fi

echo "DIAGNOSTIC_RECURSION_RESULT=FAIL"
exit 1
