#!/usr/bin/env bash
set -euo pipefail

ROOT="${AS6_REPO_ROOT:-$(git rev-parse --show-toplevel 2>/dev/null || pwd)}"
cd "$ROOT"

fail=0

echo "=== AS6 Diagnostic Recursion Guard ==="

real_exec_hits() {
  local file="$1"
  local pattern="$2"

  grep -En "$pattern" "$file" 2>/dev/null \
    | grep -v 'NEXT_COMMAND' \
    | grep -v 'next_command' \
    | grep -v 'RECOMMENDED_ACTION' \
    | grep -v 'RECOMMENDED_COMMAND' \
    | grep -v 'echo ' \
    | grep -v 'print(' \
    | grep -v 'grep -' \
    | grep -v 'cat >' \
    | grep -v 'text = ' \
    || true
}

check_no_real_exec() {
  local label="$1"
  local file="$2"
  local pattern="$3"

  if [ ! -f "$file" ]; then
    echo "${label}=FAIL:file_missing:$file"
    fail=1
    return
  fi

  hits="$(real_exec_hits "$file" "$pattern")"

  if [ -n "$hits" ]; then
    echo "${label}=FAIL:$file"
    echo "$hits"
    fail=1
  else
    echo "${label}=OK"
  fi
}

# health-cache is allowed to call command-center once as its data source.
# It must not call owner-dashboard/root-cause/diagnose-all directly.
check_no_real_exec \
  "DIAGNOSTIC_RECURSION_HEALTH_CACHE_NO_HEAVY_LOOP" \
  "ops/bin/as6-health-cache" \
  '(^|[ ;|&])(\./)?ops/bin/(as6-owner-dashboard|as6-root-cause|as6-root-cause-report|as6-diagnose-all)([[:space:]]|>|$)'

check_no_real_exec \
  "DIAGNOSTIC_RECURSION_ALERTS_NO_CACHE_REFRESH" \
  "ops/bin/as6-health-alerts" \
  '(^|[ ;|&])(\./)?ops/bin/(as6-health-cache|as6-diagnose-all|as6-platform-command-center|as6-owner-dashboard)([[:space:]]|>|$)'

check_no_real_exec \
  "DIAGNOSTIC_RECURSION_TREND_NO_ALERTS" \
  "ops/bin/as6-health-trend" \
  '(^|[ ;|&])(\./)?ops/bin/(as6-health-alerts|as6-diagnose-all|as6-platform-command-center|as6-owner-dashboard)([[:space:]]|>|$)'

check_no_real_exec \
  "DIAGNOSTIC_RECURSION_STATUS_NO_CACHE_REFRESH" \
  "ops/bin/as6-health-status" \
  '(^|[ ;|&])(\./)?ops/bin/(as6-health-cache|as6-diagnose-all|as6-platform-command-center|as6-owner-dashboard)([[:space:]]|>|$)'

check_no_real_exec \
  "DIAGNOSTIC_RECURSION_OWNER_NO_DIAGNOSE_ALL" \
  "ops/bin/as6-owner-dashboard" \
  '(^|[ ;|&])(\./)?ops/bin/as6-diagnose-all([[:space:]]|>|$)'

check_no_real_exec \
  "DIAGNOSTIC_RECURSION_PLATFORM_NO_DIAGNOSE_ALL" \
  "ops/bin/as6-platform-command-center" \
  '(^|[ ;|&])(\./)?ops/bin/as6-diagnose-all([[:space:]]|>|$)'

nested_hits="$(
  grep -RInE '(^|[ ;|&])(\./)?ops/bin/as6-diagnose-all([[:space:]]|>|$)' ops/bin/as6-diagnose-* 2>/dev/null \
    | grep -v 'ops/bin/as6-diagnose-diagnostic-recursion' \
    | grep -v 'ops/bin/as6-diagnose-all-registry' \
    | grep -v 'ops/bin/as6-diagnose-diagnostic-coverage' \
    | grep -v 'ops/bin/as6-diagnose-diagnostic-flow' \
    | grep -v 'ops/bin/as6-diagnose-working-tree-safety' \
    | grep -v 'ops/bin/as6-diagnose-diagnostic-performance' \
    | grep -v 'grep -' \
    | grep -v 'echo ' \
    | grep -v 'print(' \
    || true
)"

if [ -n "$nested_hits" ]; then
  echo "DIAGNOSTIC_RECURSION_DIAGNOSE_ALL_NESTED=FAIL"
  echo "$nested_hits"
  fail=1
else
  echo "DIAGNOSTIC_RECURSION_DIAGNOSE_ALL_NESTED=OK"
fi

echo "DIAGNOSTIC_RECURSION_FALSE_POSITIVE_FILTERS=OK"

if [ "$fail" -eq 0 ]; then
  echo "DIAGNOSTIC_RECURSION_RESULT=OK"
  exit 0
fi

echo "DIAGNOSTIC_RECURSION_RESULT=FAIL"
exit 1
