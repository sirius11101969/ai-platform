#!/usr/bin/env bash
set -Eeuo pipefail
ROOT="/var/www/ai-platform"
PAGE="$ROOT/frontend/src/pages/AS6PublicLivingWebsite.jsx"
HOME="$ROOT/frontend/src/pages/AS6PublicBrandHomeV1.jsx"
CSS="$ROOT/frontend/src/pages/AS6PublicBrandHomeV1.css"
test -f "$PAGE"
test -f "$HOME"
test -f "$CSS"
grep -Fq "import AS6PublicBrandHomeV1" "$PAGE"
grep -Fq "return <AS6PublicBrandHomeV1 />;" "$PAGE"
grep -Fq "Ваш бизнес." "$HOME"
grep -Fq "В одном месте." "$HOME"
grep -Fq "Попробовать бесплатно" "$HOME"
grep -Fq "Очень просто." "$HOME"
grep -Fq "Вы всегда знаете" "$HOME"
grep -Fq "@media(max-width:640px)" "$CSS"
grep -Fq "prefers-reduced-motion" "$CSS"
echo "AS6_PUBLIC_ONE_SECOND_MESSAGE=PASS"
echo "AS6_PUBLIC_SINGLE_PRIMARY_ACTION=PASS"
echo "AS6_PUBLIC_CHILD_COMPREHENSION=PASS"
echo "AS6_PUBLIC_BRAND_FOUNDATION_CONTROL=PASS"
