#!/usr/bin/env bash
set -euo pipefail

ROOT="${AS6_REPO_ROOT:-$(git rev-parse --show-toplevel 2>/dev/null || pwd)}"
cd "$ROOT"

echo "=== AS6 Historical Incident Suppressor Diagnostics ==="

fail=0

if ./ops/bin/as6-diagnose-health-history-gap-root-cause >/tmp/as6-historical-suppressor-gap.out 2>&1; then
  cat /tmp/as6-historical-suppressor-gap.out
else
  cat /tmp/as6-historical-suppressor-gap.out
  fail=1
fi

if ./ops/bin/as6-diagnose-health-history-recovery-window >/tmp/as6-historical-suppressor-recovery.out 2>&1; then
  cat /tmp/as6-historical-suppressor-recovery.out
else
  cat /tmp/as6-historical-suppressor-recovery.out
  fail=1
fi

gap_root="$(grep -E '^HEALTH_HISTORY_GAP_ROOT_CAUSE=' /tmp/as6-historical-suppressor-gap.out 2>/dev/null | tail -1 | cut -d= -f2- || true)"
recovery="$(grep -E '^HEALTH_HISTORY_RECOVERY_WINDOW_RESULT=' /tmp/as6-historical-suppressor-recovery.out 2>/dev/null | tail -1 | cut -d= -f2- || true)"

echo "HISTORICAL_SUPPRESSOR_GAP_ROOT_CAUSE=${gap_root:-unknown}"
echo "HISTORICAL_SUPPRESSOR_RECOVERY_WINDOW=${recovery:-unknown}"

if [ "${gap_root:-}" = "HISTORICAL_GAP_TIMER_NOW_OK" ] && [ "${recovery:-}" = "OK" ]; then
  echo "HISTORICAL_INCIDENT_SUPPRESSOR_ACTIVE=YES"
  echo "HISTORICAL_INCIDENT_SUPPRESSOR_REASON=historical_gap_recovered"
  echo "HISTORICAL_INCIDENT_SUPPRESSOR_RESULT=OK"
  exit 0
fi

if grep -q '^HEALTH_RECOVERY_WINDOW_CONFIRMED=YES' /tmp/as6-historical-suppressor-recovery.out 2>/dev/null; then
  echo "HISTORICAL_INCIDENT_SUPPRESSOR_ACTIVE=YES"
  echo "HISTORICAL_INCIDENT_SUPPRESSOR_REASON=recovery_window_confirmed"
  echo "HISTORICAL_INCIDENT_SUPPRESSOR_RESULT=OK"
  exit 0
fi

if [ "$fail" -eq 0 ]; then
  echo "HISTORICAL_INCIDENT_SUPPRESSOR_ACTIVE=NO"
  echo "HISTORICAL_INCIDENT_SUPPRESSOR_RESULT=OK"
  exit 0
fi

echo "HISTORICAL_INCIDENT_SUPPRESSOR_ACTIVE=UNKNOWN"
echo "HISTORICAL_INCIDENT_SUPPRESSOR_RESULT=FAIL"
exit 1
