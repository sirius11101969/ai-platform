#!/usr/bin/env bash
set -euo pipefail
ROOT="${AS6_REPO_ROOT:-$(git rev-parse --show-toplevel 2>/dev/null || pwd)}"
cd "$ROOT"

WF=".github/workflows/as6-codex-review.yml"
fail=0

test -f "$WF" && echo "CODEX_REVIEW_SCOPE_FILE=OK" || { echo "CODEX_REVIEW_SCOPE_FILE=FAIL"; fail=1; }
grep -q "fetch-depth: 0" "$WF" && echo "CODEX_REVIEW_FETCH_DEPTH=OK" || { echo "CODEX_REVIEW_FETCH_DEPTH=FAIL"; fail=1; }
grep -q "github.event.pull_request.base.sha" "$WF" && echo "CODEX_REVIEW_BASE_SHA=OK" || { echo "CODEX_REVIEW_BASE_SHA=FAIL"; fail=1; }
grep -q "github.event.pull_request.head.sha" "$WF" && echo "CODEX_REVIEW_HEAD_SHA=OK" || { echo "CODEX_REVIEW_HEAD_SHA=FAIL"; fail=1; }
grep -q "head -c 60000" "$WF" && echo "CODEX_REVIEW_DIFF_LIMIT=OK" || { echo "CODEX_REVIEW_DIFF_LIMIT=FAIL"; fail=1; }
grep -q "AS6_CODEX_REVIEW_SCOPED_DIFF=OK" "$WF" && echo "CODEX_REVIEW_SAFE_LOG=OK" || { echo "CODEX_REVIEW_SAFE_LOG=FAIL"; fail=1; }
grep -q "continue-on-error: true" "$WF" && echo "CODEX_REVIEW_FAIL_SOFT=OK" || { echo "CODEX_REVIEW_FAIL_SOFT=FAIL"; fail=1; }

if [ "$fail" -eq 0 ]; then
  echo "CODEX_REVIEW_SCOPE_RESULT=OK"
  exit 0
fi

echo "CODEX_REVIEW_SCOPE_RESULT=FAIL"
exit 1
