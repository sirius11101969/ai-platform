#!/usr/bin/env bash
set -uo pipefail
component="${1:-unknown}"
fail=0
echo "=== AS6 Governance Convergence Contract: ${component} ==="
[ -f ops/registry/as6-diagnostic-registry.md ] && echo "AS6_GOVERNANCE_CONVERGENCE_DIAGNOSTIC_REGISTRY=PASS" || { echo "AS6_GOVERNANCE_CONVERGENCE_DIAGNOSTIC_REGISTRY=FAIL"; fail=1; }
[ -f ops/registry/as6-coverage-registry.md ] && echo "AS6_GOVERNANCE_CONVERGENCE_COVERAGE_REGISTRY=PASS" || { echo "AS6_GOVERNANCE_CONVERGENCE_COVERAGE_REGISTRY=FAIL"; fail=1; }
[ -f ops/status/diagnostic-status-registry.json ] && echo "AS6_GOVERNANCE_CONVERGENCE_STATUS_REGISTRY=PASS" || { echo "AS6_GOVERNANCE_CONVERGENCE_STATUS_REGISTRY=FAIL"; fail=1; }
[ -f docs/AS6_PROJECT_STATE.md ] && echo "AS6_GOVERNANCE_CONVERGENCE_STATE=PASS" || { echo "AS6_GOVERNANCE_CONVERGENCE_STATE=FAIL"; fail=1; }
[ -f ops/governance/as6-governance-controller-convergence-policy.md ] && echo "AS6_GOVERNANCE_CONVERGENCE_POLICY=PASS" || { echo "AS6_GOVERNANCE_CONVERGENCE_POLICY=FAIL"; fail=1; }
grep -Fq "AEC_REQUIRE_GOVERNANCE_CONTROLLER_CONVERGENCE" ops/registry/as6-aec-registry.md && echo "AS6_GOVERNANCE_CONVERGENCE_AEC=PASS" || { echo "AS6_GOVERNANCE_CONVERGENCE_AEC=FAIL"; fail=1; }
grep -Fq "GOVERNANCE_CONTROLLER_CONVERGENCE" ops/registry/as6-prevention-registry.md && echo "AS6_GOVERNANCE_CONVERGENCE_PREVENTION=PASS" || { echo "AS6_GOVERNANCE_CONVERGENCE_PREVENTION=FAIL"; fail=1; }
if [ "$fail" -eq 0 ]; then echo "AS6_GOVERNANCE_CONVERGENCE_RESULT=OK:${component}"; exit 0; else echo "AS6_GOVERNANCE_CONVERGENCE_RESULT=FAIL:${component}"; exit 1; fi
