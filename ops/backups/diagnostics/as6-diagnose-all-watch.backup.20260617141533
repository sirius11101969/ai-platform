#!/usr/bin/env bash
set -euo pipefail
cd /var/www/ai-platform

log="${1:-/tmp/as6-diagnose-all-watch.out}"
timeout_seconds="${AS6_DIAGNOSE_ALL_TIMEOUT:-1800}"
slow_threshold="${AS6_WATCH_SLOW_THRESHOLD:-60}"

: > "$log"

echo "AS6_DIAGNOSE_ALL_WATCH_LOG=$log"
echo "AS6_DIAGNOSE_ALL_WATCH_TIMEOUT=${timeout_seconds}s"
echo "AS6_WATCH_SLOW_THRESHOLD=${slow_threshold}s"
echo "AS6_DIAGNOSE_ALL_WATCH_STARTED=$(date -u +%Y-%m-%dT%H:%M:%SZ)"
echo

timeout "$timeout_seconds" ./ops/bin/as6-diagnose-all > "$log" 2>&1 &
pid=$!

cleanup() {
  echo
  echo "AS6_DIAGNOSE_ALL_WATCH_INTERRUPTED=YES"
  kill "$pid" 2>/dev/null || true
}
trap cleanup INT TERM

start="$(date +%s)"
spin='|/-\'
i=0

last_current=""
last_change="$(date +%s)"
last_fail_count=0

stats="/tmp/as6-diagnose-all-watch-controller-stats.tsv"
: > "$stats"
printf "controller\tstarted_at\tended_at\tduration_seconds\n" > "$stats"

while kill -0 "$pid" 2>/dev/null; do
  now="$(date +%s)"
  elapsed=$((now - start))

  current="$(grep '^=== RUN:' "$log" 2>/dev/null | tail -1 | sed -E 's/^=== RUN: //; s/ ===$//' || true)"
  current="${current:-starting}"

  if [ "$current" != "$last_current" ]; then
    if [ -n "$last_current" ] && [ "$last_current" != "starting" ]; then
      duration=$((now - last_change))
      printf "%s\t%s\t%s\t%s\n" "$last_current" "$last_change" "$now" "$duration" >> "$stats"
    fi
    last_current="$current"
    last_change="$now"
  fi

  current_age=$((now - last_change))
  ok="$(grep -c 'AS6_DIAGNOSE_ALL_CHECK=OK:' "$log" 2>/dev/null || true)"
  fail="$(grep -c 'AS6_DIAGNOSE_ALL_CHECK=FAIL:' "$log" 2>/dev/null || true)"

  if [ "$fail" -gt "$last_fail_count" ]; then
    echo
    echo "NEW_FAIL_DETECTED=$(date -u +%Y-%m-%dT%H:%M:%SZ)"
    grep "AS6_DIAGNOSE_ALL_CHECK=FAIL:" "$log" | sort -u | tail -20 || true
    last_fail_count="$fail"
  fi

  slow=""
  if [ "$current_age" -ge "$slow_threshold" ]; then
    slow=" SLOW_CONTROLLER=${current_age}s"
  fi

  printf "\r[%s] elapsed=%ss OK=%s FAIL=%s current_age=%ss current=%s%s          " \
    "${spin:$i:1}" "$elapsed" "$ok" "$fail" "$current_age" "$current" "$slow"

  i=$(((i + 1) % 4))
  sleep 0.2
done

wait "$pid" || rc=$?
rc="${rc:-0}"

finish="$(date +%s)"
if [ -n "$last_current" ] && [ "$last_current" != "starting" ]; then
  duration=$((finish - last_change))
  printf "%s\t%s\t%s\t%s\n" "$last_current" "$last_change" "$finish" "$duration" >> "$stats"
fi

printf "\r[✓] finished exit=%s elapsed=%ss                                      \n" "$rc" "$((finish - start))"

echo
echo "----- FAILS -----"
grep "AS6_DIAGNOSE_ALL_CHECK=FAIL:" "$log" | sort -u || true

echo
echo "----- RESULT -----"
grep "AS6_DIAGNOSE_ALL_RESULT=" "$log" | tail -10 || true

echo
echo "----- SLOW CONTROLLERS -----"
awk -F'\t' 'NR>1 && $4 >= 30 {printf "%-55s %ss\n", $1, $4}' "$stats" | sort -k2 -nr | head -30 || true

echo
echo "----- CONTROLLER TIMINGS -----"
awk -F'\t' 'NR>1 {printf "%-55s %ss\n", $1, $4}' "$stats" | sort -k2 -nr | head -40 || true

echo
echo "----- LAST 40 LINES -----"
tail -40 "$log" || true

exit "$rc"
